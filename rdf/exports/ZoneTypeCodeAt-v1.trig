    <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/Impoundment> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/am> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/am> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:definition "Gewässerstrecke mit anthropogen bedingter Reduktionen der mittleren Fließgeschwindigkeit im Querprofil auf unter 0.3 Meter pro Sekunde bei Mittelwasser (MQ)."@de,
            "Water stretch with anthropogenically caused reductions of average flow velocity in cross sections to less than 0.3 meters per second for medium water level."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt> ;
        skos:notation "Impoundment" ;
        skos:prefLabel "Staustrecke"@de,
