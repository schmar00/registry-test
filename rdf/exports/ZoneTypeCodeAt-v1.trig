    <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/Sanierungsgebiet_Luftreinhalteprogramm> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/am> ;
        dcterms:description "Def. UBA"@de,
            "Def. UBA"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/am> ;
        skos:definition "Sanierungsgebiet ist ein Gebiet, in dem sich die Emissionsquellen befinden, die einen erheblichen Beitrag zur Überschreitung eines Immissionsgrenzwerts geleistet haben und für die in einem Luftreinhalte-Programm Maßnahmen vorgesehen werden können."@de,
            "air quality improvement zone is an area in which the emission sources are located that have made a significant contribution to exceeding an air quality limit value and for which measures can be provided in an air pollution control program."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt> ;
        skos:notation "Sanierungsgebiet_Luftreinhalteprogramm" ;
        skos:prefLabel "Sanierungsgebiet Luftreinhalteprogramm"@de,
            "air quality improvement zone"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/WaterAbstraction> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/am> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/am> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:definition "Abschnitt eines Gewässers, der durch anthropogen bedingte Ableitung bzw. durch anthropogen bedingten Rückhalt von einer Abminderung des natürlichen Abflusses betroffen ist."@de,
            "Section of a flowing water which is affected by anthropogenically caused drainage or restraint due to a reduction of its natural runoff."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt> ;
        skos:notation "WaterAbstraction" ;
        skos:prefLabel "Restwasserstrecke"@de,
            "Water abstraction"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

