        skos:topConceptOf <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/Hydropeaking> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/am> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/am> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:definition "Gewässerstrecke mit anthropogen bedingten Wasserführungsschwankungen mit Schwall-Sunk-Erscheinungen."@de,
            "Water stretch with anthropogenically caused runoff fluctuations and the occurrence of hydropeaking."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt> ;
        skos:notation "Hydropeaking" ;
        skos:prefLabel "Schwallstrecke"@de,
