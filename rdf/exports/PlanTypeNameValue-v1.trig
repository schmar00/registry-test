@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <http://www.w3.org/ns/adms#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://registry.inspire.gv.at/codelist/PlanTypeNameValue:1> {
    <https://registry.inspire.gv.at/codelist/PlanTypeNameValue/gravelControlPlan> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/plu> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Diese Flaechen (Zonen) sind auf Grund von naturschutz-, forstfachlichen, wasserrechtlichen und siedlungstechnischen Gründen für Bergbau und einen Abbau nicht geeignet bzw. auf Grund von rechtlichen Bestimmung für Bergbau und einen Abbau auszuschließen."@de,
            "Areas that are specifically excluded from any types of mining due to technical (i.e. conservation areas, forestry use, water regulations, settlement structures) or legal reasons."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> ;
        skos:notation "gravelControlPlan" ;
        skos:prefLabel "Kiesleitplan"@de,
            "gravel control plan"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/PlanTypeNameValue/greenArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/plu> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Flaechen, die die Funktion für die Land- und Forstwirtschaft, die Erholung und den Tourismus, die Siedlungshygiene und die Klimaverhaeltnisse, die Siedlungs- und Raumgliederung, das typische Orts- und Landschaftsbild, die Sicherung oder Wiederherstellung eines ausgewogenen Natur- und Landschaftshaushalts beibehalten sollen und daher von Bebauung freigehalten werden müssen."@de,
            "Zones to be kept undeveloped to provide steady conditions for agricultural and forestry use, tourism and recreational purposes as well as to foster climate and sanitation; to preserve the characteristics of towns and landscapes and to retain traditional settlement patterns. Provide a substantial basis for the protection and restoration of the ecosystem."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> ;
        skos:notation "greenArea" ;
        skos:prefLabel "Gruenzone"@de,
            "green area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/PlanTypeNameValue/sectoralSpatialPlanningProgram> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/plu> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Sektorale Raumordnungsprogramme konkretisieren die Ziele des Landes NÖ für einzelne Landesteile und legen Maßnahmen verbindlich fest. Sie sind die Grundlage für die weitere räumliche Entwicklung Niederösterreichs."@de,
            "Sectoral spatial planning programs specify the goals of the Province of Lower Austria for individual parts of the country and set binding measures. They form the basis for the further spatial development of Lower Austria."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> ;
        skos:notation "sectoralSpatialPlanningProgram" ;
        skos:prefLabel "Sektorales Raumordnungsprogramm"@de,
            "Sectoral spatial planning program"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/PlanTypeNameValue/zoningPlan> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/plu> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Der Flaechenwidmungsplan hat das Gemeindegebiet entsprechend den angestrebten Zielen zu gliedern und die Widmungsarten für alle Flaechen festzulegen."@de,
            "The zoning plan must classify the municipal area according to the intended goals and determine the types of zoning for all area."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> ;
        skos:notation "zoningPlan" ;
        skos:prefLabel "Flaechenwidmungsplan"@de,
            "Zoning Plan"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/PlanTypeNameValue> a skos:ConceptScheme ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/base2> ;
        dcterms:created "2026-05-05T14:30:11+00:00"^^xsd:dateTime ;
        dcterms:description "Typen von Plänen gemäß Definition in den Mitgliedstaaten."@de,
            "Types of plans as defined in the Member States."@en ;
        dcterms:publisher <https://registry.inspire.gv.at/dataprovider/0021> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/> ;
        dcterms:title "Bezeichnung des Plantyps"@de,
            "Plan Type Name"@en ;
        dcterms:type <http://inspire.ec.europa.eu/codelist/PlanTypeNameValue> ;
        owl:versionInfo "1.0.0" ;
        skos:hasTopConcept <https://registry.inspire.gv.at/codelist/PlanTypeNameValue/gravelControlPlan>,
            <https://registry.inspire.gv.at/codelist/PlanTypeNameValue/greenArea>,
            <https://registry.inspire.gv.at/codelist/PlanTypeNameValue/sectoralSpatialPlanningProgram>,
            <https://registry.inspire.gv.at/codelist/PlanTypeNameValue/zoningPlan> ;
        skos:scopeNote "INSPIRE extensibility: open, internal by value"@en,
            "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .
}

