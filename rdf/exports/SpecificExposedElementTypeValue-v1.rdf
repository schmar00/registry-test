    <skos:definition xml:lang="en">Shipping water areas, rivers and canals and their associated structures (e. g. jetties, locks).</skos:definition>
    <skos:definition xml:lang="de">Bauliche Infrastrukturanlagen zur Herstellung und Versorgung durch elektrischen Strom.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
