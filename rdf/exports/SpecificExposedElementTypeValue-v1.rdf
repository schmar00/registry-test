    <skos:definition xml:lang="de">Bauliche Anlagen die zur privaten, öffentlichen als auch wirtschaftlichen Nutzung verhergesehen sind.</skos:definition>
    <skos:definition xml:lang="en">Buildings for private, public and commercial use.</skos:definition>
