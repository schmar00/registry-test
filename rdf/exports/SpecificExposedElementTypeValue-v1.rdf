  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/remainingRisk">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/nz-core"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone"/>
    <skos:definition xml:lang="de">Restlicher Überflutungsbereich eines Hochwassers mit seltener Eintrittswahrscheinlichkeit.</skos:definition>
    <skos:definition xml:lang="en">Remaining areas of a flood with a rare probability of occurrence.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>remainingRisk</skos:notation>
