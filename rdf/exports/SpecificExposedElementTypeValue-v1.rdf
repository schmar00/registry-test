  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/forestAndAgriculturalTrails">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
