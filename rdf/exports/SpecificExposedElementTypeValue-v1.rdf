  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/waterPipelines">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/nz-core"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/transporAndNetworkInfrastructure"/>
    <skos:definition xml:lang="en">Structural infrastructure facilities for transporting water to places where it is not naturally available.</skos:definition>
    <skos:definition xml:lang="de">Bauliche Infrastrukturanlagen zum Transport von Wasser an Orte, an denen es auf natürlichem Wege nicht zur Verfügung steht.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>waterPipelines</skos:notation>
    <skos:prefLabel xml:lang="en">water pipelines</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Wasserleitungen</skos:prefLabel>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/miscellaneousLoss">
