    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/buildingsAndFacilities"/>
    <skos:definition xml:lang="en">Constructional facilities that serve the public and are therefore accessible to everyone.</skos:definition>
    <skos:definition xml:lang="de">Bauliche Anlagen, die der Öffentlichkeit dienen und daher für jedermann zugänglich sind.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>publicBuilding</skos:notation>
