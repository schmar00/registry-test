    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/buildingsAndFacilities"/>
    <skos:definition xml:lang="de">Gesamtheit mobiler Objekte, die Gebäuden und baulichen Anlagen im direkten Zusammenhang stehen.</skos:definition>
    <skos:definition xml:lang="en">A set of mobile objects that are directly related to buildings and facilities.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>inventoryAndEquipment</skos:notation>
    <skos:prefLabel xml:lang="en">inventory and equipment</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Inventar und Geraetschaften</skos:prefLabel>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
