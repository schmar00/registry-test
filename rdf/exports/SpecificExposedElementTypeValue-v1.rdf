    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/transporAndNetworkInfrastructure"/>
    <skos:definition xml:lang="en">Structural objects that serve as a transport route for the appropriate management of agricultural and forestry properties.</skos:definition>
    <skos:definition xml:lang="de">Bauliche Objekte, die als Transportweg zur zweckmäßigen Bewirtschaftung von land- und forstwirtschaftlichen Liegenschaften dienen.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>forestAndAgriculturalTrails</skos:notation>
    <skos:prefLabel xml:lang="de">Forst und Agrarwege</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Forest and agricultural trails</skos:prefLabel>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
