    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/transporAndNetworkInfrastructure"/>
    <skos:definition xml:lang="de">Schiffbare Wasserflächen, Flüsse und Kanäle und deren dazugehörgigen baulichen Anlagen (z.B. Anlegesteg, Schleussen)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>waterpathTransport</skos:notation>
    <skos:prefLabel xml:lang="de">Wasserweg</skos:prefLabel>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/formerRedZone">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/nz-core"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone"/>
    <skos:definition xml:lang="en">These are risk areas where flood protection systems are in operation. When a flood event exceeds the degree of protection or a technical fault occurs, the flood protection system does not function, flooding occurs to a degree similar to the absence of the flood protection system. New buildings are to be built flood-proof in this area.</skos:definition>
    <skos:definition xml:lang="de">Hierbei handelt es sich um Restrisikogebiete im Wirkungsbereich von Hochwasserschutzanlagen. Wenn ein Hochwasserereignis das Bemessungsereignis übersteigt bzw. in Folge eines technischen Gebrechens die Hochwasserschutzanlage nicht funktioniert, kommt es im Wirkungsbereich der Hochwasserschutzanlage zu Überflutungen in einem Ausmaß ähnlich wie bei Nichtvorhandensein der Hochwasserschutzanlage. Neubauten sind in diesem Bereich hochwassergeschützt zu errichten.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>formerRedZone</skos:notation>
    <skos:prefLabel xml:lang="en">former red zone</skos:prefLabel>
    <skos:prefLabel xml:lang="de">ehemals Rote Zone</skos:prefLabel>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/nz-core"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:definition xml:lang="en">Group of applied classification zones.</skos:definition>
    <skos:definition xml:lang="de">Gruppe von verwendeten Klassen.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/yellowZone"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/blueZone"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/formerRedZone"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/redYellowZone"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/redZone"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/remainingRisk"/>
    <skos:notation>classificationZone</skos:notation>
    <skos:prefLabel xml:lang="en">classification zones</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Klassifikationszonen</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/electricalInstallations">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
