    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/yellowZone">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/nz-core"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone"/>
    <skos:definition xml:lang="de">Bereiche die von Hochwasser mit mittlerer Eintrittswahrscheinlichkeit geringer gefährdet sind. Neubauten in dieser Zone sind hochwassergeschützt zu errichten.</skos:definition>
    <skos:definition xml:lang="en">Areas that are less vulnerable to floods with a medium probability of occurrence. New buildings in this zone are to be built flood-proof.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>yellowZone</skos:notation>
    <skos:prefLabel xml:lang="en">yellow zone</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Gelbe Zone</skos:prefLabel>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
