    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone"/>
    <skos:definition xml:lang="en">These areas are intended as retention, drainage and water management priority zones and are of great importance for the safe discharge and flood retention in flood situations.</skos:definition>
    <skos:definition xml:lang="de">Diese Bereiche sind als Retentions-, Abfluss- und wasserwirtschaftliche Vorrangzonen vorgesehen und sind für den schadlosen Abfluss und Hochwasserrückhalt im Hochwasserfall von großer Bedeutung.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"/>
    <skos:notation>redYellowZone</skos:notation>
    <skos:prefLabel xml:lang="de">Rot Gelbe Zone</skos:prefLabel>
    <skos:prefLabel xml:lang="en">red yellow zone</skos:prefLabel>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
