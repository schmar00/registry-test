    <skos:prefLabel xml:lang="de">Oeffentliche Gebaeude</skos:prefLabel>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/buildingsAndFacilities">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
