    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme"/>
    <skos:definition xml:lang="de">Datensatz, Dienst oder Dokument wird auf dem Open Governmental Data Portal veröffentlicht.</skos:definition>
    <skos:definition xml:lang="en">Data and data service or document is published at the OGD Portal.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/DirectiveRelevance"/>
    <skos:notation>ogdIdentified</skos:notation>
