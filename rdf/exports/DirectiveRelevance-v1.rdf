    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme"/>
    <skos:definition xml:lang="de">Datensatz, Dienst ist INSPIRE-relevant.</skos:definition>
    <skos:definition xml:lang="en">Data and data service has a INSPIRE relevance.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/DirectiveRelevance"/>
    <skos:notation>inspireIdentified</skos:notation>
    <skos:prefLabel xml:lang="de">INSPIRE identifiziert</skos:prefLabel>
    <skos:prefLabel xml:lang="en">INSPIRE identified</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/DirectiveRelevance"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/DirectiveRelevance/ogdIdentified">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
