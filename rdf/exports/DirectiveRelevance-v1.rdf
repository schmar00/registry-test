    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme"/>
    <skos:definition xml:lang="de">Datensatz, Dienst oder Dokument ist konform zur Public-Sector-Information Richtlinie.</skos:definition>
    <skos:definition xml:lang="en">Data and data service or document is compliant with EU Public Sector Information Directive.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/DirectiveRelevance"/>
    <skos:notation>psiKonform</skos:notation>
