<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:ns1="http://www.w3.org/ns/adms#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/FeuchtgebietsObjekt">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/hb"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/hb"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare"/>
    <skos:definition xml:lang="en">Invntory of Wetlands in Austria; total area of wetlands assessd in Nov. 2008 ammounts to 2744 km2 divided into 889 wetland objects</skos:definition>
    <skos:definition xml:lang="de">Abgrenzung der Feuchtgebiete gemäß Feuchtgebietsinventar, Abgrenzung generalisiert; Insgesamt umfasst das Feuchtgebietsinventar Österreich im November 2008 insgesamt 889 Feuchtgebiete. Die Gesamtfläche der beschriebenen Gebiete beträgt mehr als 2744.0 km2. Das Inventar wird laufend durch Expertenmeldungen laufend erweitert.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe"/>
    <skos:notation>FeuchtgebietsObjekt</skos:notation>
    <skos:prefLabel xml:lang="en">Wetland object</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Feuchtgebietsobjekt</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/hb"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/hb"/>
    <skos:definition xml:lang="de">Naturschutzfachliche Inventare, die zumeist sehr spezifische Ökosysteme (Moore, Feuchtgebiete, Trockenrasen etc.) abdecken</skos:definition>
    <skos:definition xml:lang="en">nature conservation inventories that cover mostly very specific ecosystem types (e.g. bogs and mires, wetlands, dry grasslands, etc.)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/TrockenrasenObjekt"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/MoorObjekt"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/FeuchtgebietsObjekt"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/AuenObjekt"/>
    <skos:notation>Naturschutzinventare</skos:notation>
    <skos:prefLabel xml:lang="de">Naturschutzinventare</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Nature conservation inventories</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/AuenObjekt">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/hb"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/hb"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare"/>
    <skos:definition xml:lang="en">Inventory of floodplain objects in Austria (minimum area 20 ha) and detailed mapping in Carinthia and Styria (minimum area 5 ha).822 floodplain properties with a total area of 95,541 ha were designated.  Credits: Werner LAZOWSKI and Ulrich SCHWARZ, Aueninventar Austria: Report on the nationwide overview of floodplain objects, Vienna, 2011; Reference: Siehe: https://www.bmlrt.gv.at/dam/jcr:988293c2-2c0e-424d-86dd-91721197be61/%C3%96sterreichisches%20Aueninventar_Final_20111108.pdf</skos:definition>
    <skos:definition xml:lang="de">Inventar der Auobjekte Österreichs (Minimalfläche 20 ha) und Detailkartierung in Kärnten und Steiermark (Minimalfläche 5 ha). 822 Auenobjekte mit einer Gesamtfläche von 95.541 ha. , Credits: Werner LAZOWSKI und Ulrich SCHWARZ, Aueninventar Österreich: Bericht zur bundesweiten Übersicht der Auobjekte, Wien, 2011; Siehe: https://www.bmlrt.gv.at/dam/jcr:988293c2-2c0e-424d-86dd-91721197be61/%C3%96sterreichisches%20Aueninventar_Final_20111108.pdf</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe"/>
    <skos:notation>AuenObjekt</skos:notation>
    <skos:prefLabel xml:lang="en">Floodplain object</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Auenobjekt</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/MoorObjekt">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/hb"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/hb"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare"/>
    <skos:definition xml:lang="de">Moorflächen aus dem Moorschutzkatalog (Steiner et al. 1992), Hrsg.: Bundesministerium für Gesundheit und Umweltschutz, Credits: Gert Michael STEINER unter Mitarbeit von P. Englmaier, M. Fink, F, Grünweis, I. Höfner I. Korner, A. Ströhle und W. Wolf (im Auftrag des Bundesministeriums für Gesundheit und Umweltschutz), Wien, 1992</skos:definition>
    <skos:definition xml:lang="en">Bog and mire inventory</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe"/>
    <skos:notation>MoorObjekt</skos:notation>
    <skos:prefLabel xml:lang="de">Moorobjekt</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Bog and Mire object</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/TrockenrasenObjekt">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/hb"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/hb"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare"/>
    <skos:definition xml:lang="en">Mapping of dry meadows in Austria</skos:definition>
    <skos:definition xml:lang="de">Flächenhaft abgegrenzte Trockenrasen Österreichs mit Stand 1986; vielfach schon sehr veralterte Information, Gesamtanzahl der flächenhaft abgegrenzten Trockenrasen: 682. Erstabgrenzung anhand der topographischen Karte ÖK 50; Abgrenzung vor allem in Ostösterreich (Sauberer), Ergänzung im Jahr 2008 durch VINCA und Aufbereitung durch Digitalisierung.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe"/>
    <skos:notation>TrockenrasenObjekt</skos:notation>
    <skos:prefLabel xml:lang="de">Trockenrasenobjekt</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Dry meadow object</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/hb"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-05T14:30:11+00:00</dcterms:created>
    <dcterms:description xml:lang="en">generalized habitat complexes that establish a functional relation between different habitat types and that are assessd in single projects</dcterms:description>
    <dcterms:description xml:lang="de">generalisierte Habitatkomplexe, die eine funktionalen Zusammenhang zwischen mehreren Biotoptypen darstellen und im Rahmen von Einzelprojekten erhoben werden</dcterms:description>
    <dcterms:publisher rdf:resource="https://registry.inspire.gv.at/dataprovider/0008"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/hb"/>
    <dcterms:title xml:lang="en">generalized habitatcomplexes</dcterms:title>
    <dcterms:title xml:lang="de">generalisierte Habitatkomplexe</dcterms:title>
    <dcterms:type rdf:resource="http://inspire.ec.europa.eu/codelist/LocalNameCodeValue"/>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare"/>
    <skos:scopeNote xml:lang="en">INSPIRE extensibility: open, internal by value</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
</rdf:RDF>
