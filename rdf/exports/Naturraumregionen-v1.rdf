    <skos:scopeNote xml:lang="en">INSPIRE extensibility: open, internal by value</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/Naturraumregionen/NAV">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/br"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/br"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/Naturraumregionen/KONT"/>
    <skos:definition xml:lang="de">Vorland nördlich der Alpen unter Ausschluss der Flyschzone</skos:definition>
    <skos:definition xml:lang="en">only available in german</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/Naturraumregionen"/>
    <skos:notation>NAV</skos:notation>
    <skos:prefLabel xml:lang="en">northern foothils of the Alps</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Nördliches Alpenvorland</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/Naturraumregionen/ZAlpZ">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/br"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/br"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/Naturraumregionen/ZAlp"/>
    <skos:definition xml:lang="de">Untergliederund der Zentralalpen aufgrund pysiogeograühischer Charakteristika (überwiegend Hochgebirgscharakter und reicht vom Montafon im Westen über die Silvretta, den Ötzlater und Stubaier Alpen, den Hohen Tauern bis zu den Niederen Tauern im Westen)</skos:definition>
    <skos:definition xml:lang="en">only available in german</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/Naturraumregionen"/>
    <skos:notation>ZAlpZ</skos:notation>
    <skos:prefLabel xml:lang="de">Zentralalpen - zentraler Teil</skos:prefLabel>
    <skos:prefLabel xml:lang="en">central Alps - central part</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
