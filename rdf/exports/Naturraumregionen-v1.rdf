    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-05T14:30:11+00:00</dcterms:created>
    <dcterms:description xml:lang="en">Physiogeographic Ecoregions in Austria divided into 7 main zones and 10 subregions; Credits: SAUBERER, N., GRABHERR, G. 1995: Fachliche Grundlagen zur Umsetzung der FFH-Richtlinie in Österreich. Schwerpunkt Lebensräume. Umweltbundesamtes Report 115.</dcterms:description>
    <dcterms:description xml:lang="de">Naturräumliche Gliederung Österreichs (Naturraumregionen bzw. Ökozonen) nach 7 Hauptzonen und 10 Unterregionen, Credits: SAUBERER, N., GRABHERR, G. 1995: Fachliche Grundlagen zur Umsetzung der FFH-Richtlinie in Österreich. Schwerpunkt Lebensräume. Report des Umweltbundesamtes 115.</dcterms:description>
    <dcterms:publisher rdf:resource="https://registry.inspire.gv.at/dataprovider/0008"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/br"/>
    <dcterms:title xml:lang="en">Physiogeographic Ecoregions</dcterms:title>
    <dcterms:title xml:lang="de">Naturraumregionen</dcterms:title>
    <dcterms:type rdf:resource="http://inspire.ec.europa.eu/codelist/RegionClassificationValue"/>
    <owl:versionInfo>1.0.0</owl:versionInfo>
