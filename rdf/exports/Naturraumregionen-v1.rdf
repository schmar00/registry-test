    <skos:definition xml:lang="de">Untegrliederung der Zentralalpen aufgrund physiogeographischer Charakteristika (überwiegend Mittelgebirgscharakter und umfaßt die Buckelige Welt, das steirische Bergland, die Fischbacher Alpen, die Gleinalpe, die Koralpe, die Seetaler Apen und die Nochberge)</skos:definition>
    <skos:definition xml:lang="en">only available in german</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/Naturraumregionen"/>
    <skos:notation>ZAlpSO</skos:notation>
    <skos:prefLabel xml:lang="de">Zentralalpen - südöstlicher Teil</skos:prefLabel>
    <skos:prefLabel xml:lang="en">central Alps - southeastern part</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
