    <skos:definition xml:lang="de">sind Flächen für Einkaufszentren.</skos:definition>
    <skos:definition xml:lang="en">are areas for shopping centers.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>shoppingCenters</skos:notation>
    <skos:prefLabel xml:lang="en">Shopping centers</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Einkaufszentren</skos:prefLabel>
