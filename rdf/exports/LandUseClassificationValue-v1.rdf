  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/residentialAreas">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Wohnen sind Gebiete die ausschließlich oder vornehmlich für Wohnzwecke bestimmt sind.</skos:definition>
    <skos:definition xml:lang="en">Residential areas are areas that are exclusively or primarily intended for residential purposes.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>residentialAreas</skos:notation>
    <skos:prefLabel xml:lang="de">Wohnen</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Residential areas</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/waterBodies">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">Making visible the supra-local legally effective definition of water bodies.</skos:definition>
    <skos:definition xml:lang="de">Ersichtlichmachung der überörtlich rechtwirksamen Festlegung Gewässer.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>waterBodies</skos:notation>
    <skos:prefLabel xml:lang="en">Water Bodies</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Gewässer</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/rAIndustry">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">SG-Industrie sind nicht vollwertige Baulandflächen, die nach Beseitigung von Mängel zu vollwertigen Industriegebieten werden.</skos:definition>
    <skos:definition xml:lang="en">RA-Industrial areas are not fully fledged building land, which become fully fledged industrial areas once defects have been remedied.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>rAIndustry</skos:notation>
    <skos:prefLabel xml:lang="de">SG-Industrie</skos:prefLabel>
    <skos:prefLabel xml:lang="en">RA-Industry</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/fAResidentialArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">FA-Residential area are undeveloped gaps in the building land, which can be declared a residential area once the legal criteria are met.</skos:definition>
    <skos:definition xml:lang="de">AF-Wohnen sind unbebaute Lücken  im Bauland, die nach Vorliegen der rechtlichen Kriterien als Wohngebiet erklärt werden können.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>fAResidentialArea</skos:notation>
    <skos:prefLabel xml:lang="en">FA-Residential area</skos:prefLabel>
    <skos:prefLabel xml:lang="de">AF-Wohnen</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/villageAreas">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">Village areas are areas which are intended for buildings of agricultural and forestry use in a dense arrangement.</skos:definition>
    <skos:definition xml:lang="de">Dorfgebiet sind Flächen, die für Bauten  land- und forstwirtschaftlicher Nutzung in verdichteter Anordnung bestimmt sind.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>villageAreas</skos:notation>
    <skos:prefLabel xml:lang="en">Village areas</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Dorfgebiet</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/industryAndCommerce">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">sind Flächen für Gewerbe und Industrie inklusive Verwaltungsgebäuden und die für die Aufrechterhaltung erforderlichen Wohnungen.</skos:definition>
    <skos:definition xml:lang="en">are areas for trade and industry including administrative buildings and the apartments required for maintenance.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>industryAndCommerce</skos:notation>
    <skos:prefLabel xml:lang="en">Industry and commerce</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Industrie und Gewerbe</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-05T14:30:11+00:00</dcterms:created>
    <dcterms:description xml:lang="en">List of land use categories to be used in INSPIRE Land Use and agreed at a national or local level.</dcterms:description>
    <dcterms:description xml:lang="de">Liste der für das INSPIRE-Thema Bodennutzung zu verwendenden und auf nationaler oder lokaler Ebene abgestimmten Bodennutzungskategorien.</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <dcterms:title xml:lang="de">Klassifikation der Bodennutzung</dcterms:title>
    <dcterms:title xml:lang="en">Land Use Classification</dcterms:title>
    <dcterms:type rdf:resource="http://inspire.ec.europa.eu/codelist/LandUseClassificationValue"/>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/waterBodies"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/villageAreas"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/trafficAreas"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/specialUseOpenland"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/shoppingCenters"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/residentialAreas"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/rAVillage"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/rAResidentialArea"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/rAIndustry"/>
