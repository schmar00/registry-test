    <dcterms:description xml:lang="de">Def. NOE</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Fasst die Baulandwidmungsarten Wohngebiete (BW), Agrargebiete (BA), Kerngebiete (BK) und Gebiete fuer erhaltenswerte Ortsstrukturen (BO) zusammen (inkl. Aufschließungszonen bzw. wenn als Folgenutzungsart angegeben).</skos:definition>
    <skos:definition xml:lang="en">Covers building land use types residential areas (BW), agricultural areas (BA), core areas (BK) and areas with local structures worth preserving (BO) (incl. development zones or if subsequent type of use is specified).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>buildingLandResidentialOrMixedUse</skos:notation>
    <skos:prefLabel xml:lang="en">Building land residential or mixed use</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Bauland Wohn oder Mischnutzung</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/buildingLandSpecialZone">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. NOE</dcterms:description>
    <dcterms:description xml:lang="de">Def. NOE</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">Building land - special zones for uses that require particular protection such as hospitals, schools, nursing homes, or that are to be assigned a specific location, such as asphalt mixing plants, or that cannot be categorised under other building use types, such as barracks or sports facilities.</skos:definition>
    <skos:definition xml:lang="de">Bauland Sondergebiete, fuer Nutzungen, die einen besonderen Schutz wie Krankenanstalten, Schulen, Pflegeheime erfordern oder denen ein bestimmter Standort zugeordnet werden soll wie Asphaltmischanalgen oder die sich nicht in die anderen Baulandwidmungen einordnen lassen wie Kasernen oder Sportanlagen.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>buildingLandSpecialZone</skos:notation>
    <skos:prefLabel xml:lang="en">Building land special zone</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Bauland-Sondergebiet</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/greenLandOpenSpaceArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. NOE</dcterms:description>
    <dcterms:description xml:lang="de">Def. NOE</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">Green land - open space areas (to be left completely undeveloped).</skos:definition>
    <skos:definition xml:lang="de">Freihalteflaechen (ist von jeglicher Bebauung frei zu halten).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>greenLandOpenSpaceArea</skos:notation>
    <skos:prefLabel xml:lang="de">Gruenland FreihalteflaecheGruenland</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Green land open space area</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/mainAreas">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Kerngebiete sind Flächen mit einer im Vergleich zu anderen Baugebieten höheren Nutzungsvielfalt und Bebauungsdichte.</skos:definition>
    <skos:definition xml:lang="en">Are areas with a higher variety of uses and building density compared to other building areas.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>mainAreas</skos:notation>
    <skos:prefLabel xml:lang="en">Main areas</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Kerngebiet</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/buildingLandCoreAreaCommercialFacilities">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. NOE</dcterms:description>
    <dcterms:description xml:lang="de">Def. NOE</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">Building land - core area commercial facilities.</skos:definition>
    <skos:definition xml:lang="de">Bauland Kerngebiet-Handelseinrichtungen</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>buildingLandCoreAreaCommercialFacilities</skos:notation>
    <skos:prefLabel xml:lang="en">Building land core area commercial facilities</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Bauland-Kerngebiet Handelseinrichtungen</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/greenLandSportsFacility">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">v</dcterms:description>
    <dcterms:description xml:lang="de">Def. NOE</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Gruenland Sportstaetten.</skos:definition>
    <skos:definition xml:lang="en">Green land - sports facilities.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>greenLandSportsFacility</skos:notation>
    <skos:prefLabel xml:lang="de">Gruenland Sportstaette</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Green land sports facility</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/dAIndustry">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">DA-Industry are not yet fully developed industrial sites, but their production is expected and they are not designated as redevelopment sites.</skos:definition>
    <skos:definition xml:lang="de">AS-Industrie sind noch nicht vollwertige Industrieflächen, deren Herstellung aber zu erwarten ist und die nicht als Sanierungsgebiete ausgewiesen sind.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>dAIndustry</skos:notation>
    <skos:prefLabel xml:lang="en">DA-Industry</skos:prefLabel>
    <skos:prefLabel xml:lang="de">AS-Industrie</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/rAVillage">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">SG-Dorf  sind nicht vollwertige Baulandflächen, die nach Beseitigung von Mängel zu vollwertigen Dorfgebiet werden.</skos:definition>
    <skos:definition xml:lang="en">RA-Villages are not fully-fledged building land which, once defects have been remedied, become fully-fledged village areas.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>rAVillage</skos:notation>
    <skos:prefLabel xml:lang="de">SG-Dorf</skos:prefLabel>
    <skos:prefLabel xml:lang="en">RA-Village</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LandUseClassificationValue/openland">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. STMRK</dcterms:description>
    <dcterms:description xml:lang="de">Def. STMRK</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Alle nicht als Bauland und Verkehrsland festgelegte Grundflächen gehören zum Freiland. Im Freiland können Sondernutzungen festgelegt werden (z.B.: öffentliche Parkanlagen).</skos:definition>
    <skos:definition xml:lang="en">All land not designated as building land or traffic land belongs to the open land. Special uses can be defined in the open land (e.g.: public parks).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <skos:notation>openland</skos:notation>
    <skos:prefLabel xml:lang="en">Openland</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Freiland</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LandUseClassificationValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
