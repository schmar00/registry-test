  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor/coreArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/hb"/>
    <dcterms:description xml:lang="en">OOE</dcterms:description>
    <dcterms:description xml:lang="de">OOE</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/hb"/>
    <skos:definition xml:lang="de">Gebiete mit hoher Waldausstattung (&gt; 50 % Flächenanteil) und guter Eignung als Lebensraum für waldgebundene Tierarten mit großen Raumansprüchen. Größere geschlossene Waldgebiete, kaum Siedlungsinfrastruktur und Zerschneidung durch hochrangige Verkehrsträger, kleinteilige Kulturlandschaft.</skos:definition>
    <skos:definition xml:lang="en">Areas with a high portion of woodland (more than 50 % of total amount) and appropriate habitat function for large forest animals. Larger closed woodland areas or highly diverse cultural landscapes, hardly or not fragmented by traffic infrastructure and settlements.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor"/>
    <skos:notation>coreArea</skos:notation>
    <skos:prefLabel xml:lang="de">Kernzone</skos:prefLabel>
    <skos:prefLabel xml:lang="en">core area</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
