  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor/transitionArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/hb"/>
    <dcterms:description xml:lang="en">OOE</dcterms:description>
    <dcterms:description xml:lang="de">OOE</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/hb"/>
    <skos:definition xml:lang="de">Gebiete mit signifikanter Waldausstattung (30-50 % Flächenanteil) und eingeschränkter Eignung als Lebensraum für waldgebundene Tierarten mit großen Raumansprüchen. Strukturreiche Kulturlandschaft mit vielen Kleinwaldflächen, wenig Siedlungsinfrastruktur, geringe Zerschneidung durch hochrangige Verkehrsträger.</skos:definition>
    <skos:definition xml:lang="en">Areas with a sginificant portion of woodland (30-50 % of total amount) and reduced habitat function for large forest animals. Diverse cultural landscape with small structured forest areas, only moderately fragmented by traffic infrastructure and settlements.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor"/>
    <skos:notation>transitionArea</skos:notation>
    <skos:prefLabel xml:lang="de">Uebergangszone</skos:prefLabel>
    <skos:prefLabel xml:lang="en">transition area</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
