  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ooeLandUseValue/recreationalAreas">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. OOE, Kennzahl 13101, 13102, 13103, 13104, 13105, 13106, 13107, 13108, 13109, 13110, 13100</dcterms:description>
    <dcterms:description xml:lang="de">Def. OOE, Kennzahl 13101, 13102, 13103, 13104, 13105, 13106, 13107, 13108, 13109, 13110, 13100</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Flaechen fuer Erholungs- oder Sportanlagen wie Parkanlagen, Spiel- und Liegewiesen, Sport- und Spielflaechen, Freibaeder, Campingplaetze, Tennishallen, Golfplaetze, Reitsportanlagen, Gaststaetten und Schutzhuetten sowie Wintersportanlagen einschliesslich der Schipisten</skos:definition>
    <skos:definition xml:lang="en">Areas for recreational, parks, playgrounds, sports facilities, outdoor swimming pools, campsites, tennis halls, golf courses, equestrian facilitiies, winter sport facilities, protective huts and slopes</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/ooeLandUseValue"/>
    <skos:notation>recreationalAreas</skos:notation>
    <skos:prefLabel xml:lang="en">recreational areas</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Erholungsflaechen</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/ooeLandUseValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
