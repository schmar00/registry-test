  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ooeLandUseValue/reservedArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lunom"/>
    <dcterms:description xml:lang="en">Def. OOE, Kennzahl 14001, 14002, 14003, 14004, 14005, 14006, 14007, 14008, 14009, 14010, 14011, 14012, 14013, 14000</dcterms:description>
    <dcterms:description xml:lang="de">Def. OOE, Kennzahl 14001, 14002, 14003, 14004, 14005, 14006, 14007, 14008, 14009, 14010, 14011, 14012, 14013, 14000</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Vorbehaltsflaechen fuer oeffentlichen Zwecken dienenden Bauwerken und Anlagen (Verwaltungsgebaeude, Schule, Krankenanstalt, Altersheim, Heil- und Pflegeanstalt, Altstoffsammelzentrum, Jugendheim oder Jugendherberge, Seelsorgeeinrichtung, Kindergarten, Hallenbad, Feuerwehr, Luftschutzanlage, Hochwasserschutzanlagen, Ergaenzungsmoeglichkeiten fuer Vorbehaltsflaechen)</skos:definition>
    <skos:definition xml:lang="en">Land reserved for public facilities (governmental office, school, hospital, retirement home, nursing home or sanatorium, waste collection center, youth center, counseling facility, kindergarden, indoor pool, fire department, air-raid shelter, flood protection, possible augmentation of facilty)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/ooeLandUseValue"/>
    <skos:notation>reservedArea</skos:notation>
    <skos:prefLabel xml:lang="de">Vorbehaltsflaechen</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Reserved areas</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/ooeLandUseValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ooeLandUseValue/existingFacilitiesReservedArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
