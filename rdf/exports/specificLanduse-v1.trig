        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Golfplätze sind eine besondere Form einer Sportstätte."@de,
            "Golf Course"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificLanduse> ;
        skos:notation "golfCourse" ;
        skos:prefLabel "Golfplatz"@de,
            "Golf Course"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificLanduse> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificLanduse/skiSlope> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/selu> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Teil eines Berges, der für das Skifahren und das Snowboardfahren vorgesehen ist."@de,
            "ki Slope"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificLanduse> ;
        skos:notation "skiSlope" ;
        skos:prefLabel "Skipiste"@de,
            "Ski Slope"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificLanduse> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificLanduse> a skos:ConceptScheme ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/base2> ;
        dcterms:created "2026-05-05T14:30:11+00:00"^^xsd:dateTime ;
        dcterms:description "Liste der für das INSPIRE-Thema Bodennutzung zu verwendenden und auf nationaler oder lokaler Ebene abgestimmten Bodennutzungskategorien."@de,
            "List of land use categories to be used in INSPIRE Land Use and agreed at a national or local level."@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/> ;
        dcterms:title "spezifische Landnutzung"@de,
