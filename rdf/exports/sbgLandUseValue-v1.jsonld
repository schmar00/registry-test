    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Ablagerungsplätze sind Flächen, auf denen Materialien auf Dauer deponiert werden, um sich ihrer zu entledigen"
      }
    ],
