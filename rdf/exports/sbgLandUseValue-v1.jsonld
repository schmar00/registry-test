      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Als Bau-, Möbel- oder Gartenmärkte gelten Handelsgroßbetriebe, die Waren für Baumaßnahmen, die Raumausstattung bzw die Raum- oder Gartengestaltung sowie allenfalls in geringfügigem Ausmaß Lebens- und Genußmittel anbieten."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue"
