  {
    "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue/BALK",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lunom"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lu"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Ländliche Kerngebiete sind Flächen im Bereich bereits überwiegend bebauter Gebiete, die bestimmt sind für a) Klein- und Mittelbetriebe des Handels und des Gewerbes, die keine übermäßige Geruchs- oder Lärmbelästigung, sonstige Luftverunreinigung oder Erschütterung für die Nachbarschaft und keinen übermäßigen Straßenverkehr verursachen und keine Gefährdung der Umgebung durch Explosions- oder Strahlungsgefahr zu verursachen geeignet sind; b) Bauten des Fremdenverkehrs; c) land- und forstwirtschaftliche Betriebsbauten; d) sonstige in Z 2 angeführte Bauten;"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue"
      }
    ],
