      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue/BAIG",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lunom"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lu"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Industriegebiete sind Flächen, die bestimmt sind für a) Betriebe, auch wenn sie eine übermäßige Beeinträchtigung der Umgebung verursachen oder eine besondere räumliche Ausdehnung aufweisen; nicht jedoch Betriebe, die in hohem Maß Explosions- oder Strahlungsgefahr für die Umgebung erwarten lassen; b) betriebsbedingte Wohnungen und Einrichtungen"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue"
      }
    ],
