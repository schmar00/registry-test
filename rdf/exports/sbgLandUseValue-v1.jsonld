      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue/BASF",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lunom"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lu"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Sonderflächen sind Flächen für Bauten und Anlagen, a) die sich nach der Art oder den Umständen des jeweiligen Vorhabens nicht unter die Z 1 bis 10 einordnen lassen (wie Kasernen, größere Kranken- und Kuranstalten); b) die aufgrund ihres Verwendungszweckes an einen bestimmten Standort gebunden sind oder für die ein bestimmter Standort besonders geeignet ist (wie Fernwärmeerzeugungsanlagen, zentrale Abwasserreinigungsanlagen, Tankstellen, Liftstationen, bestehende einzelstehende Betriebe im Grünland)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "BASF"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Sonderflächen"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
