      {
        "@language": "de",
        "@value": "Sonstige Flächen sind alle sonstigen, nicht als Bauland oder als Verkehrsfläche ausgewiesenen Flächen"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
