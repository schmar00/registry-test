      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Lagerplätze sind Flächen über 1.000 m2, die dauernd der vorübergehenden Lagerung von Materialien außerhalb von Bauten dienen"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
