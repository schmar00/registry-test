      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Erholungsgebiete sind Flächen, die für öffentlich zugängliche Gärten und Parkanlagen sowie sonstige für die Gesundheit und Erholung notwendige Grünflächen bestimmt sind"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue"
