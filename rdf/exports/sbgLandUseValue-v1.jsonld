      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lu"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Als Verkehrsflächen sind wichtige Verkehrsflächen der Gemeinde samt den dazugehörigen baulichen Anlagen und den angrenzenden Grünstreifen auszuweisen, die für die Anlage oder ihren Schutz notwendig sind. Dazu gehören auch solche Verkehrsflächen, die in nächster Zukunft einem solchen Zweck gewidmet werden sollen."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/sbgLandUseValue"
      }
