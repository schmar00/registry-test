        "@language": "de",
        "@value": "Sonstige nicht als Bauland oder Verkehrsfläche ausgewiesene Flächen"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
