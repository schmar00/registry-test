@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <http://www.w3.org/ns/adms#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://registry.inspire.gv.at/codelist/specialisedZoneType:1> {
    <https://registry.inspire.gv.at/codelist/specialisedZoneType/exclusion> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/am> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/am> ;
        skos:definition "In Ausschlusszonen ist die Errichtung von Windkraftanlagen unzulässig."@de,
            "In exclusion zones is the erection of wind power plants not permitted."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specialisedZoneType> ;
        skos:notation "exclusion" ;
        skos:prefLabel "Ausschluss"@de,
            "exclusion"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specialisedZoneType> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specialisedZoneType/priority> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/am> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/am> ;
        skos:definition "In Vorrangzonen ist die Errichtung von Windkraftanlagen mit einer Nennleistung von mindestens 0,5 Megawatt zulässig für nachstehende Projekte, die folgende Voraussetzungen erfüllen: 1. bei der Neuerrichtung von Windkraftanlagen muss eine elektrische Gesamtleistung von mindestens 15 MW erreicht werden; 2. bei der Erweiterung von bestehenden Windkraftanlagen muss eine zusätzliche elektrische Gesamtleistung von mindestens 7,5 MW erreicht werden; 3. bei sonstigen Erweiterungen von bestehenden Windkraftanlagen muss bereits vor der Erweiterung ein Verfahren nach UVP-G 2000, BGBl. I Nr. 80/2018, durchgeführt worden sein. Im Zuge einer allfälligen Umweltverträglichkeitsprüfung soll durch geeignete Maßnahmen sichergestellt werden, dass dauerbewirtschaftete Schutzhütten und Weitwanderwege in ihrer Funktion nicht beeinträchtigt werden."@de,
            "In priority zones, the erection of wind turbines with a rated output of at least 0.5 megawatts is permitted for the following projects that meet the following requirements: 1. the new construction of wind power plants must achieve a total electrical output of at least 15 MW 2. when expanding existing wind power plants, an additional total electrical output of at least 7.5 MW must be achieved; 3. in the case of other extensions of existing wind power plants, a procedure pursuant to UVP-G 2000, Federal Law Gazette I No. 80/2018, must have been carried out prior to the extension. In the course of any environmental impact assessment, suitable measures shall be taken to ensure that the function of permanently managed refuges and long-distance hiking trails is not impaired."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specialisedZoneType> ;
        skos:notation "priority" ;
        skos:prefLabel "Vorrang"@de,
            "priority"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specialisedZoneType> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specialisedZoneType/suitability> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/am> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/am> ;
        skos:definition "In Eignungszonen ist die Errichtung von Windkraftanlagen mit einer Nennleistung von mindestens 0,5 Megawatt zulässig."@de,
            "In suitability zones is the installation of wind turbines with a rated output of at least 0.5 megawatts permitted."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specialisedZoneType> ;
        skos:notation "suitability" ;
        skos:prefLabel "Eignung"@de,
            "suitability"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specialisedZoneType> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specialisedZoneType> a skos:ConceptScheme ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/am> ;
        dcterms:created "2026-05-05T14:30:11+00:00"^^xsd:dateTime ;
        dcterms:description "Klassifikation, die den Typ des Bewirtschaftungsgebiets, Schutzgebiets oder geregelten Gebiets definiert."@de,
            "Classification defining the type of Management, Restriction or Regulation Zone."@en ;
        dcterms:publisher <https://registry.inspire.gv.at/dataprovider/0008> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/am> ;
        dcterms:title "spezifischer Code des Gebietstyps Österreich"@de,
            "specialised Zone Type Code Austria"@en ;
        dcterms:type <http://inspire.ec.europa.eu/codelist/ZoneTypeCode> ;
        owl:versionInfo "1.0.0" ;
        skos:hasTopConcept <https://registry.inspire.gv.at/codelist/specialisedZoneType/exclusion>,
            <https://registry.inspire.gv.at/codelist/specialisedZoneType/priority>,
            <https://registry.inspire.gv.at/codelist/specialisedZoneType/suitability> ;
        skos:scopeNote "INSPIRE extensibility: open, internal by value"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .
}

