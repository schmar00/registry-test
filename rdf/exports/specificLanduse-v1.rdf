    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Teil eines Berges, der für das Skifahren und das Snowboardfahren vorgesehen ist.</skos:definition>
    <skos:definition xml:lang="en">ki Slope</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/specificLanduse"/>
