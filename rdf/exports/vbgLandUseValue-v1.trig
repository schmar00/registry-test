        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/W> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/E> ;
        skos:definition "Im Flächenwidmungsplan sind, soweit nicht besondere Widmungen festgelegt werden, die für die Raumplanung bedeutsamen Gegebenheiten, wie öffentliche Gewässer ersichtlich zu machen."@de,
            "In the zoning plan, as far as special zonings are not determined, the significant conditions for spatial planning, like public waters, must be visualized."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "W" ;
        skos:prefLabel "Gewässer"@de,
            "waters"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/F> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Fläche für dezidierte Nutzung daklariert."@de,
            "Area designated for dedicated use."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/vbgLandUseValue/FF>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/FL>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/FS> ;
        skos:notation "F" ;
        skos:prefLabel "Freifläche"@de,
            "open space"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VF> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Als Verkehrsflächen können Flächen für Straßen und Eisenbahntrassen einschließlich der dazugehörigen Anlagen festgelegt werden."@de,
            "Areas and the associated facilities can be determined as traffic areas"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VB>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VS>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VSP> ;
        skos:notation "VF" ;
        skos:prefLabel "Verkehrsfläche"@de,
            "traffic area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/B> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Bauflächen sind im Flächenwidmungsplan bereits bebaute Flächen und Flächen, die sich aufgrund der natürlichen Verhältnisse für die Bebauung eignen"@de,
            "Building areas are areas in the zoning plan that have already been built on and areas that are suitable for building on the basis of natural conditions."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BB>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BB-I>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BB-II>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BK>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BM>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BW> ;
        skos:notation "B" ;
        skos:prefLabel "Baufläche"@de,
            "building zone"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BE> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Bauerwartungsflächen dürfen nur als Folgewidmung nach §12 Abs. 4 oder bei Umwidmungen nach §23 Abs.2 lit. a Raumplanungsgesetz festgelegt werden. Flächen, die gemäß § 13 Abs. 2 als Bauflächen nicht geeignet sind, dürfen nicht als Bauerwartungsflächen gewidmet werden. Bauerwartungsflächen können in Kern-, Wohn-, Misch- oder Betriebsgebiete unterteilt werden. Kerngebiete sind Gebiete in zentraler innerörtlicher Lage, die vornehmlich für Gebäude für Verwaltung, Handel, Bildungs-und andere kulturelle und soziale Einrichtungen, sonstige Dienstleistungen und Wohnungen bestimmt sind. Andere Gebäude und Anlagen sind zulässig, wenn der Charakter als Kerngebiet nicht gestört wird."@de,
            "to be defined"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEB>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEB-I>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEB-II>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEK>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEM>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEW> ;
        skos:notation "BE" ;
        skos:prefLabel "Bauerwartungsfläche-Kerngebiet"@de,
            "future development zone"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
