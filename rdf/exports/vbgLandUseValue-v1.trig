@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <http://www.w3.org/ns/adms#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://registry.inspire.gv.at/codelist/vbgLandUseValue:1> {
    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BB> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/B> ;
        skos:definition "Bauflächen sind im Flächenwidmungsplan bereits bebaute Flächen und Flächen, die sich aufgrund der natürlichen Verhältnisse für die Bebauung eignen und in absehbarer Zeit, längstens aber innert 7 Jahren, als Bauflächen benötigt werden und innerhalb dieser Frist erschlossen werden können. Bauflächen sind nach Erfordernis und Zweckmäßigkeit in Kern-, Wohn-, Misch- oder Betriebsgebiete zu unterteilen. Es wird zwischen Gebieten, die für Betriebsanlagen bestimmt sind, der Kategorien I und II unterschieden."@de,
            "Building zones in the zoning plan (of a municipality) are built-up areas and areas, that are suitable for building due to the natural conditions and are needed as building zones in a foreseeable time, but within 7 years at the longest, and where services can be provided within that time limit. Building zones must be divided into core areas, residential-, mixed- or operating areas, according to necessity and expediency. A distinction is made between category I and category II areas, which are designated for operating facilities."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BB" ;
        skos:prefLabel "Baufläche-Betriebsgebiet"@de,
            "building zone - operating area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BB-I> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/B> ;
        skos:definition "Bauflächen sind im Flächenwidmungsplan bereits bebaute Flächen und Flächen, die sich aufgrund der natürlichen Verhältnisse für die Bebauung eignen und in absehbarer Zeit, längstens aber innert 7 Jahren, als Bauflächen benötigt werden und innerhalb dieser Frist erschlossen werden können. Bauflächen sind nach Erfordernis und Zweckmäßigkeit in Kern-, Wohn-, Misch- oder Betriebsgebiete zu unterteilen. Betriebsgebiete Kategorie I sind Gebiete, die für Betriebsanlagen bestimmt sind, die keine wesentlichen Störungen für die Umgebung des Betriebsgebiets verursachen. Im Betriebsgebiet Kategorie I ist die Errichtung von Wohnungen für die in Betrieben des betreffenden Gebiets Beschäftigten sowie von Gebäuden und Anlagen zulässig, die der Versorgung und den sozialen Bedürfnissen der in solchen Gebieten arbeitenden Bevölkerung dienen. Wenn dies nach den für die Raumplanung maßgeblichen Verhältnissen erforderlich ist, können im Betriebsgebiet Kategorie I zum Zwecke der Sicherung geeigneter Flächen für Produktionsbetriebe Zonen festgelegt werden, in denen Gebäude und Anlagen nach Abs. 6 zweiter Satz lit. a, b oder c nicht zulässig sind."@de,
            "Building zones in the zoning plan (of a municipality) are built-up areas and areas, that are suitable for building due to the natural conditions and are needed as building zones in a foreseeable time, but within 7 years at the longest, and where services can be provided within that time limit. Building zones must be divided into core areas, residential-, mixed- or operating areas, according to necessity and expediency. Category I operating areas are areas that are intended for operating facilities that do not cause any significant disturbance to the vicinity of the operating area. In the operating area of Category I, the construction of apartments is permitted for those employed in businesses in the area concerned, as well as buildings and facilities that serve the supply and social needs of the population working in such areas. If this is necessary according to the circumstances relevant for spatial planning, zones can be defined in the operating area Category I for the purpose of securing suitable areas for production companies in which buildings and facilities according to Paragraph 6, second sentence lit. a, b or c are not permitted."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BB-I" ;
        skos:prefLabel "Baufläche-Betriebsgebiet Kategorie I"@de,
            "building zone - category I operating area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BB-II> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/B> ;
        skos:definition "Bauflächen sind im Flächenwidmungsplan bereits bebaute Flächen und Flächen, die sich aufgrund der natürlichen Verhältnisse für die Bebauung eignen und in absehbarer Zeit, längstens aber innert 7 Jahren, als Bauflächen benötigt werden und innerhalb dieser Frist erschlossen werden können. Bauflächen sind nach Erfordernis und Zweckmäßigkeit in Kern-, Wohn-, Misch- oder Betriebsgebiete zu unterteilen. Betriebsgebiete Kategorie II sind Gebiete, die vornehmlich für Betriebsanlagen, die im Betriebsgebiet Kategorie I nicht errichtet werden dürfen, bestimmt sind. In Betriebsgebieten Kategorie II dürfen nicht errichtet werden a) Wohnungen, ausgenommen betriebsnotwendige Wohnungen für das Aufsichts-und Wartungspersonal, wenn diese in den Betrieb integriert sind, b) Gebäude und Anlagen für Sport-und Freizeitzwecke und c) Gebäude und Anlagen für Zwecke des Handels, sofern der Handel nicht ausschließlich zum Weiterverkauf von Waren des nicht täglichen Bedarfs oder untergeordnet in Produktionsbetrieben zum Verkauf von Waren überwiegend eigener Produktion erfolgt."@de,
            "Building zones in the zoning plan (of a municipality) are built-up areas and areas, that are suitable for building due to the natural conditions and are needed as building zones in a foreseeable time, but within 7 years at the longest, and where services can be provided within that time limit. Building zones must be divided into core areas, residential-, mixed- or operating areas, according to necessity and expediency. Category II operating areas are areas, which are primarily destined for operating facilites, that must not be be errected in category I operating areas. In category II operating areas must not be built a) appartments, with the exception of operationally necessary appartments for the supervisory- and maintenance staff, if they are integrated into the business, b) buildings and facilities for sports or leisure purposes c) buildings and facilities for the purpose of trade, provided that the trade does not take place exclusively for the resale of non-basic goods or subordinately in production plants for the sale of goods of predominantly own production."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BB-II" ;
        skos:prefLabel "Baufläche-Betriebsgebiet Kategorie II"@de,
            "building zone - category II operating area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEB> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BE> ;
        skos:definition "Bauerwartungsflächen dürfen nur als Folgewidmung nach §12 Abs. 4 oder bei Umwidmungen nach §23 Abs.2 lit. a Raumplanungsgesetz festgelegt werden. Flächen, die gemäß § 13 Abs. 2 als Bauflächen nicht geeignet sind, dürfen nicht als Bauerwartungsflächen gewidmet werden. Bauerwartungsflächen können in Kern-, Wohn-, Misch- oder Betriebsgebiete unterteilt werden. Es wird zwischen Gebieten, die für Betriebsanlagen bestimmt sind, der Kategorien I und II unterschieden."@de,
            "Future development zones' may only be determined as a consecutive zoning under § 12 section 4 or in the case of rezonings, ruled in § 23 sec. 2 lit. a, Code of Spatial Planning of Vorarlberg. Land, that is not suitable as building zones, must not be zoned in future development zones. Future development zones can be subdivided into core-, residential-, mixed- or operating areas. A distinction is made between category I and category II areas, which are designated for operating facilities."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BEB" ;
        skos:prefLabel "Bauerwartungsfläche-Betriebsgebiet"@de,
            "future development zone - operating area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEB-I> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BE> ;
        skos:definition "Bauerwartungsflächen dürfen nur als Folgewidmung nach §12 Abs. 4 oder bei Umwidmungen nach §23 Abs.2 lit. a Raumplanungsgesetz festgelegt werden. Flächen, die gemäß § 13 Abs. 2 als Bauflächen nicht geeignet sind, dürfen nicht als Bauerwartungsflächen gewidmet werden. Bauerwartungsflächen können in Kern-, Wohn-, Misch- oder Betriebsgebiete unterteilt werden. Betriebsgebiete Kategorie I sind Gebiete, die für Betriebsanlagen bestimmt sind, die keine wesentlichen Störungen für die Umgebung des Betriebsgebiets verursachen. Im Betriebsgebiet Kategorie I ist die Errichtung von Wohnungen für die in Betrieben des betreffenden Gebiets Beschäftigten sowie von Gebäuden und Anlagen zulässig, die der Versorgung und den sozialen Bedürfnissen der in solchen Gebieten arbeitenden Bevölkerung dienen. Wenn dies nach den für die Raumplanung maßgeblichen Verhältnissen erforderlich ist, können im Betriebsgebiet Kategorie I zum Zwecke der Sicherung geeigneter Flächen für Produktionsbetriebe Zonen festgelegt werden, in denen Gebäude und Anlagen nach Abs. 6 zweiter Satz lit. a, b oder c nicht zulässig sind."@de,
            "Future development zones' may only be determined as a consecutive zoning under § 12 section 4 or in the case of rezonings, ruled in § 23 sec. 2 lit. a, Code of Spatial Planning of Vorarlberg. Land, that is not suitable as building zones, must not be zoned in future development zones. Future development zones can be subdivided into core-, residential-, mixed- or operating areas. Category I operating areas are areas that are intended for operating facilities that do not cause any significant disturbance to the vicinity of the operating area. In the operating area of Category I, the construction of apartments is permitted for those employed in businesses in the area concerned, as well as buildings and facilities that serve the supply and social needs of the population working in such areas. If this is necessary according to the circumstances relevant for spatial planning, zones can be defined in the operating area Category I for the purpose of securing suitable areas for production companies in which buildings and facilities according to Paragraph 6, second sentence lit. a, b or c are not permitted."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BEB-I" ;
        skos:prefLabel "Bauerwartungsfläche-Betriebsgebiet Kategorie I"@de,
            "future development zone - category I operating area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEB-II> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BE> ;
        skos:definition "Bauerwartungsflächen dürfen nur als Folgewidmung nach §12 Abs. 4 oder bei Umwidmungen nach §23 Abs.2 lit. a Raumplanungsgesetz festgelegt werden. Flächen, die gemäß § 13 Abs. 2 als Bauflächen nicht geeignet sind, dürfen nicht als Bauerwartungsflächen gewidmet werden. Bauerwartungsflächen können in Kern-, Wohn-, Misch- oder Betriebsgebiete unterteilt werden. Betriebsgebiete Kategorie II sind Gebiete, die vornehmlich für Betriebsanlagen, die im Betriebsgebiet Kategorie I nicht errichtet werden dürfen, bestimmt sind. In Betriebsgebieten Kategorie II dürfen nicht errichtet werden a) Wohnungen, ausgenommen betriebsnotwendige Wohnungen für das Aufsichts-und Wartungspersonal, wenn diese in den Betrieb integriert sind, b) Gebäude und Anlagen für Sport-und Freizeitzwecke und c) Gebäude und Anlagen für Zwecke des Handels, sofern der Handel nicht ausschließlich zum Weiterverkauf von Waren des nicht täglichen Bedarfs oder untergeordnet in Produktionsbetrieben zum Verkauf von Waren überwiegend eigener Produktion erfolgt."@de,
            "Future development zones' may only be determined as a consecutive zoning under § 12 section 4 or in the case of rezonings, ruled in § 23 sec. 2 lit. a, Code of Spatial Planning of Vorarlberg. Land, that is not suitable as building zones, must not be zoned in future development zones. Future development zones can be subdivided into core-, residential-, mixed- or operating areas. Category II operating areas are areas, which are primarily destined for operating facilites, that must not be be errected in category I operating areas. In category II operating areas must not be built a) appartments, with the exception of operationally necessary appartments for the supervisory- and maintenance staff, if they are integrated into the business, b) buildings and facilities for sports or leisure purposes c) buildings and facilities for the purpose of trade, provided that the trade does not take place exclusively for the resale of non-basic goods or subordinately in production plants for the sale of goods of predominantly own production."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BEB-II" ;
        skos:prefLabel "Bauerwartungsfläche-Betriebsgebiet Kategorie II"@de,
            "future development area - category II operating area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEK> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BE> ;
        skos:definition "Bauerwartungsflächen dürfen nur als Folgewidmung nach §12 Abs. 4 oder bei Umwidmungen nach §23 Abs.2 lit. a Raumplanungsgesetz festgelegt werden."@de,
            "Future development zones' may only be determined as a consecutive zoning under § 12 section 4 or in the case of rezonings, ruled in § 23 sec. 2 lit. a, Code of Spatial Planning of Vorarlberg. Land, that is not suitable as building zones, must not be zoned in future development zones. Future development zones can be subdivided into core-, residential-, mixed- or operating areas. Core areas are areas in central, local location, which are primarily designated for buildings for administration, trade, educational and other cultural and social facilities, other services and appartments. Other buildings and facilites are permitted, if the character of a core area is not violated."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BEK" ;
        skos:prefLabel "Bauerwartungsfläche"@de,
            "future development zone - core area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEM> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BE> ;
        skos:definition "Bauerwartungsflächen dürfen nur als Folgewidmung nach §12 Abs. 4 oder bei Umwidmungen nach §23 Abs.2 lit. a Raumplanungsgesetz festgelegt werden. Flächen, die gemäß § 13 Abs. 2 als Bauflächen nicht geeignet sind, dürfen nicht als Bauerwartungsflächen gewidmet werden. Bauerwartungsflächen können in Kern-, Wohn-, Misch- oder Betriebsgebiete unterteilt werden. Mischgebiete sind Gebiete, in denen Wohngebäude und sonstige Gebäude und Anlagen zulässig sind, die das Wohnen nicht wesentlich stören."@de,
            "Future development zones' may only be determined as a consecutive zoning under § 12 section 4 or in the case of rezonings, ruled in § 23 sec. 2 lit. a, Code of Spatial Planning of Vorarlberg. Land, that is not suitable as building zones, must not be zoned in future development zones. Future development zones can be subdivided into core-, residential-, mixed- or operating areas. Mixed areas are areas, in which residential buildings and other buildings and facilities are permitted, that do not cause a significant disturbance to the living."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BEM" ;
        skos:prefLabel "Bauerwartungsfläche-Mischgebiet"@de,
            "future development zone - mixed area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEW> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BE> ;
        skos:definition "Bauerwartungsflächen dürfen nur als Folgewidmung nach §12 Abs. 4 oder bei Umwidmungen nach §23 Abs.2 lit. a Raumplanungsgesetz festgelegt werden. Flächen, die gemäß § 13 Abs. 2 als Bauflächen nicht geeignet sind, dürfen nicht als Bauerwartungsflächen gewidmet werden. Bauerwartungsflächen können in Kern-, Wohn-, Misch- oder Betriebsgebiete unterteilt werden. Wohngebiete sind Gebiete, die für Wohngebäude bestimmt sind. Andere Gebäude und Anlagen dürfen in Wohngebieten errichtet werden, wenn dadurch das Wohnen und auch sonst der Charakter als Wohngebiet nicht gestört wird."@de,
            "Future development zones' may only be determined as a consecutive zoning under § 12 section 4 or in the case of rezonings, ruled in § 23 sec. 2 lit. a, Code of Spatial Planning of Vorarlberg. Land, that is not suitable as building zones, must not be zoned in future development zones. Future development zones can be subdivided into core-, residential-, mixed- or operating areas. Residential areas are areas, which are designated for residential buildings. Other buildings and facilities can be errected, if the housing and also otherwise the character as a residential area is not violated."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BEW" ;
        skos:prefLabel "Bauerwartungsfläche-Wohngebiet"@de,
            "future development zone - residential area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BK> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/B> ;
        skos:definition "Bauflächen sind im Flächenwidmungsplan bereits bebaute Flächen und Flächen, die sich aufgrund der natürlichen Verhältnisse für die Bebauung eignen und in absehbarer Zeit, längstens aber innert 7 Jahren, als Bauflächen benötigt werden und innerhalb dieser Frist erschlossen werden können. Bauflächen sind nach Erfordernis und Zweckmäßigkeit in Kern-, Wohn-, Misch- oder Betriebsgebiete zu unterteilen. Kerngebiete sind Gebiete in zentraler innerörtlicher Lage, die vornehmlich für Gebäude für Verwaltung, Handel, Bildungs-und andere kulturelle und soziale Einrichtungen, sonstige Dienstleistungen und Wohnungen bestimmt sind. Andere Gebäude und Anlagen sind zulässig, wenn der Charakter als Kerngebiet nicht gestört wird."@de,
            "Building zones in the zoning plan (of a municipality) are built-up areas and areas, that are suitable for building due to the natural conditions and are needed as building zones in a foreseeable time, but within 7 years at the longest, and where services can be provided within that time limit. Building zones must be divided into core areas, residential-, mixed- or operating areas, according to necessity and expediency. Core areas are areas in central, local location, which are primarily designated for buildings for administration, trade, educational and other cultural and social facilities, other services and appartments. Other buildings and facilites are permitted, if the character of a core area is not disturbed."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BK" ;
        skos:prefLabel "Baufläche-Kerngebiet"@de,
            "building zone - core area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BM> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/B> ;
        skos:definition "Bauflächen sind im Flächenwidmungsplan bereits bebaute Flächen und Flächen, die sich aufgrund der natürlichen Verhältnisse für die Bebauung eignen und in absehbarer Zeit, längstens aber innert 7 Jahren, als Bauflächen benötigt werden und innerhalb dieser Frist erschlossen werden können. Bauflächen sind nach Erfordernis und Zweckmäßigkeit in Kern-, Wohn-, Misch- oder Betriebsgebiete zu unterteilen. Mischgebiete sind Gebiete, in denen Wohngebäude und sonstige Gebäude und Anlagen zulässig sind, die das Wohnen nicht wesentlich stören."@de,
            "Building zones in the zoning plan (of a municipality) are built-up areas and areas, that are suitable for building due to the natural conditions and are needed as building zones in a foreseeable time, but within 7 years at the longest, and where services can be provided within that time limit. Building zones must be divided into core areas, residential-, mixed- or operating areas, according to necessity and expediency. Mixed areas are areas, in which residential buildings and other buildings and facilities are permitted, that do not cause a significant disturbance to the living."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BM" ;
        skos:prefLabel "Baufläche-Mischgebiet"@de,
            "building zone - mixed area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BW> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/B> ;
        skos:definition "Bauflächen sind im Flächenwidmungsplan bereits bebaute Flächen und Flächen, die sich aufgrund der natürlichen Verhältnisse für die Bebauung eignen und in absehbarer Zeit, längstens aber innert 7 Jahren, als Bauflächen benötigt werden und innerhalb dieser Frist erschlossen werden können. Bauflächen sind nach Erfordernis und Zweckmäßigkeit in Kern-, Wohn-, Misch- oder Betriebsgebiete zu unterteilen. Wohngebiete sind Gebiete, die für Wohngebäude bestimmt sind. Andere Gebäude und Anlagen dürfen in Wohngebieten errichtet werden, wenn dadurch das Wohnen und auch sonst der Charakter als Wohngebiet nicht gestört wird."@de,
            "Building zones in the zoning plan (of a municipality) are built-up areas and areas, that are suitable for building due to the natural conditions and are needed as building zones in a foreseeable time, but within 7 years at the longest, and where services can be provided within that time limit. Building zones must be divided into core areas, residential-, mixed- or operating areas, according to necessity and expediency. Residential areas are areas, which are designated for residential buildings. Other buildings and facilities can be errected, if the housing and also otherwise the character as a residential area is not violated."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "BW" ;
        skos:prefLabel "Baufläche-Wohngebiet"@de,
            "building zone - residential area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/FF> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/F> ;
        skos:definition "Als Freihaltegebiete sind Freiflächen festzulegen, die im öffentlichen Interesse, insbesondere zum Schutz des Landschafts-und Ortsbildes oder wegen der natürlichen Verhältnisse (Grundwasserstand, Bodenbeschaffenheit,Lawinen-, Hochwasser-, Vermurungs-, Steinschlag-und Rutschgefahr usw.) von einer Bebauung freizuhalten sind. Alle Freiflächen, die nicht als Landwirtschaftsgebiete oder Sondergebiete gewidmet sind, sind Freihaltegebiete. Auf Waldflächen ist die Errichtung von Gebäuden und Anlagen zulässig, soweit dies für forstwirtschaftliche Zwecke notwendig ist."@de,
            "Zones shall be determined as areas to be kept clear that, in the public interest, especially for the protection of the landscape and the site of local character or due to the natural conditions (groundwater level, soil condition, risk of avalanches, of flooding, of landslide, of rockfall and of slide etc.) have to be kept free of building. All open spaces, that are not zoned as agricultural or exceptional areas, are areas to be kept clear. On forest areas, the construction of buildings and facilities is permitted, as far as it is necessary for silvicultural purposes."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "FF" ;
        skos:prefLabel "Freifläche-Freihaltegebiet"@de,
            "open space - area to be kept clear"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/FG> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/E> ;
        skos:definition "Im Flächenwidmungsplan sind, soweit nicht besondere Widmungen festgelegt werden, die für die Raumplanung bedeutsamen Gegebenheiten, wie Waldflächen ersichtlich zu machen."@de,
            "In the zoning plan, as far as special zonings are not determined, the significant conditions for spatial planning, like forest areas, must be visualised."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "FG" ;
        skos:prefLabel "Waldfläche"@de,
            "forest area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/FL> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/F> ;
        skos:definition "In Landwirtschaftsgebieten ist die Errichtung von Gebäuden und Anlagen zulässig, soweit dies für die bodenabhängige land- und forstwirtschaftliche Nutzung einschließlich der dazu gehörenden erforderlichen Wohnräume und Wohngebäude und für Nebengewerbe der Land-und Forstwirtschaft sowie die häusliche Nebenbeschäftigung notwendig ist."@de,
            "In agricultural areas, the construction of buildings and facilities is permitted, as far as it is necessary in terms of the soil-dependent agricultural and silvicultural use, including the associated, necessary residential spaces and residential buildings and for the subsidiary occupation of agriculture and silviculture as well as the domestic external activity."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "FL" ;
        skos:prefLabel "Freifläche-Landwirtschaftsgebiet"@de,
            "open space - agricultural area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/FS> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/F> ;
        skos:definition "Als Sondergebiete können Flächen festgelegt werden, auf denen Gebäude und Anlagen errichtet werden dürfen, die ihrer Zweckwidmung nach an einen bestimmten Standort gebunden sind oder sich an einem bestimmten Standort besonders eignen, wie z.B. Flächen für Kleingärten, gewerbliche Gärtnereien, Kinderspielplätze, Erholungs-und Sportanlagen, Campingplätze, Ausflugsgasthöfe, Schutzhütten, Steinbrüche, Kiesgruben, Anlagen zur Fassung von Quell-sowie zur Entnahme von Grundwasser, Schießstätten und Sprengmittellager. Der vorgesehene Verwendungszweck ist in der Widmung anzuführen."@de,
            "Zones can be determined as exceptional areas, on which buildings and facilities can be errected, that are tied to a specific location or are highly suited for a specific location, as e.g. areas for allotments, commercial gardening, playgrounds, recreational- and sports facilities, camping grounds, excurison inns, refuges, stone quarries, gravel pits, facilities to load spring water as well as the extraction of ground water, shooting ranges and explosive storage depots. The intended use has to be cited in the zoning."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "FS" ;
        skos:prefLabel "Freifläche-Sondergebiet"@de,
            "open space - exceptional area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/V> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/E> ;
        skos:definition "In Bauflächen, Bauerwartungsflächen oder Freiflächen (Grundwidmung) können Flächen festgelegt werden, die Zwecken des Gemeinbedarfs dienen oder für solche Zwecke voraussichtlich innerhalb von 20 Jahren benötigt werden (Vorbehaltsflächen). Die vorgesehene Verwendung ist im Flächenwidmungsplan anzugeben."@de,
            "In building zones, future development areas or open spaces (base zoning), such areas can be determined, that serve purposes of common needs or are expected to be needed within 20 years fo these purposes (reserved area). The intended use has to be determined in the zoning plan."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "V" ;
        skos:prefLabel "Vorbehaltsfläche"@de,
            "reserved area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VB> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VF> ;
        skos:definition "Als Verkehrsflächen können Flächen für Straßen und Eisenbahntrassen einschließlich der dazugehörigen Anlagen festgelegt werden. Andere Vorhaben sind auf solchen Flächen nur zulässig, wenn der Zweck der Widmung als Verkehrsfläche nicht entgegensteht."@de,
            "Areas for railway lines including the associated facilities can be determined as traffic areas. Other projects on these areas are only permitted, if the purpose [of the project] does not interfere with the zoning as traffic area."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "VB" ;
        skos:prefLabel "Verkehrsfläche Bahn"@de,
            "traffic area - railway"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VBE> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/E> ;
        skos:definition "Im Flächenwidmungsplan sind, soweit nicht besondere Widmungen festgelegt werden, die für die Raumplanung bedeutsamen Gegebenheiten, wie Eisenbahnen ersichtlich zu machen."@de,
            "In the zoning plan, as far as special zonings are not determined, the significant conditions for spatial planning, like railways, must be visualized."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "VBE" ;
        skos:prefLabel "Verkehrsfläche Bahn Ersichtlichmachung"@de,
            "traffic area - rail visualization"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VS> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VF> ;
        skos:definition "Als Verkehrsflächen können Flächen für Straßen und Eisenbahntrassen einschließlich der dazugehörigen Anlagen festgelegt werden. Andere Vorhaben sind auf solchen Flächen nur zulässig, wenn der Zweck der Widmung als Verkehrsfläche nicht entgegensteht."@de,
            "Areas for streets including the associated facilities can be determined as traffic areas. Other projects on these areas are only permitted, if the purpose [of the project] does not interfere with the zoning as traffic area."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "VS" ;
        skos:prefLabel "Verkehrsfläche Straße"@de,
            "traffic area - street"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VSE> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/E> ;
        skos:definition "Im Flächenwidmungsplan sind, soweit nicht besondere Widmungen festgelegt werden, die für die Raumplanung bedeutsamen Gegebenheiten, wie bestehende Landes-und Bundesstraßen ersichtlich zu machen."@de,
            "In the zoning plan, as far as special zonings are not determined, the significant conditions for spatial planning, like existing state- and federal highways, must be visualized."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "VSE" ;
        skos:prefLabel "Verkehrsfläche Straße Ersichtlichmachung"@de,
            "traffic area - street visualization"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VSP> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. VBG"@de,
            "Def. VBG"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:broader <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VF> ;
        skos:definition "Als Verkehrsflächen können Flächen für geplante Straßen einschließlich der dazugehörigen Anlagen festgelegt werden. Andere Vorhaben sind auf solchen Flächen nur zulässig, wenn der Zweck der Widmung als Verkehrsfläche nicht entgegensteht."@de,
            "Areas for planned streets including the associated facilities can be determined as traffic areas. Other projects on these areas are only permitted, if the purpose [of the project] does not interfere with the zoning as traffic area."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
        skos:notation "VSP" ;
        skos:prefLabel "Verkehrsfläche Straße Planung"@de,
            "traffic area - street planning"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/vbgLandUseValue/VSPE> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
