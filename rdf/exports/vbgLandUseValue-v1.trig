            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEB-II>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEK>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEM>,
            <https://registry.inspire.gv.at/codelist/vbgLandUseValue/BEW> ;
        skos:notation "BE" ;
        skos:prefLabel "Bauerwartungsfl횄짚che-Kerngebiet"@de,
            "future development zone"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical" ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/vbgLandUseValue> ;
