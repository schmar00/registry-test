@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <http://www.w3.org/ns/adms#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV:1> {
    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/avalancheCatchmentArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Das Lawinen-Einzugsgebiet kennzeichnet den Nähr-, Abbruch- und Ablagerungsbereich einer Lawine. Eine Schneemasse mit typischerweise einem Volumen von mehr als 100 m³ und einer Mindestlänge von 50 Metern, die schnell talwärts rutscht."@de,
            "The avalanche catchment area indicates the eligibility of an avalanche to be fed, the area in which it breaks off and the area in which it deposits. A snow mass with typically a volume greater than 100 m³ and a minimum length of 50 meters that slides rapidly downhill."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "avalancheCatchmentArea" ;
        skos:prefLabel "Lawinen-Einzugsgebiet"@de,
            "avalanche catchment area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/blueReservationArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Blaue Vorbehaltsbereiche sind Flächen, die für zukünftige technische (z.B. Bau eines Absetzbeckens) oder biologische Bekämpfungsmaßnahmen (z.B. Aufforstungen) freigehalten werden sollen."@de,
            "Blue reservation areas are areas which are to be kept free for future technical (e.g. construction of a sedimentation basin) or biological control measures (e.g. afforestation)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "blueReservationArea" ;
        skos:prefLabel "Blauer Vorbehaltsbereich"@de,
            "blue reservation area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/brownReferenceArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Die braunen Hinweisbereiche weisen auf Gefahren hin, die nicht durch Wildbäche und Lawinen hervorgerufen werden (z.B. Steinschlag- und Rutschgebiete)."@de,
            "The brown reference areas indicate hazards other than those evoked by torrents and avalanches (e.g. stone fall and slide areas)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "brownReferenceArea" ;
        skos:prefLabel "Brauner Hinweisbereich"@de,
            "brown reference area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/partiallyRelevantArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Unter Raumrelevanten Bereichen im Sinne der Gefahrenzonenplanung der Wildbach- und Lawinenverbauung (WLV) sind Flächen zu verstehen, die derzeitigem oder künftig möglichem Bauland mit den unmittelbar dazugehörigen Verkehrsflächen vorbehalten sind. Ebenso sind Gebiete mit besonderer Nutzung, wie Campingplätze, Sportplätze, Schwimmbäder, jeweils samt zugehörigen Verkehrsflächen, als Raumrelevanter Bereich auszuweisen. Weiters sollte Raumrelevanz auch jenen Flächen zuerkannt werden, die aufgrund ihrer Lage, ihrer Aufschließung oder sonstiger Funktion eine Gefahrenzonenplanung vorteilhaft erscheinen lassen. Insbesondere sind auch 'nicht als Bauland gewidmete Flächen' als raumrelevant auszuweisen, wenn für sie in absehbarer Zeit (bis zur Revision des Gefahrenzonenplans) eine Umwidmung zum Zwecke einer Bebauung wahrscheinlich ist."@de,
            "Parts of the plan area, which were defined as areas of interest for hazard zone planning. These include present and future building land, residential areas, areas for public use."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "partiallyRelevantArea" ;
        skos:prefLabel "Raumrelevanter Bereich"@de,
            "patially relevant area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/planArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Das Plangebiet im Sinne der Gefahrenzonenplanung der WLV umfasst gemäß § 3 der GZP-Verordnung in der Regel das Gebiet einer Gemeinde. Es darf aber, falls erforderlich und begründbar, auch auf Teile eines Gemeindegebietes beschränkt werden."@de,
            "The plan area defines the municipality or parts of a municipality for which the hazard zone map was elaborated."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "planArea" ;
        skos:prefLabel "Plangebiet"@de,
            "plan area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/purpleReferenceArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Gebiete, deren gegenwärtiger Zustand erhalten werden muss, um die Schutzfunktion auch in Zukunft zu gewährleisten (z.B. natürliche Umleitungsdämme, hochwasserrückhaltende Flächen in Form von Geländemulden), werden als violette Hinweisbereiche ausgewiesen."@de,
            "Areas whose present state has to be preserved in order to ensure the protective function also in the future (e.g. natural diversion dams, flood retarding areas in the form of terrain synclines) are identified as purple reference areas."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "purpleReferenceArea" ;
        skos:prefLabel "Violetter Hinweisbereich"@de,
            "purple reference area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/redHazardZone> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "In den roten Gefahrenzonen ist die Bedrohung durch Lawinen/sturzflutartiges Hochwasser so hoch, dass eine dauerhafte Besiedlung nicht oder nur mit unverhältnismäßig hohem Aufwand möglich ist. Der Bau neuer Gebäude wird nicht empfohlen."@de,
            "In red hazard zones the threat due to snow avalanches /torrential floods is so high that permanent settlement is not possible or only possible with a disproportionately high expenditure. The construction of new buildings is not recommended."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "redHazardZone" ;
        skos:prefLabel "Rote Gefahrenzone"@de,
            "red hazard zone"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/torrentCatchmentAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Ein Wildbach (im Sinne des § 99 Abs. 1 ForstG) ist ein dauernd oder zeitweise fließendes Gewässer, das durch rasch eintretende und nur kurze Zeit dauernde Anschwellungen Feststoffe aus seinem Einzugsgebiet oder aus seinem Bachbett in gefahrdrohendem Ausmaße entnimmt, diese mit sich führt und innerhalb oder außerhalb seines Bettes ablagert oder einem anderen Gewässer zuführt. Das Einzugsgebiet eines Wildbaches (im Sinne des § 99 Abs. 3 ForstG) ist die Fläche des von diesem und seinen Zuflüssen entwässerten Niederschlagsgebietes sowie der Ablagerungsbereich des Wildbaches."@de,
            "A torrential catchment area comprises the area of the torrent, its tributaries and its alluvial fan. Torrents are perennial or partially active waters. They are characterized by sediment transport, debris flows and woody debris."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "torrentCatchmentAreas" ;
        skos:prefLabel "Wildbach-Einzugsgebiet"@de,
            "torrent catchment areas"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/yellowHazardZone> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "In gelben Gefahrenzonen ist die dauerhafte Nutzung für Siedlungs- und Transportzwecke durch Lawinen/sturzflutartiges Hochwasser beeinträchtigt. Das Bauen in diesen Gebieten ist nur unter besonderen Auflagen möglich."@de,
            "In yellow hazard zones the permanent use for settlement and transport purposes is impaired by snow avalanches /torrential floods. Building in these areas is only possible with specific building control requirements"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        skos:notation "yellowHazardZone" ;
        skos:prefLabel "Gelbe Gefahrenzone"@de,
            "yellow hazard zone"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV> a skos:ConceptScheme ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:created "2026-05-05T14:30:11+00:00"^^xsd:dateTime ;
        dcterms:description "Zusätzliche Bezeichnung gefährdeter Elemente."@de,
            "An additional denomination of exposed elements."@en ;
        dcterms:publisher <https://registry.inspire.gv.at/dataprovider/0009> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        dcterms:title "Spezifischer Typ gefährdeter Elemente der WLV"@de,
            "specific exposed element type of WLV"@en ;
        dcterms:type <http://inspire.ec.europa.eu/codelist/SpecificExposedElementTypeValue> ;
        owl:versionInfo "1.0.0" ;
        skos:hasTopConcept <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/avalancheCatchmentArea>,
            <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/blueReservationArea>,
            <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/brownReferenceArea>,
            <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/partiallyRelevantArea>,
            <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/planArea>,
            <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/purpleReferenceArea>,
            <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/redHazardZone>,
            <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/torrentCatchmentAreas>,
            <https://registry.inspire.gv.at/codelist/specificExposedElementTypeWLV/yellowHazardZone> ;
        skos:scopeNote "INSPIRE extensibility: open, internal by value"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .
}

