  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_11_DwarfShrubs">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 2122_DwarfShrubs - Da großflächige Zwergstrauchbestände nur in der (sub)alpinen Zone auftreten können diese durchaus mit einer gröberen räumlichen Auflösung erfaßt werden.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 2122_DwarfShrubs</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody"/>
    <skos:definition xml:lang="en">woody plants with a height between 0,2 and 0,5m.</skos:definition>
    <skos:definition xml:lang="de">Flächige Bestände von v.a. Alpenrose und anderen Zwergsträuchern (Schwarzbeere, Preiselbeere, Rauschbeere). Zwergsträucher sind zwischen 10 cm und 40 cm hoch, wintergrün und meist als Sukzessionsstadien nach der Aufgabe von Almweide zu finden. Sie können mit Almweideflächen in enger Verzahnung auftreten.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_4_11_DwarfShrubs</skos:notation>
    <skos:prefLabel xml:lang="de">Zwergstrauch</skos:prefLabel>
    <skos:prefLabel xml:lang="en">dwarf shrubs</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:definition xml:lang="de">Flächen, die keine vegetationsbedeckung aufweisen (abiotisch)</skos:definition>
    <skos:definition xml:lang="en">Any unvegetated surfaces, either covered with man-made artificial structures or geologically natural material surfaces (with or without anthropogenic influence or impact).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp"/>
    <skos:notation>1_Abiotic</skos:notation>
    <skos:prefLabel xml:lang="de">nicht vegetationsbedeckt</skos:prefLabel>
    <skos:prefLabel xml:lang="en">abiotic</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_6_SurfaceWater">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 312_InlandWater - Zeitliche Dynamik: Wasserflächen unterliegen einer unbestimmten zeitlichen Dynamik, die von Tag, Woche, Monat und Jahr abhängig sein kann. Da Wasser als Landbedeckungsklasse manchmal nur sehr temporär und zeitlich beschränkt auftreten kann, ist dies bei der Ausweisung von flächenstatistischen Bilanzen zu Landbedeckungsveränderungen zu berücksichtigen (ähnliche Problematik wie bei Schneebedeckung bzw. Schatten)</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 312_InlandWater</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water"/>
    <skos:definition xml:lang="de">Offene Wasserflächen von stehenden und fließenden Gewässern. Bei teilweise überschirmten Gewässern (kleinere Bachläufe) wird nur die tatsächliche luftbildsichtbare Wasserfläche ausgewiesen - es sei denn, daß Laserscanning Daten eine leichte und automatisierte Differenzierung auch überschirmter Wasserflächen gestatten.</skos:definition>
    <skos:definition xml:lang="en">All kinds of inland surface water with no direct interference or interchange with open sea water.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_3_6_SurfaceWater</skos:notation>
    <skos:prefLabel xml:lang="de">Wasseroberfläche</skos:prefLabel>
    <skos:prefLabel xml:lang="en">surface water</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="en">Includes: unvegetated rocky mountainous regions, sand, also quarries and extraction sites, etc</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic"/>
    <skos:definition xml:lang="en">Any kind of surface material which remains in its natural consistence or form either with or without anthropogenic influence. Consolidated and unconsolidated surfaces.</skos:definition>
    <skos:definition xml:lang="de">Flächen, die durch keine anthropogen erzeugte dauerhaft befestigte Abdeckungs des Erdbodens charakterisiert sind</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_5_BareRock"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_3_PermanentBareSoil"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_4_Screes"/>
    <skos:notation>1_2_NonBuiltUp</skos:notation>
    <skos:prefLabel xml:lang="de">nicht befestigte Fläche</skos:prefLabel>
    <skos:prefLabel xml:lang="en">non built-up</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_4_Screes">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 1221_MineralFragments - Die Abgrenzung zu den 'sonstigen befestigten Flächen': frisch ausgehobenes Material oder temporär zwischengelagertes Material wird als Schutt/Sand bezeichnet. Wichtiges Unterscheidungskriterium zu 'sonstige befestigte Flächen' ist auch, ob der Oberboden eindeutig erkennbar durch menschliche Tätigkeiten abgeschoben (durch z.B. Bagger) und das darunterliegende Material verfestigt wurde (sonstige befestigte Flächen, z.B. Lager- und Umschlagplätze) bzw. die Flächen mit Fremdmaterial befestigt wurden (sonstige befestigte Flächen).</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 1221_MineralFragments</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp"/>
    <skos:definition xml:lang="en">Screes come to be through physical disintegration of geological formations and are the result of becoming smaller and smaller along time. They are accumulated on site due to sedimentary processes or human activity. Further subdivision is made according to their particle size and constellation.</skos:definition>
    <skos:definition xml:lang="de">Schutt und Sand: Lockersedimente wie Schuttfluren, Geröllfelder, Schotterflächen und sandige Bereiche bis hin zu Geröll (bis ca. max. 2 m Durchmesser) ohne erkennbare Beimischung von Humus. Der Vegetationsanteil beträgt maximal 10%.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_2_4_Screes</skos:notation>
    <skos:prefLabel xml:lang="en">screes</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Schotter</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water"/>
    <skos:definition xml:lang="en">Snow and Ice (solid aggregated water)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_2_Ice"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_1_Snow"/>
    <skos:notation>1_3_7_SnowIce</skos:notation>
    <skos:prefLabel xml:lang="en">snow/ice</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Schnee und Eis</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_3_PermanentBareSoil">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 1223_BareSoils - Da diese Klasse - wie die anderen - noch rein auf spektrale Merkmalen basiert, deckt sie eine sehr breite Nutzungspalette ab. Meist kommt diese Klasse im landwirtschaftlichen Bereich vor, es handelt sich dabei um Böden ohne Vegetationsbedeckung, aber mit reichlichem Humusgehalt (=Erde). Je geringer der Humusgehalt, desto mehr geht die Klasse offener Boden in die Klasse 'Schotter/Sand' über. Die Abgrenzung zum Grünbewuchs erfolgt über den Vegetationsindex (Einteilung in: keine, wenig, mittel und hoch siehe 'Grünbewuchs)). Der Vegetationsanteil beträgt maximal 10%. - Die im Gemüsebau manchmal anzutreffende temporäre Abdeckung von Äckern bzw. Ackerstreifen mittels schwarzen und weißen Folien soll als 'offener Boden' klassifiziert werden.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 1223_BareSoils</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp"/>
    <skos:definition xml:lang="de">Nicht vegetationsbedeckter, offener Boden.</skos:definition>
    <skos:definition xml:lang="en">Mixture of mineral and organic material that is capable of sustaining plant life, but being unvegetated at the moment of observation (primarily bare arable land).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_2_3_PermanentBareSoil</skos:notation>
    <skos:prefLabel xml:lang="en">permanent bare soil</skos:prefLabel>
    <skos:prefLabel xml:lang="de">offener Boden (dauerhaft)</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_1_HerbaceousPermanent">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">Flächen, die Größtenteils als Grünland genutzt werden.</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous"/>
    <skos:definition xml:lang="en">herbeceous vegetation that is permanently covered with vegetation throughout a year</skos:definition>
    <skos:definition xml:lang="de">Flächen, die über ein ganzes Jahr hinweg durch Grünbewuchs bedeckt sind und keine unterjährliche Bodenbearbeitung auzfweisen.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_5_12_1_HerbaceousPermanent</skos:notation>
    <skos:prefLabel xml:lang="en">herbaceous permanent</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Grünbewuchs dauerhaft</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_2_MixedTrees">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees"/>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_4_9_2_MixedTrees</skos:notation>
    <skos:prefLabel xml:lang="en">mixed trees</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Mischung Laub/Nadel</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_10_Bushes">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 2121_RegularBushes/Shrubs - Die im Siedlungsbereich häufig anzutreffenden Hecken und Gebüschreihen werden erst ab einer Breite von 1m erfasst. Für die Überprüfung der Genauigkeit gilt die generelle Evaluierungsbreite von 3m. - Weinreben werden aufgrund ihrer geringen Breite, aber der erkennbaren linearen Struktur, unter 'Grünbewuchs' mit dem Attribut 'lineare, parallele Struktur' geführt.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 2121_RegularBushes/Shrubs</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody"/>
    <skos:definition xml:lang="en">woody plants with a height between 0,5 and 5m.</skos:definition>
    <skos:definition xml:lang="de">Mit Krummholzbestände (z.B. Latsche), Büschen (z.B. Grünerle), Sträuchern (z.B. Hecken) bewachsene Flächen. Die Höhe liegt unter 5 m aber fast immer über 0,5 m. Der Deckungsgrad mit Gebüschen liegt dabei &gt;50%. Jungwuchs und Dickungen mit einer Höhe &lt; 5 m fallen ebenfalls in diese Klasse.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_4_10_Bushes</skos:notation>
    <skos:prefLabel xml:lang="de">Gebüsch</skos:prefLabel>
    <skos:prefLabel xml:lang="en">bushes</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_Biotic">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="en">Includes: - Any vegetated land surface, either naturally grown, semi-natural or artificially planted vegetation (e.g. crops, urban parks), with or without anthropogenic influence.</dcterms:description>
    <dcterms:description xml:lang="de">Vegetationsbedeckte Flächen weisen eine bestimmte Dichte der Biomasse zum Zeitpunkt der Aufnahme auf. Diese Vegetationsdichte kann durch entsprechende Parameter wie z.B. dem NDVI aus Fernerkundungsdaten ermittelt werden. Für deren Ermittlung ist die Verfügbarkeit von spektraler Information aus dem nahen Infrarot Bereich erforderlich (IR-Luftbilder oder Satellitenbilder). - Der Vegetationsindex ist je nach Phänologie saisonalen und jährlichen Änderungen unterworfen. Trotz dieser Änderungen ist der Vegetationsindex ein wichtiges Attribut und wird zur Differenzierung sowie räumlichen Trennung dieser Klassen herangezogen werden.</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:definition xml:lang="en">Biotic surfaces have to be differentiated according to their attributes (e.g. coniferous percentage, biomass density, wetness, etc.)</skos:definition>
    <skos:definition xml:lang="de">Flächen mit einer Vegetationsbedeckung (biotisch)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous"/>
    <skos:notation>2_Biotic</skos:notation>
    <skos:prefLabel xml:lang="en">biotic</skos:prefLabel>
    <skos:prefLabel xml:lang="de">vegetationsbedeckt</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="en">identical to EAGLE class: 22_Herbaceous</dcterms:description>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 22_Herbaceous - Abgrenzung von benachbarten Objekten gleicher Klassenzugehörigkeit: Insbesondere in der Klasse Grünbewuchs ist es wichtig - ähnlich wie in der Klasse offener Boden jene Objekte zu erfassen, die eine geschlossene räumliche Einheit bilden. Grünbewuchsflächen können aneinander angrenzen und trotzdem werden sie räumlich differenziert, da sie sich - Auch sämtliche Ackerflächen, die eine luftbildsichtbare Vegetation aufweisen fallen in diese Kategorie (Weizen, Mais, Erdäpfel, etc.). Die Grünflächen enthalten somit alle vegetationsbedeckten aber nicht bestockten Flächen. Darunter fallen sowohl natürliche Wiesen, Wirtschaftsgrünland, Parkanlagen, Rasenflächen in Hausgärten, Grünbegleitstreifen etc.</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous"/>
    <skos:definition xml:lang="de">Sämtliche mit sichtbarer niedriger Vegetation (Gras oder Krautvegetation) bedeckte Flächen. Die innere Differenzierung des Grünbewuchse ('einzelne Schläge als getrennte Segmente' - Landschaftsstruktur) ist dabei mitzuerfassen. Der Deckungsgrad durch oberirdische Pflanzenteile muß mindestens 10% innerhalb der Referenzfläche einnehmen.</skos:definition>
    <skos:definition xml:lang="en">This large class contains all kind of arable crops, pastures, meadows and natural grasslands. As for bare soil it is in the context of agricultural use not essential to assign the object the correct class, as the class of an object is a rather random issue depending on the acquisition date. However it is important to differentiate objects of the same class, if they are located next to each other, and if they can differentiate according to their vegetation index and physiognomic appearance.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_2_HerbaceousPeriodically"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_1_HerbaceousPermanent"/>
    <skos:notation>2_5_12_Herbaceous</skos:notation>
    <skos:prefLabel xml:lang="de">Grünbewuchs</skos:prefLabel>
    <skos:prefLabel xml:lang="en">herbaceous</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_2_OtherConstructedArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 1112_OtherConstructions - Beinhaltet befestigte Straßen, Gehsteige, Parkplätze und sonstige befestigte Flächen, wie z.B. Tennisplätze, Sportlaufbahnen etc. Auch befestigte Baunebenflächen und Manipulationsflächen in Gewerbe- und Industrie fallen darunter. Ebenso in diese Kategorie fallen die dauerhaft angelegten landwirtschaftlichen Güterwege und Zu- und Abfahrten zu Industrie- und Gewerbegebieten sowie Lagerplätzen. - Plätze in Anlagen mit permanenter Nutzung sind in der Regel als befestigt anzusehen (Kompostanlagen, Industrielager, LKW-Abstellplätze etc.). Vorübergehend zur Lagerung benutzte Flächen sind in der Regel nicht durch Aufbringung von Fremdmaterial charakterisiert, aber die menschliche Intention ist klar erkennbar, der Oberboden angeschoben und das Erdreich verdichtet (Holzlager, Materialdepots von Baustellen etc.). - Abgrenzung: Bei der Klasse Schotter/Sand handelt es sich hingegen um natürliche Prozesse.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 1112_OtherConstructions - Includes: e.g. asphalt, concrete, pave dings like on roads, parking lots, squares, storages areas, airport run ways, quays, sealed bottom pools, unvegetated cemeteries. - Excludes: gravel bed of railway track. It is an artificial surface but not impervious, better to be placed under Gravel, Pebble</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp"/>
    <skos:definition xml:lang="de">Künstlich angelegte, ganz oder teilweise versiegelte Flächen, insbesondere asphaltierte, betonierte, bekieste, geschotterte, gemergelte sowie mit Steinen oder Platten belegte Böden (© Schweizer Arealstatistik).</skos:definition>
    <skos:definition xml:lang="en">Flat surfaces covered by any type of impervious material which that is used for artificial surface pavements (e.g. asphalt, concrete, tarmacadam).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_1_2_OtherConstructedArea</skos:notation>
    <skos:prefLabel xml:lang="de">sonstige befestigte Fläche</skos:prefLabel>
    <skos:prefLabel xml:lang="en">other constructed area</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic"/>
    <skos:definition xml:lang="en">The chemical substance of water (H2O), either in liquid or in frozen solid state of aggregation.</skos:definition>
    <skos:definition xml:lang="de">Die Landbedeckung Wasser wird nach ihren Aggregatzuständen unterschieden.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_6_SurfaceWater"/>
    <skos:notation>1_3_Water</skos:notation>
    <skos:prefLabel xml:lang="en">water</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Wasser</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_1_Building">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 1111_Buildings - Diese Klasse beinhaltet Gebäude und Gebäudekomplexe. Gebäude sind aus Sicht der Raumplanung ab einer Größe von 50 m² zu erfassen, da diese Größe die minimale Fläche eines Gebäudes ist, welches als Hauptgebäude (ganzjährige Wohnung und/oder betriebliche Arbeitsstätte) geeignet ist. Die minimale Höhe eines Gebäudes wird nicht definiert. - Im Bau befindliche Gebäude, bei welchen die Dachkonstruktion noch nicht abgeschlossen ist, werden als 'sonstige befestigte Flächen' klassifiziert.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 1111_Buildings</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp"/>
    <skos:definition xml:lang="de">Überdachte, auf Dauer errichtete Bauwerke, die geeignet oder bestimmt sind, dem Schutz oder der Unterbringung von Menschen, Tieren oder Sachen zu dienen.</skos:definition>
    <skos:definition xml:lang="en">Roof-covered constructions like single buildings or block of buildings with a significant height difference from the surrounding surface</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_1_1_Building</skos:notation>
    <skos:prefLabel xml:lang="de">Gebäude</skos:prefLabel>
    <skos:prefLabel xml:lang="en">building</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_2_HerbaceousPeriodically">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">flächen, die größtenteils als Acker genutzt werden</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous"/>
    <skos:definition xml:lang="en">herbeceous vegetation that is not permanently covered with vegetation throughout a year. Bare soil can be observed at least once per year</skos:definition>
    <skos:definition xml:lang="de">Flächen, die im Laufe eines Jahres zumindest einmal eine Bodenbearbeitung aufweisen.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_5_12_2_HerbaceousPeriodically</skos:notation>
    <skos:prefLabel xml:lang="en">herbaceous periodically</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Grünbewuchs periodisch</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_1_Snow">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 321_Snow - Zeitliche Dynamik: Die Schneebedeckung ist zeitlich variable (Wochen, Monats-, Jahresdynamik). Dies ist bei der Etablierung eines Monitoringsystemes zu berücksichtigen, da keine echten Landbedeckungsänderungen unterhalb der Schneedecke feststellbar sind, dürfen die vom Schnee bedeckten Flächen auch nicht in Änderungsstatistiken übernommen werden. Wie bei großflächig beschatteten Bereichen sind auch bei Schneeflächen auf die Befüllung durch Ersatzdaten (Übernahme alter Daten bzw. Heranziehen weiterer Satellitenbildaufnahmen) besonders zu achten.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 321_Snow</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce"/>
    <skos:definition xml:lang="en">Permanent snow in alpine areas. Temporary snow coverage must not be mapped.</skos:definition>
    <skos:definition xml:lang="de">Die Schneebedeckung ist naturgemäß in erster Linie vom Zeitpunkt der Aufnahme mittels Fernerkundungsdaten abhängig. Jedoch stellt sie sowohl in Luft- als auch in Satellitenbildern eine relativ einfach zu differenzierende Landbedeckungsklasse dar. Schnee überdeckt eine andere Landbedeckungsklasse, die aber zum Zeitpunkt der Aufnahme eben nicht feststellbar ist, sofern keine Information aus einer Vorperiode zur Verfügung steht. Vielfach befinden sich auch Eisflächen (Gletscher) unter dem Schnee.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_3_7_1_Snow</skos:notation>
    <skos:prefLabel xml:lang="en">snow</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Schnee</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
</rdf:RDF>
