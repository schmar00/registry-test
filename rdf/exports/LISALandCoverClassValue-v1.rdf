  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_3_PermanentBareSoil">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 1223_BareSoils - Da diese Klasse - wie die anderen - noch rein auf spektrale Merkmalen basiert, deckt sie eine sehr breite Nutzungspalette ab. Meist kommt diese Klasse im landwirtschaftlichen Bereich vor, es handelt sich dabei um BÃ¶den ohne Vegetationsbedeckung, aber mit reichlichem Humusgehalt (=Erde). Je geringer der Humusgehalt, desto mehr geht die Klasse offener Boden in die Klasse 'Schotter/Sand' Ã¼ber. Die Abgrenzung zum GrÃ¼nbewuchs erfolgt Ã¼ber den Vegetationsindex (Einteilung in: keine, wenig, mittel und hoch siehe 'GrÃ¼nbewuchs)). Der Vegetationsanteil betrÃ¤gt maximal 10%. - Die im GemÃ¼sebau manchmal anzutreffende temporÃ¤re Abdeckung von Ãckern bzw. Ackerstreifen mittels schwarzen und weiÃen Folien soll als 'offener Boden' klassifiziert werden.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 1223_BareSoils</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp"/>
    <skos:definition xml:lang="de">Nicht vegetationsbedeckter, offener Boden.</skos:definition>
    <skos:definition xml:lang="en">Mixture of mineral and organic material that is capable of sustaining plant life, but being unvegetated at the moment of observation (primarily bare arable land).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_2_3_PermanentBareSoil</skos:notation>
    <skos:prefLabel xml:lang="en">permanent bare soil</skos:prefLabel>
    <skos:prefLabel xml:lang="de">offener Boden (dauerhaft)</skos:prefLabel>
    <skos:scopeNote>INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_1_Building">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
