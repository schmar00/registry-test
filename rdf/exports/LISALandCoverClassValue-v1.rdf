    <dcterms:title xml:lang="de">LISA Bodenbedeckungsklasse</dcterms:title>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_Biotic"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic"/>
