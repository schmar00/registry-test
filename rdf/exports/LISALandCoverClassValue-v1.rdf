  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_3_ConiferousTrees">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees"/>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_4_9_3_ConiferousTrees</skos:notation>
    <skos:prefLabel xml:lang="de">Nadelbäume</skos:prefLabel>
    <skos:prefLabel xml:lang="en">coniferous trees</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_13_Reeds">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 2212_Reeds, Bamboos and Canes</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 2212_Reeds, Bamboos and Canes</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous"/>
    <skos:definition xml:lang="de">Schilf kommt in größerem Ausmaß z.B. im Schilfgürtel des Neusiedler Sees vor und ist spektral eindeutig von anderen Klassen zu unterscheiden. Kleinsträumig ist Schilf mit Wasserflächen assoziiert (MVU = 500 m²)</skos:definition>
    <skos:definition xml:lang="en">Reed is a common name for several tall, grass-like plants of wetlands. They are all members of the order Poales (in the modern, expanded circumscription) (© wikipedia)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_5_13_Reeds</skos:notation>
    <skos:prefLabel xml:lang="de">Schilf</skos:prefLabel>
    <skos:prefLabel xml:lang="en">reeds</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="en">Excludes: - Urban greenery may be artificial and under human maintenance, but after all it is vegetation and not to be placed her.</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic"/>
    <skos:definition xml:lang="de">Befestigte Flächen sind charakterisiert durch eine dauerhafte befestigte Abdeckung des Erdbodens</skos:definition>
    <skos:definition xml:lang="en">All Surfaces where Landscape has been changed by or is under influence of human construction activities by replacing natural surfaces with artificial abiotic 2D/3D constructions or artificial materials. Artificial parts of urban and suburban areas, where mankind has settled with permanent settlement infrastructures, also the settlement parts of rural areas, built-up areas (buildings, other constructions and sealed flat surfaces) and non-built-up areas (no buildings, artificial and unsealed).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_2_OtherConstructedArea"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_1_Building"/>
    <skos:notation>1_1_BuiltUp</skos:notation>
    <skos:prefLabel xml:lang="en">built-up</skos:prefLabel>
    <skos:prefLabel xml:lang="de">befestigte Fläche</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="en">identical to EAGLE class: 211_Trees</dcterms:description>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 211_Trees - Bestockte Flächen können aus Einzelbäumen, Baumgruppen oder zusammenhängenden Waldbeständen aufgebaut sein. Sie weisen fast immer auch einen entsprechenden Höhenunterschied (erkennbar durch Schatten bzw. Höhendifferenz aus ALS-Daten) zu benachbarten Flächen auf. Die mit Bäumen bestockten Flächen werden aufgrund ihrer flächendeckenden Bedeutung (ca. 47 % von Österreich) sollen nach dem Kriterium Flächengröße validiert werden. Die Flächengrößen der Validierungsstrata entsprechen ca. den in Version 1 des Datenmodelles geführten Unterklassen 'Einzelbaum', 'Baumgruppe' und 'Waldstück'. - Die Zuweisung zur Landbedeckungsklasse 'bestockte Fläche' nimmt keineswegs zwangsläufig die Zuordnung zur Landnutzungsklasse 'Wald' vorweg. Bei überwiegender Dominanz anderer als forstlicher Nutzung können Waldstücke durchaus auch der Landnutzung 'Landwirtschaft' zugewiesen werden bzw. aufgrund des Größenkriteriums in einer anderen Klasse aggregiert werden. - Anzumerken ist dabei, dass auch Streuobstwiesen, Obstplantagen oder Christbaumkulturen in der Klasse 'bestockte Fläche' ausgewiesen werden. Eine Differenzierung nach der Art der Nutzung (Wald vs. Landwirtschaft) erfolgt erst im Datenmodellbereich 'Landnutzung'.</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody"/>
    <skos:definition xml:lang="de">Mit bestockter Fläche werden innerhalb von LISA sämtliche mit verholzten Pflanzen (Bäumen oder Gebüschen) bestockte Flächen definiert. Die Höhe von bestockten Flächen ist &gt;5 m (Ausnahme Jungwuchs und Dickungen - können auch kleiner als 5m sein, und werden daher in der Landbedeckung trotzdem zu Klasse 'bestockte Fläche' gezählt!).</skos:definition>
    <skos:definition xml:lang="en">Trees with a minimum crown coverage: 10% (measured as stem-to-stem distance of 10m)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_3_ConiferousTrees"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_2_MixedTrees"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_1_DeciduousTrees"/>
    <skos:notation>2_4_9_Trees</skos:notation>
    <skos:prefLabel xml:lang="de">bestockte Fläche</skos:prefLabel>
    <skos:prefLabel xml:lang="en">trees</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_2_Ice">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 322_IceAndGlaciers - Eis findet sich in erster Linie in der alpinen Höhenzone wieder (innerhalb von LISA werden kaum Winteraufnahmen von gefrorenen Flüssen und Seen verwendet). Eis weist spektral eine deutlich unterschiedliche Signatur als Schnee auf (bläuliche Farbtöne). Eis bildet damit den Hauptbestandteil von Gletscherflächen. Vielfach ist das eigentliche Eis jedoch durch Schutt- und Moränenmaterial überdeckt und kann nicht als solches identifiziert werden.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 322_IceAndGlaciers</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce"/>
    <skos:definition xml:lang="de">Vorwiegend mit Gletscher und Firn bedeckte Flächen.</skos:definition>
    <skos:definition xml:lang="en">Glaciers in alpine zones.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_3_7_2_Ice</skos:notation>
    <skos:prefLabel xml:lang="en">ice</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Eis</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_5_BareRock">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 1211_BareRocks - Natura 2000: Felsflächen beinhalten bedeutende Lebensraumtypen mit großflächigem Vorkommen. Weitere Differenzierung über Geologie. - - 8210 Kalkfelsen mit Felsspaltenvegetation (Flächenschätzung 50.000-240.000 ha) - - 8220 Silikatfelsen mit Felsspaltenvegetation (Flächenschätzung 10.000-100.000 ha) - Hinweis: Felsbereiche sind oft sehr stark von topographischen Schattenflächen beeinflußt. Im Sinne eines flächenstatistisch korrekten Monitoring ist auf die Befüllung dieser Schattenflächen durch Ersatzdaten (Übernahme veralteter Daten bzw. Heranziehen weiterer Satellitenbildaufnahmen) besonders zu achten.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 1211_BareRocks - Includes: - e.g. solid (closed) rock formations, fresh lava flows, quarries, mineral extraction sites, open pit mines</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp"/>
    <skos:definition xml:lang="en">The rock surface is continuous except perhaps for a few cracks in the material. Some areas may be covered by shallow layers of soil or there could be isolated pockets of soil or a mixture of both.</skos:definition>
    <skos:definition xml:lang="de">Felsen und anstehendes festes Gestein. Anhäufungen von Gestein (Gesteinsfelder) werden ab einem durchschnittlichen Durchmesser von 2m als 'Fels/Gestein' ausgewiesen, darunter als 'Schotter/Sand'.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_2_5_BareRock</skos:notation>
    <skos:prefLabel xml:lang="en">bare rock</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Fels</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
