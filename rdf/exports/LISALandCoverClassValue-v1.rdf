  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_4_Screes">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 1221_MineralFragments - Die Abgrenzung zu den 'sonstigen befestigten FlÃ¤chen': frisch ausgehobenes Material oder temporÃ¤r zwischengelagertes Material wird als Schutt/Sand bezeichnet. Wichtiges Unterscheidungskriterium zu 'sonstige befestigte FlÃ¤chen' ist auch, ob der Oberboden eindeutig erkennbar durch menschliche TÃ¤tigkeiten abgeschoben (durch z.B. Bagger) und das darunterliegende Material verfestigt wurde (sonstige befestigte FlÃ¤chen, z.B. Lager- und UmschlagplÃ¤tze) bzw. die FlÃ¤chen mit Fremdmaterial befestigt wurden (sonstige befestigte FlÃ¤chen).</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 1221_MineralFragments</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp"/>
    <skos:definition xml:lang="en">Screes come to be through physical disintegration of geological formations and are the result of becoming smaller and smaller along time. They are accumulated on site due to sedimentary processes or human activity. Further subdivision is made according to their particle size and constellation.</skos:definition>
    <skos:definition xml:lang="de">Schutt und Sand: Lockersedimente wie Schuttfluren, GerÃ¶llfelder, SchotterflÃ¤chen und sandige Bereiche bis hin zu GerÃ¶ll (bis ca. max. 2 m Durchmesser) ohne erkennbare Beimischung von Humus. Der Vegetationsanteil betrÃ¤gt maximal 10%.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_2_4_Screes</skos:notation>
    <skos:prefLabel xml:lang="en">screes</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Schotter</skos:prefLabel>
    <skos:scopeNote>INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
