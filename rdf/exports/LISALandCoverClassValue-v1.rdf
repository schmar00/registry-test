    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 322_IceAndGlaciers - Eis findet sich in erster Linie in der alpinen HÃ¶henzone wieder (innerhalb von LISA werden kaum Winteraufnahmen von gefrorenen FlÃ¼ssen und Seen verwendet). Eis weist spektral eine deutlich unterschiedliche Signatur als Schnee auf (blÃ¤uliche FarbtÃ¶ne). Eis bildet damit den Hauptbestandteil von GletscherflÃ¤chen. Vielfach ist das eigentliche Eis jedoch durch Schutt- und MorÃ¤nenmaterial Ã¼berdeckt und kann nicht als solches identifiziert werden.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 322_IceAndGlaciers</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce"/>
    <skos:definition xml:lang="de">Vorwiegend mit Gletscher und Firn bedeckte FlÃ¤chen.</skos:definition>
    <skos:definition xml:lang="en">Glaciers in alpine zones.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_3_7_2_Ice</skos:notation>
    <skos:prefLabel xml:lang="en">ice</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Eis</skos:prefLabel>
    <skos:scopeNote>INSPIRE governance level: national-technical</skos:scopeNote>
