    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_4_9_1_DeciduousTrees</skos:notation>
    <skos:prefLabel xml:lang="de">Laubbäume</skos:prefLabel>
    <skos:prefLabel xml:lang="en">deciduous trees</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_Biotic"/>
    <skos:definition xml:lang="de">Flächen, die von nicht verholzter Vegetation bedeckt sind</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_13_Reeds"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous"/>
