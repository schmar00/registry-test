  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_13_Reeds">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 2212_Reeds, Bamboos and Canes</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 2212_Reeds, Bamboos and Canes</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous"/>
    <skos:definition xml:lang="de">Schilf kommt in grÃ¶Ãerem AusmaÃ z.B. im SchilfgÃ¼rtel des Neusiedler Sees vor und ist spektral eindeutig von anderen Klassen zu unterscheiden. KleinstrÃ¤umig ist Schilf mit WasserflÃ¤chen assoziiert (MVUÂ =Â 500Â mÂ²)</skos:definition>
    <skos:definition xml:lang="en">Reed is a common name for several tall, grass-like plants of wetlands. They are all members of the order Poales (in the modern, expanded circumscription) (Â© wikipedia)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>2_5_13_Reeds</skos:notation>
    <skos:prefLabel xml:lang="de">Schilf</skos:prefLabel>
    <skos:prefLabel xml:lang="en">reeds</skos:prefLabel>
    <skos:scopeNote>INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="en">identical to EAGLE class: 211_Trees</dcterms:description>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 211_Trees - Bestockte FlÃ¤chen kÃ¶nnen aus EinzelbÃ¤umen, Baumgruppen oder zusammenhÃ¤ngenden WaldbestÃ¤nden aufgebaut sein. Sie weisen fast immer auch einen entsprechenden HÃ¶henunterschied (erkennbar durch Schatten bzw. HÃ¶hendifferenz aus ALS-Daten) zu benachbarten FlÃ¤chen auf. Die mit BÃ¤umen bestockten FlÃ¤chen werden aufgrund ihrer flÃ¤chendeckenden Bedeutung (ca. 47 % von Ãsterreich) sollen nach dem Kriterium FlÃ¤chengrÃ¶Ãe validiert werden. Die FlÃ¤chengrÃ¶Ãen der Validierungsstrata entsprechen ca. den in Version 1 des Datenmodelles gefÃ¼hrten Unterklassen 'Einzelbaum', 'Baumgruppe' und 'WaldstÃ¼ck'. - Die Zuweisung zur Landbedeckungsklasse 'bestockte FlÃ¤che' nimmt keineswegs zwangslÃ¤ufig die Zuordnung zur Landnutzungsklasse 'Wald' vorweg. Bei Ã¼berwiegender Dominanz anderer als forstlicher Nutzung kÃ¶nnen WaldstÃ¼cke durchaus auch der Landnutzung 'Landwirtschaft' zugewiesen werden bzw. aufgrund des GrÃ¶Ãenkriteriums in einer anderen Klasse aggregiert werden. - Anzumerken ist dabei, dass auch Streuobstwiesen, Obstplantagen oder Christbaumkulturen in der Klasse 'bestockte FlÃ¤che' ausgewiesen werden. Eine Differenzierung nach der Art der Nutzung (Wald vs. Landwirtschaft) erfolgt erst im Datenmodellbereich 'Landnutzung'.</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody"/>
    <skos:definition xml:lang="de">Mit bestockter FlÃ¤che werden innerhalb von LISA sÃ¤mtliche mit verholzten Pflanzen (BÃ¤umen oder GebÃ¼schen) bestockte FlÃ¤chen definiert. Die HÃ¶he von bestockten FlÃ¤chen ist &gt;5 m (Ausnahme Jungwuchs und Dickungen - kÃ¶nnen auch kleiner als 5m sein, und werden daher in der Landbedeckung trotzdem zu Klasse 'bestockte FlÃ¤che' gezÃ¤hlt!).</skos:definition>
    <skos:definition xml:lang="en">Trees with a minimum crown coverage: 10% (measured as stem-to-stem distance of 10m)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_3_ConiferousTrees"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_2_MixedTrees"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_1_DeciduousTrees"/>
    <skos:notation>2_4_9_Trees</skos:notation>
    <skos:prefLabel xml:lang="de">bestockte FlÃ¤che</skos:prefLabel>
    <skos:prefLabel xml:lang="en">trees</skos:prefLabel>
    <skos:scopeNote>INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_2_Ice">
