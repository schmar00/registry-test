  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_Biotic">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="en">Includes: - Any vegetated land surface, either naturally grown, semi-natural or artificially planted vegetation (e.g. crops, urban parks), with or without anthropogenic influence.</dcterms:description>
    <dcterms:description xml:lang="de">Vegetationsbedeckte FlÃ¤chen weisen eine bestimmte Dichte der Biomasse zum Zeitpunkt der Aufnahme auf. Diese Vegetationsdichte kann durch entsprechende Parameter wie z.B. dem NDVI aus Fernerkundungsdaten ermittelt werden. FÃ¼r deren Ermittlung ist die VerfÃ¼gbarkeit von spektraler Information aus dem nahen Infrarot Bereich erforderlich (IR-Luftbilder oder Satellitenbilder). - Der Vegetationsindex ist je nach PhÃ¤nologie saisonalen und jÃ¤hrlichen Ãnderungen unterworfen. Trotz dieser Ãnderungen ist der Vegetationsindex ein wichtiges Attribut und wird zur Differenzierung sowie rÃ¤umlichen Trennung dieser Klassen herangezogen werden.</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:definition xml:lang="en">Biotic surfaces have to be differentiated according to their attributes (e.g. coniferous percentage, biomass density, wetness, etc.)</skos:definition>
    <skos:definition xml:lang="de">FlÃ¤chen mit einer Vegetationsbedeckung (biotisch)</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous"/>
    <skos:notation>2_Biotic</skos:notation>
    <skos:prefLabel xml:lang="en">biotic</skos:prefLabel>
    <skos:prefLabel xml:lang="de">vegetationsbedeckt</skos:prefLabel>
    <skos:scopeNote>INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
