  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_1_Snow">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 321_Snow - Zeitliche Dynamik: Die Schneebedeckung ist zeitlich variable (Wochen, Monats-, Jahresdynamik). Dies ist bei der Etablierung eines Monitoringsystemes zu berÃ¼cksichtigen, da keine echten LandbedeckungsÃ¤nderungen unterhalb der Schneedecke feststellbar sind, dÃ¼rfen die vom Schnee bedeckten FlÃ¤chen auch nicht in Ãnderungsstatistiken Ã¼bernommen werden. Wie bei groÃflÃ¤chig beschatteten Bereichen sind auch bei SchneeflÃ¤chen auf die BefÃ¼llung durch Ersatzdaten (Ãbernahme alter Daten bzw. Heranziehen weiterer Satellitenbildaufnahmen) besonders zu achten.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 321_Snow</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce"/>
    <skos:definition xml:lang="en">Permanent snow in alpine areas. Temporary snow coverage must not be mapped.</skos:definition>
    <skos:definition xml:lang="de">Die Schneebedeckung ist naturgemÃ¤Ã in erster Linie vom Zeitpunkt der Aufnahme mittels Fernerkundungsdaten abhÃ¤ngig. Jedoch stellt sie sowohl in Luft- als auch in Satellitenbildern eine relativ einfach zu differenzierende Landbedeckungsklasse dar. Schnee Ã¼berdeckt eine andere Landbedeckungsklasse, die aber zum Zeitpunkt der Aufnahme eben nicht feststellbar ist, sofern keine Information aus einer Vorperiode zur VerfÃ¼gung steht. Vielfach befinden sich auch EisflÃ¤chen (Gletscher) unter dem Schnee.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_3_7_1_Snow</skos:notation>
    <skos:prefLabel xml:lang="en">snow</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Schnee</skos:prefLabel>
    <skos:scopeNote>INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
