  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_2_OtherConstructedArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso>http://www.landinformationsystem.at/en-us/lisa/overview.aspx</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/lcn"/>
    <dcterms:description xml:lang="de">identisch mit EAGLE-Klasse: 1112_OtherConstructions - Beinhaltet befestigte StraÃen, Gehsteige, ParkplÃ¤tze und sonstige befestigte FlÃ¤chen, wie z.B. TennisplÃ¤tze, Sportlaufbahnen etc. Auch befestigte BaunebenflÃ¤chen und ManipulationsflÃ¤chen in Gewerbe- und Industrie fallen darunter. Ebenso in diese Kategorie fallen die dauerhaft angelegten landwirtschaftlichen GÃ¼terwege und Zu- und Abfahrten zu Industrie- und Gewerbegebieten sowie LagerplÃ¤tzen. - PlÃ¤tze in Anlagen mit permanenter Nutzung sind in der Regel als befestigt anzusehen (Kompostanlagen, Industrielager, LKW-AbstellplÃ¤tze etc.). VorÃ¼bergehend zur Lagerung benutzte FlÃ¤chen sind in der Regel nicht durch Aufbringung von Fremdmaterial charakterisiert, aber die menschliche Intention ist klar erkennbar, der Oberboden angeschoben und das Erdreich verdichtet (Holzlager, Materialdepots von Baustellen etc.). - Abgrenzung: Bei der Klasse Schotter/Sand handelt es sich hingegen um natÃ¼rliche Prozesse.</dcterms:description>
    <dcterms:description xml:lang="en">identical to EAGLE class: 1112_OtherConstructions - Includes: e.g. asphalt, concrete, pave dings like on roads, parking lots, squares, storages areas, airport run ways, quays, sealed bottom pools, unvegetated cemeteries. - Excludes: gravel bed of railway track. It is an artificial surface but not impervious, better to be placed under Gravel, Pebble</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lc"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp"/>
    <skos:definition xml:lang="de">KÃ¼nstlich angelegte, ganz oder teilweise versiegelte FlÃ¤chen, insbesondere asphaltierte, betonierte, bekieste, geschotterte, gemergelte sowie mit Steinen oder Platten belegte BÃ¶den (Â© Schweizer Arealstatistik).</skos:definition>
    <skos:definition xml:lang="en">Flat surfaces covered by any type of impervious material which that is used for artificial surface pavements (e.g. asphalt, concrete, tarmacadam).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"/>
    <skos:notation>1_1_2_OtherConstructedArea</skos:notation>
    <skos:prefLabel xml:lang="de">sonstige befestigte FlÃ¤che</skos:prefLabel>
    <skos:prefLabel xml:lang="en">other constructed area</skos:prefLabel>
    <skos:scopeNote>INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous">
