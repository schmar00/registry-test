<https://registry.inspire.gv.at/codelist/stmLandUseValue:1> {
    <https://registry.inspire.gv.at/codelist/stmLandUseValue/dAIndustry> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "AS-Industrie sind noch nicht vollwertige Industrieflächen, deren Herstellung aber zu erwarten ist und die nicht als Sanierungsgebiete ausgewiesen sind."@de,
            "DA-Industry are not yet fully developed industrial sites, but their production is expected and they are not designated as redevelopment sites."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "dAIndustry" ;
        skos:prefLabel "AS-Industrie"@de,
            "DA-Industry"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/dAResidentialArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "AS-Wohnen sind noch nicht vollwertige Wohnflächen, deren Herstellung aber zu erwarten ist und die nicht als Sanierungsgebiete ausgewiesen sind."@de,
            "DA-Residential areas are not yet fully-fledged residential areas, but their construction is expected and they are not designated as redevelopment areas."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "dAResidentialArea" ;
        skos:prefLabel "AS-Wohnen"@de,
            "DA-Residential area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/dAVillage> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "AS-Dorf sind noch nicht vollwertige Dorfflächen, deren Herstellung aber zu erwarten ist und die nicht als Sanierungsgebiete ausgewiesen sind."@de,
            "DA-Village are not yet fully-fledged village areas, but their production is expected and they are not designated as redevelopment areas."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "dAVillage" ;
        skos:prefLabel "AS-Dorf"@de,
            "DA-Village"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/fAResidentialArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "AF-Wohnen sind unbebaute Lücken  im Bauland, die nach Vorliegen der rechtlichen Kriterien als Wohngebiet erklärt werden können."@de,
            "FA-Residential area are undeveloped gaps in the building land, which can be declared a residential area once the legal criteria are met."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "fAResidentialArea" ;
        skos:prefLabel "AF-Wohnen"@de,
            "FA-Residential area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/fAVillage> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "AF-Dorf sind unbebaute Lücken  im Bauland, die nach Vorliegen der rechtlichen Kriterien als Dorfgebiet erklärt werden können."@de,
            "FA-Village are undeveloped gaps in the building land, which can be declared a village area once the legal criteria have been met."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "fAVillage" ;
        skos:prefLabel "AF-Dorf"@de,
            "FA-Village"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/forest> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "laut Forstbehörde als Wald festgelegte Areale."@de,
            "areas designated as forests according to the Forest Service."@en ;
