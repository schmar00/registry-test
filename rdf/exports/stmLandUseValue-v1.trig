        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/industryAndCommerce> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "sind Flächen für Gewerbe und Industrie inklusive Verwaltungsgebäuden und die für die Aufrechterhaltung erforderlichen Wohnungen."@de,
            "are areas for trade and industry including administrative buildings and the apartments required for maintenance."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "industryAndCommerce" ;
        skos:prefLabel "Industrie und Gewerbe"@de,
            "Industry and commerce"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/mainAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Kerngebiete sind Flächen mit einer im Vergleich zu anderen Baugebieten höheren Nutzungsvielfalt und Bebauungsdichte."@de,
            "Are areas with a higher variety of uses and building density compared to other building areas."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "mainAreas" ;
        skos:prefLabel "Kerngebiet"@de,
            "Main areas"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/openland> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Alle nicht als Bauland und Verkehrsland festgelegte Grundflächen gehören zum Freiland. Im Freiland können Sondernutzungen festgelegt werden (z.B.: öffentliche Parkanlagen)."@de,
            "All land not designated as building land or traffic land belongs to the open land. Special uses can be defined in the open land (e.g.: public parks)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "openland" ;
        skos:prefLabel "Freiland"@de,
            "Openland"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/rAIndustry> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "SG-Industrie sind nicht vollwertige Baulandflächen, die nach Beseitigung von Mängel zu vollwertigen Industriegebieten werden."@de,
            "RA-Industrial areas are not fully fledged building land, which become fully fledged industrial areas once defects have been remedied."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "rAIndustry" ;
        skos:prefLabel "SG-Industrie"@de,
            "RA-Industry"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/rAResidentialArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "SG-Wohnen sind nicht vollwertige Baulandflächen, die nach Beseitigung von Mängel zu vollwertigen Wohngebieten werden."@de,
            "RA-Residential areas are not fully-fledged building land that becomes fully-fledged residential areas after defects have been remedied."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "rAResidentialArea" ;
        skos:prefLabel "SG-Wohnen"@de,
            "RA-Residential area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/rAVillage> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "SG-Dorf  sind nicht vollwertige Baulandflächen, die nach Beseitigung von Mängel zu vollwertigen Dorfgebiet werden."@de,
            "RA-Villages are not fully-fledged building land which, once defects have been remedied, become fully-fledged village areas."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "rAVillage" ;
        skos:prefLabel "SG-Dorf"@de,
            "RA-Village"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/railway> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Flächen die durch rechtwirksame überörtliche Festlegungen für den Bahnbetrieb festgelegt wurden."@de,
            "Areas that have been defined for railway operation by legally effective supra-local regulations."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "railway" ;
        skos:prefLabel "Bahn"@de,
            "Railway"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/residentialAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Wohnen sind Gebiete die ausschließlich oder vornehmlich für Wohnzwecke bestimmt sind."@de,
            "Residential areas are areas that are exclusively or primarily intended for residential purposes."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "residentialAreas" ;
        skos:prefLabel "Wohnen"@de,
            "Residential areas"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/shoppingCenters> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "sind Flächen für Einkaufszentren."@de,
            "are areas for shopping centers."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "shoppingCenters" ;
        skos:prefLabel "Einkaufszentren"@de,
            "Shopping centers"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/specialUseOpenland> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "sind Flächen, wenn auf Grund ihrer besonderen Standortgunst die flächenhafte Nutzung im Vordergrund steht und diese nicht typischerweise einem Baulandgebiet zuzuordnen ist. Insbesondere sind das Flächen für Erwerbsgärtnereien, Erholungszwecke, Spielzwecke, Parkanlagen, Friedhöfe,…"@de,
            "are areas if, due to their particular locational advantages, the focus is on land use and this is not typically assigned to a building land area. In particular, these are areas for commercial nurseries, recreational purposes, playgrounds, parks, cemeteries, etc."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "specialUseOpenland" ;
        skos:prefLabel "Sondernutzung im Freiland"@de,
            "Special use in the open land"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/trafficAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Verkehrsflächen sind solche Flächen, die für die Abwicklung des fließenden und ruhenden Verkehrs, sowie für die Aufschließung des Baulandes und des Freilandes vorgesehen sind."@de,
            "Traffic areas are those areas which are intended for the handling of moving and stationary traffic, as well as for the development of building land and open land"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "trafficAreas" ;
        skos:prefLabel "Verkehr"@de,
            "Traffic areas"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/stmLandUseValue/villageAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Dorfgebiet sind Flächen, die für Bauten  land- und forstwirtschaftlicher Nutzung in verdichteter Anordnung bestimmt sind."@de,
            "Village areas are areas which are intended for buildings of agricultural and forestry use in a dense arrangement."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        skos:notation "villageAreas" ;
        skos:prefLabel "Dorfgebiet"@de,
            "Village areas"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/stmLandUseValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

