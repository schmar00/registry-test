  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/saproWindEnergy">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/am"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/am"/>
    <skos:definition xml:lang="en">The aim of this development program is to define supra-local guidelines for the spatially compatible expansion of wind energy in Styria.</skos:definition>
    <skos:definition xml:lang="de">Dieses Entwicklungsprogramm hat die Festlegung von überörtlichen Vorgaben zum raumverträglichen Ausbau der Windenergie in der Steiermark zum Ziel.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <skos:notation>saproWindEnergy</skos:notation>
    <skos:prefLabel xml:lang="de">SAPRO Windenergiezone</skos:prefLabel>
    <skos:prefLabel xml:lang="en">SAPRO Wind Energy Zone</skos:prefLabel>
