  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/WaterAbstraction">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/am"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/am"/>
    <skos:definition xml:lang="en">Section of a flowing water which is affected by anthropogenically caused drainage or restraint due to a reduction of its natural runoff.</skos:definition>
    <skos:definition xml:lang="de">Abschnitt eines Gewässers, der durch anthropogen bedingte Ableitung bzw. durch anthropogen bedingten Rückhalt von einer Abminderung des natürlichen Abflusses betroffen ist.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <skos:notation>WaterAbstraction</skos:notation>
    <skos:prefLabel xml:lang="en">Water abstraction</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Restwasserstrecke</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/Sanierungsgebiet_Luftreinhalteprogramm">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/am"/>
    <dcterms:description xml:lang="en">Def. UBA</dcterms:description>
    <dcterms:description xml:lang="de">Def. UBA</dcterms:description>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/am"/>
    <skos:definition xml:lang="de">Sanierungsgebiet ist ein Gebiet, in dem sich die Emissionsquellen befinden, die einen erheblichen Beitrag zur Überschreitung eines Immissionsgrenzwerts geleistet haben und für die in einem Luftreinhalte-Programm Maßnahmen vorgesehen werden können.</skos:definition>
    <skos:definition xml:lang="en">air quality improvement zone is an area in which the emission sources are located that have made a significant contribution to exceeding an air quality limit value and for which measures can be provided in an air pollution control program.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <skos:notation>Sanierungsgebiet_Luftreinhalteprogramm</skos:notation>
    <skos:prefLabel xml:lang="de">Sanierungsgebiet Luftreinhalteprogramm</skos:prefLabel>
    <skos:prefLabel xml:lang="en">air quality improvement zone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
