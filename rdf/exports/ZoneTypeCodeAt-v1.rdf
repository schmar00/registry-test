  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/ALSAG_Gebiete">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/am"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/am"/>
    <skos:definition xml:lang="de">Gebiete gemaess Altlastensanierungsgesetz (ALSAG). Vom Landeshauptmann gemeldete Altablagerungen (alte Deponien) und Altstandorte (ehemalige Fabriken), die vor 1989 kontaminiert sein koennen, werden nach Durchführung einer Gefaehrdungsabschaetzung und Feststellung einer erheblichen Gefaehrdung für die Umwelt und Gesundheit (nach Bewertung durch das Umweltbundesamt) als sicherungs- und sanierungsbeduerftige Altlasten vom Bundesminister in der AltlastenVO ausgewiesen. Die Bewertung der Dringlichkeit von erforderlichen Sanierungsmassnahmen werden mittels drei Prioritätenklassen unterschieden. Eine Einstufung in die Prioritätenklasse 1 bedeutet die höechste Dringlichkeit von Sanierungsmaßnahmen. Nach Bestaetigung des Sanierungserfolges werden die Daten zur Altlast vom Umweltbundesamt aktualisiert und in der AltlastenVO vom Bundesminister als sanierte oder gesicherte Altlast gekennzeichnet.</skos:definition>
    <skos:definition xml:lang="en">Areas pursuant to the Contaminated Sites Remediation Act.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <skos:notation>ALSAG_Gebiete</skos:notation>
    <skos:prefLabel xml:lang="de">Gebiete gemaess Altlastensanierungsgesetz</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Contaminated Site Area</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
