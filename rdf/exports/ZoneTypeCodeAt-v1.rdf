    <skos:prefLabel xml:lang="de">Schwallstrecke</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Hydropeaking</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
