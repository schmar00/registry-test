    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/am"/>
    <skos:definition xml:lang="en">Alpine pasture regions and main Alpine pasture regions of Austria on the basis of political municipalities</skos:definition>
    <skos:definition xml:lang="de">Almregionen und Almhauptregionen Österreichs auf Basis politischer Gemeinden</skos:definition>
