    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/Impoundment">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/am"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/am"/>
    <skos:definition xml:lang="en">Water stretch with anthropogenically caused reductions of average flow velocity in cross sections to less than 0.3 meters per second for medium water level.</skos:definition>
    <skos:definition xml:lang="de">Gewässerstrecke mit anthropogen bedingter Reduktionen der mittleren Fließgeschwindigkeit im Querprofil auf unter 0.3 Meter pro Sekunde bei Mittelwasser (MQ).</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"/>
    <skos:notation>Impoundment</skos:notation>
    <skos:prefLabel xml:lang="de">Staustrecke</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Impoundment</skos:prefLabel>
