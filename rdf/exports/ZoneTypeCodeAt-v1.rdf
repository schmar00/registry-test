  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/Hydropeaking">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:seeAlso xml:lang="en">national-technical</rdfs:seeAlso>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/am"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/am"/>
    <skos:definition xml:lang="en">Water stretch with anthropogenically caused runoff fluctuations and the occurrence of hydropeaking.</skos:definition>
    <skos:definition xml:lang="de">Gewässerstrecke mit anthropogen bedingten Wasserführungsschwankungen mit Schwall-Sunk-Erscheinungen.</skos:definition>
