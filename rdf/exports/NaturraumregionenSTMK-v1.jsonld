      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/tZA",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "On the Styrian side, this is a little-known term for a low mountain range with only a very small Styrian share, which is very typical for the limestone foothills of the Alps and is predominantly made up of Triassic Dolomites. The highest peak of the area, which is clearly bordered by the Mariazeller Pass and the Salzatal (Hall Valley), is the Gr. Sulzberg, 1400 m, in the Styrian part of the Schwarzkogel, 1365 m. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Auf der steirischen Seite wenig gelaeufige Bezeichnung fuer einen in seiner Formenausstattung fuer die Kalkvoralpen sehr typischen, vorherrschend aus Dolomiten der Trias aufgebauten Mittelgebirgsraum mit nur sehr kleinem steirischen Anteil. Hoechster Gipfel des von Mariazeller Paßlandschaft und Salzatal (Halltal) klar umgrenzten Gebietes ist der Gr. Sulzberg, 1400 m, im steirischen Teil der Schwarzkogel, 1365 m. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "tZA"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Tuernitzer Alps"
      },
      {
        "@language": "de",
        "@value": "Tuernitzer Alpen"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
