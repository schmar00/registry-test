        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/oPL",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Recht gut eingebuergerte Bezeichnung fuer die die Wasserscheide zwischen Granitzenbach/Mur und Lavant/Drau tragende Senke zwischen Seetaler Alpen im W und StSteiermarklpe im E, die von tertiaeren, z.T. auch quartaeren Lockermaterialien erfuellt ist und daher recht sanfte Formen aufweist. Die Grenzziehung ist besonders im N und E schwierig. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "en",
        "@value": "Quite well established name for the depression carrying the watershed between Granitzenbach/Mur and Lavant/Drau between Seetaler Alps in the W and StSteiermarklpe in the E, which is filled by tertiary, partly also quaternary loose materials and therefore shows quite gentle forms. The borderline is especially difficult to draw in the N and E. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "oPL"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Obdacher Passlandschaft"
      },
      {
        "@language": "en",
        "@value": "Obdacher pass landscape"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/eEA",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name for the mountain range that borders the Liesing-Paltental furrow in the N, with a predominant high mountain character. Due to the location of the southern border of the Ennstaler Alps, two mountain massifs (Lahngangkogel, 1778 m, and Duerrenschoeberl, 1737 m), topographically isolated from this main ridge, fall in the extreme W. Also in the E, there are two particularly independent deposits, each developed as mighty high mountain massifs of the plateau type, which were also marked as independent subregions: These are the Kaiserschildgruppe (Hochkogel, 2105 m) north of the Radmerhals, which, in contrast to the other Iron Ore Alps belonging to the Paleozoic Greywacke Zone, is geologically part of the Northern Limestone Alps, and the Stock des Reiting (Goeßeck, 2214 m), south of the Hoheneck. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Benennung fuer den die Liesing-Paltental-Furche im N begrenzenden Gebirgszug mit vorherrschendem Hochgebirgscharakter. Bedingt durch die Lage der Suedgrenze der Ennstaler Alpen fallen im aeußersten W zwei topographisch von diesem Hauptkamm isolierte Bergmassive (Lahngangkogel, 1778 m, und Duerrenschoeberl, 1737 m) hinzu. Auch im E gibt es zwei besonders eigenstaendige, jeweils als maechtige Hochgebirgsstoecke vom Plateautypus entwickelte Vorlagerungen, die auch als selbstaendige Teilgebiete gekennzeichnet wurden: Es sind dies die Kaiserschildgruppe (Hochkogel, 2105 m) noerdlich des Radmerhalses, die im Gegensatz zu den uebrigen, der palaeozoischen Grauwackenzone angehoerenden Eisenerzer Alpen geologisch ein Teil der Noerdlichen Kalkalpen ist, und der Stock des Reiting (Goeßeck, 2214 m), suedlich des Hohenecks. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "eEA"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Eisenerzer Alps"
      },
      {
        "@language": "de",
        "@value": "Eisenerzer Alpen"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/gNA",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name for the northeasternmost part of the Styrian mountain range on the right side of the Mur, culminating in the Lenzmoarkogel, 1991 m. The train crossing the forest line on larger areas in its center has predominantly low mountain character and is built up by crystalline rocks (with remarkable frequency of amphibolites). The boundary to the StSteiermarklpe along the depth line Rachaugraben - Stierkreuz - Schrottgraben is problematic; as a sub-area the Hochalpe (more precisely: Brucker Hochalpe) in the NE of the saddle at the Almwirt, 1170 m, can be casually excluded (highest peak Roßeck, 1664 m).  (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerter Name fuer den im Lenzmoarkogel, 1991 m, kulminierenden nordoestlichsten Teil des Steirischen Randgebirges rechts der Mur. Der auf groeßeren Flaechen in seinem Zentrum die Waldgrenze ueberschreitende Zug hat vorherrschend Mittelgebirgscharakter und wird von kristallinen Gesteinen (mit bemerkenswerter Haeufigkeit von Amphiboliten) aufgebaut. Die Begrenzung zur StSteiermarklpe entlang der Tiefenlinie Rachaugraben - Stierkreuz - Schrottgraben ist problematisch; als Teilgebiet kann zwanglos die Hochalpe (genauer: Brucker Hochalpe) im NE des Sattels beim Almwirt, 1170 m, ausgesondert werden (hoechster Gipfel Roßeck, 1664 m).  (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "gNA"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Gleinalpe"
      },
      {
        "@language": "de",
        "@value": "Gleinalpe"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/wSB",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Recht gut eingebuergerter Name fuer den auffallend lebhaft reliefierten Teil des Vorlandes zwischen Poeßnitzfurche im S, Saggautal im W, Sulmtal im N sowie Leibnitzer Feld und Unterem Murtal im NE. Das vorherrschend aus tertiaeren Lockergesteinen aufgebaute Huegelland kulminiert im Kreuzberg, 633 m, und setzt sich unter kontinuierlicher Abnahme der relativen und absoluten Hoehen in Richtung SE nach Slowenien fort (Slovenske Gorice). (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "en",
        "@value": "Quite well established name for the remarkably lively relieved part of the foreland between Poeßnitzfurche in the S, Saggautal in the W, Sulmtal in the N as well as Leibnitzer Feld and Unteres Murtal in the NE. The hilly area, predominantly built up of Tertiary loose rocks, culminates in the Kreuzberg, 633 m, and continues with a continuous decrease of relative and absolute heights in the direction of SE to Slovenia (Slovenske Gorice). (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "wSB"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Windische Buehel"
      },
      {
        "@language": "de",
        "@value": "Windische Buehel"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
