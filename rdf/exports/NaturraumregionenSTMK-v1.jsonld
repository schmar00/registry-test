  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/lZF",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well established name for the Mur valley between the narrowness of Wildon in the N and the change of direction of the river to an approaching W-E course in the S (there blurred border, see Lower Mur valley). There is a spacious valley area consisting of fluvial and fluvioglacial sediments, which are highly significant as groundwater reservoirs. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung fuer das Murtal zwischen der Enge von Wildon im N und dem Richtungswechsel des Flusses auf annaeherenden W-E-Verlauf im S (dort unscharfe Grenze, siehe Unteres Murtal). Es liegt ein geraeumiger Talraum vor, der aus fluvialen und fluvioglazialen Sedimenten besteht, die eine hohe Bedeutung als Grundwasserspeicher aufweisen. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "lZF"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Leibnitzer Feld"
      },
      {
        "@language": "de",
        "@value": "Leibnitzer Feld"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
