      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/gZF",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name for the Mur valley between its exit from the Alps in Weinzoedl on the northern outskirts of Graz and the narrow of Wildon in S. The Graz field is a spacious valley area consisting of fluvial and fluvioglacial sediments, which are important as groundwater reservoirs. The northern part of this area is completely occupied by the city of Graz, its boundaries in the E and W show characteristic asymmetries. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung fuer das Murtal zwischen dessen Austritt aus den Alpen in Weinzoedl am noerdlichen Stadtrand von Graz und der Enge von Wildon im S. Das Grazer Feld ist ein geraeumiger Talraum, der aus fluvialen und fluvioglazialen Sedimenten besteht, die als Grundwasserspeicher bedeutend sind. Der Nordteil dieses Gebietes wird zur Gaenze von der Stadt Graz eingenommen, seine Begrenzungen im E und W weisen zueinander charakteristische Asymmetrien auf. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "gZF"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Grazer Feld"
      },
      {
        "@language": "de",
        "@value": "Grazer Feld"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
