  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/rBT",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name, which is used here only for the non-alpine part of the river valley (the inner alpine part belongs to the Graz mountains and the Passail basin). The valley has the character of a spacious sole valley of fluvial and fluvioperiglacial sediments, with remarkably little variation in width. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerter Name, der hier nur fuer den ausseralpinen Teil des Flusstales Verwendung findet (der inneralpine gehoert dem Grazer Bergland und dem Passailer Becken an). Das Tal hat den Charakter eines geraeumigen, in seiner Breite auffallend wenig variierenden Sohlentales aus fluvialen und fluvioperiglazialen Sedimenten. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "rBT"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Raabtal"
      },
      {
        "@language": "de",
        "@value": "Raabtal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
