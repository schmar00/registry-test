      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/sTA",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name for the isolated NNW-SSE, which rises between distinct depth contours and culminates in the Zirbitzkogel, 2396 m, with a clearly pronounced high mountain character. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung fuer den isoliert zwischen ausgepraegten Tiefenlinien aufragenden, NNW-SSE streichenden, im Zirbitzkogel, 2396 m, kulminierenden Kristallinzug mit deutlich ausgepraegtem Hochgebirgscharakter. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "sTA"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Seetaler Alps"
      },
      {
        "@language": "de",
        "@value": "Seetaler Alpen"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/oGB",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name for the low mountain range on both sides of the Mur in the N of Graz, which is mainly composed of weakly metamorphic rocks of the Palaeozoic. It is a morphologically very diversely structured area, whereby the rock stock with tendentially gentler forms in silicate and steeper forms in carbonate rocks (hint of high mountain character in the area of the highest peak, the Hochlantsch, 1720 m) plays a major role in the differentiation of the landscape. The boundary is complicated in the W and S in its course, a clear subdivision results from the Mur valley in a western and an eastern part. The assignment to the Styrian border mountains can be criticized from a geological point of view.  (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung fuer das ueberwiegend aus schwach metamorphen Gesteinen des Palaeozoikums aufgebaute Mittelgebirge beiderseits der Mur im N von Graz. Es handelt sich um ein morphologisch sehr vielfaeltig strukturiertes Gebiet, wobei der Gesteinsbestand mit tendenziell sanfteren Formen in Silikat- und steileren Formen in Karbonatgesteinen (Andeutung von Hochgebirgscharakter im Bereich des hoechsten Gipfels, des Hochlantsch, 1720 m) eine große Rolle bei der Differenzierung des Landschaftsbildes spielt. Die Begrenzung ist im W und S in ihrem Verlauf kompliziert, eine klare Untergliederung ergibt sich durch das Murtal in einen westlichen und einen oestlichen Teil. Die Zuordnung zum Steirischen Randgebirge kann aus geologischer Sicht kritisiert werden.  (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "oGB"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "oestliches Grazer Bergland"
      },
      {
        "@language": "en",
        "@value": "eastern Graz Highlands"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/pTT",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name for the valley, which is largely filled with fluvial sediments and forms a continuous longitudinal valley line over the Schoberpass, 849 m, together with the Liesing valley. In contrast to the Liesing valley, the valley width in the Paltental is constantly high and the shapes are more uniform, with an alternation of flat valley bottoms and lateral alluvial and debris-flow cones, which is related to its configuration by a side arm of the Pleistocene Enns glacier. The valley area is separated from the Middle Enns Valley by the narrowness near Selzthal. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung fuer das weithin von fluvialen Sedimenten erfuellte Tal, das ueber den Schoberpass, 849 m, hinweg mit dem Liesingtal eine durchgehende Laengstalflucht bildet, fuer die frueher auch der gemeinsame Name Kammertal verwendet wurde. Im Gegensatz zum Liesingtal ist im Paltental die Talbreite konstant hoch und die Formenausstattung mit einem Wechsel von flachen Talbodenstuecken und seitlichen Schwemm- und Murenkegeln einheitlicher, was mit seiner Ausgestaltung durch einen Seitenarm des pleistozaenen Ennsgletschers zusammenhaengt. Der Talraum ist vom Mittleren Ennstal durch die Enge bei Selzthal getrennt. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "pTT"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Paltental"
      },
      {
        "@language": "de",
        "@value": "Paltental"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
