  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/pLT",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name, which is applied in the present structure, however, only to the sufficiently broadly developed valley section below Moederbrugg (also name Unteres Poelstal possible). Here, the valley open to the Judenburg-Knittelfeld Basin is occupied by fluvial and fluvioglacial sediments (marginal position to the Wuerm Age debris-flow glacier). (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung, die in der vorliegenden Gliederung jedoch nur auf den genuegend breit entwickelten Talabschnitt unterhalb von Moederbrugg angewandt wird (auch Bezeichnung Unteres Poelstal moeglich). Hier wird das zum Judenburg-Knittelfelder Becken offene Tal von fluvialen und fluvioglazialen Sedimenten (Randposition zum wuermzeitlichen Murgletscher) eingenommen. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "pLT"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Poelstal"
      },
      {
        "@language": "de",
        "@value": "Poelstal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
