  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/bWW",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well established and the landscape character quite well descriptive designation for a mountainous country, which is located to the far predominant part on Lower Austrian territory. The Styrian part in the area around Schaeffern consists of crystalline rocks and tertiary boulder gravel, its limitation against the change along the Diving and Spitalbach is more of an embarrassment solution in the style of Mang 1984, because the compact massif of the change changes very gradually merges into the confusing mountainous area of the Bucklige Welt. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte und den Landschaftscharakter recht gut beschreibende Bezeichnung fuer ein zum weitaus ueberwiegenden Teil auf niederoesterreichischem Gebiet gelegenes Bergland. Der steirische Anteil im Gebiet um Schaeffern besteht aus kristallinen Gesteinen und tertiaeren Blockschottern, seine Begrenzung gegen den Wechsel entlang des Tauchen- und Spitalbaches ist mehr eine Verlegenheitsloesung in Anlehnung an Mang 1984, weil das kompakte Massiv des Wechsels ganz allmaehlich in das unuebersichtliche Bergland der Buckligen Welt uebergeht. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "bWW"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Bucklige Welt"
      },
      {
        "@language": "de",
        "@value": "Bucklige Welt"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
