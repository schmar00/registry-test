        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/kNT",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name, which in this context is only used for the non-alpine, lower part of the river valley (possibly also to be called Lower Kainach Valley). It is a wide valley area built up of fluvial and fluvioperiglacial sediments. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerter Name, der in diesem Rahmen nur fuer den ausseralpinen, unteren Teil des Flusstales verwendet wird (eventuell auch als Unteres Kainachtal zu bezeichnen). Es handelt sich um einen breiten, aus fluvialen und fluvioperiglazialen Sedimenten aufgebauten Talraum. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "kNT"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Kainachtal"
      },
      {
        "@language": "de",
        "@value": "Kainachtal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/pSR",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name for the spur of the peripheral mountain range, the greater part of which belongs to Slovenia (Kozjak). The morphologically quite uniform low mountain range shows great geological diversity, as elements of the Styrian peripheral mountains, the Graz highlands and the foothills are involved in its construction. It is the latter in particular that build up the highest elevation, the Klementkogel (Kapunerkogel), 1052 m. The northern boundary follows in the W the slope bend, which protrudes well in the world of forms, between the Riedeln (Western Styrian Riedelland), which slope off to the Saggautal, and the actual comb area of the Poßruck, in the E however, where there is only a weakly pronounced morphological contrast to the Windische Bueheln, the depth line of the two Poeßnitz brooks.  (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerter Name fuer den das weststeirische Vorland im S begrenzenden Sporn des Randgebirges, dessen groeßerer Teil zu Slowenien gehoert (Kozjak). Der morphologisch recht einheitliche Mittelgebirgszug zeigt große geologische Vielfalt, sind doch Elemente des Steirischen Randgebirges, des Grazer Berglandes und des Vorlandes an seinem Bau beteiligt. Gerade die letztgenannten bauen auch die hoechste Erhebung, den Klementkogel (Kapunerkogel), 1052 m, auf. Die Nordbegrenzung folgt im W dem in der Formenwelt gut hervortretenden Hangknick zwischen den zum Saggautal abdachenden Riedeln (Weststeirisches Riedelland) und dem eigentlichen Kammbereich des Poßruck, im E hingegen, wo zu den Windischen Bueheln ein nur schwach ausgepraegter morphologischer Gegensatz besteht, der Tiefenlinie der beiden Poeßnitzbaeche.  (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "pSR"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Possruck"
      },
      {
        "@language": "de",
        "@value": "Possruck"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
