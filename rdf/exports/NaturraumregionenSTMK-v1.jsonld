        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/lZT",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name, which is used here only for the non-alpine part of the river valley from Deutschlandsberg downwards (the upper one is an almost uninhabited, canyon-like mountain valley). It is a wide valley area built up from fluvial and fluvioperiglacial sediments. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerter Name, der hier nur fuer den ausseralpinen Teil des Flusstales von Deutschlandsberg abwaerts verwendet wird (der obere ist ein fast unbesiedeltes, schluchtartiges Gebirgstal). Es handelt sich um einen breiten, aus fluvialen und fluvioperiglazialen Sedimenten aufgebauten Talraum. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "lZT"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Lassnitztal"
      },
      {
        "@language": "de",
        "@value": "Lassnitztal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/wSR",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Recht gut eingebuergerte Bezeichnung fuer das aus tertiaeren Lockergesteinen aufgebaute Riedelland westlich der Mur, das durch die breiten Taeler von Sulm, Lassnitz und Kainach in 4 voneinander getrennte, physiognomisch jedoch sehr aehnliche Teile gegliedert wird. Die Begrenzung zum Steirischen Randgebirge ist haeufig als scharfer Hangknick entwickelt und dadurch eindeutig festzulegen, allein zum Voitsberger und Gratkorner Becken sowie zum Grazer Bergland herrschen fließende uebergaenge und lassen bei der Grenzziehung einen relativ hohen subjektiven Spielraum. Am Rande des Grazer Feldes wurden der Kaiserwald (altpleistozaene Schotterplatte) und am Rande des Leibnitzer Feldes der Wildoner Berg (kleines, verkarstetes Plateaubergland aus tertiaerem Leithakalk, im Buchkogel 550 m hoch) als gut abgrenzbare Teilraeume gekennzeichnet. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "en",
        "@value": "Quite well established name for the reedland west of the Mur, which is built up from tertiary loose rocks and is divided by the wide valleys of Sulm, Lassnitz and Kainach into 4 separate, physiognomically however very similar parts. The boundary to the Styrian mountain range is often developed as a sharp bend in the slope and is therefore clearly defined. Only to the Voitsberger and Gratkorner basins and to the Graz mountain range there are flowing transitions and leave a relatively high subjective leeway in the drawing of the boundary. At the edge of the Graz field, the Kaiserwald (Old Pleistocene gravel plate) and at the edge of the Leibnitz field, the Wildoner Berg (small, karstified plateau overburden of tertiary Leithakalk, 550 m high in the Buchkogel) have been identified as clearly delimitable subspaces. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "wSR"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Weststeirisches Riedelland"
      },
      {
        "@language": "en",
        "@value": "west styrian Riedelland"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/wSL",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well established name for the mighty, compact low mountain ridge at the eastern end of the Styrian Randgebirge. It consists of crystalline rocks and towers above the current timberline in its summit area (Hochwechsel, 1743 m). The border is very blurred towards S to Joglland and towards E to Bucklige Welt.  (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung fuer den maechtigen, kompakten Mittelgebirgsruecken am Ostende des Steirischen Randgebirges. Er besteht aus kristallinen Gesteinen und ueberragt in seinem Gipfelbereich (Hochwechsel, 1743 m) die aktuelle Waldgrenze. Die Begrenzung ist nach S zum Joglland und nach E zur Buckligen Welt sehr unscharf.  (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "wSL"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Wechsel"
      },
      {
        "@language": "de",
        "@value": "Wechsel"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/oSR",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Recht gut eingebuergerte Bezeichnung fuer das aus tertiaeren Lockergesteinen aufgebaute Riedelland oestlich der Mur, das durch die breiten Taeler von Raab, Feistritz und Lafnitz (sowie einiger weiterer, in der vorliegenden Gliederung unberuecksichtigter Baeche) in 3 voneinander getrennte, physiognomisch jedoch sehr aehnliche Teile gegliedert wird. Die Grenze zum Gebirge ist lokal unterschiedlich scharf ausgebildet, am undeutlichsten im SW von Weiz und in der Poellauer Bucht. Im Zwickel zwischen Lafnitz und Feistritz sowie am Nordrand des Unteren Murtales werden groeßere Areale von altpleistozaenen Platten eingenommen, und lokal treten im SE des Gebietes aus dem Riedelland kleine, aus vulkanischen Gesteinen des Tertiaers aufgebaute Berglaender bzw. Erhebungen hervor. Von diesen wurden die drei groeßten als Teilgebiete hervorgehoben (Stradner Kogel, 609 m, Gleichenberger Koegel, 598 m, und Kloecher Massiv, 462 m), wozu jedoch bemerkt werden muß, dass sie sich nur schlecht abgrenzen lassen. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "en",
        "@value": "Rather well established name for the reedlands east of the Mur, built up from tertiary loose rocks, which are divided by the wide valleys of Raab, Feistritz and Lafnitz (as well as some further brooks not considered in the present classification) into 3 separate, physiognomically however very similar parts. The border to the mountains is locally differently sharply formed, most indistinctly in the SW of Weiz and in the Poellauer Bucht. In the gusset between Lafnitz and Feistritz as well as at the northern edge of the Lower Mur valley, larger areas are occupied by Old Pleistocene plates, and locally, in the SE of the area, small mountain lands or elevations, built up from volcanic rocks of the Tertiary, emerge from the reedlands. Of these, the three largest have been highlighted as sub-areas (Stradner Kogel, 609 m, Gleichenberger Koegel, 598 m, and Kloecher Massiv, 462 m), although it must be noted that they are difficult to delimit. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "oSR"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Oststeirisches Riedelland"
      },
      {
        "@language": "en",
        "@value": "east styrian Riedelland"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
