      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/oET",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Recht gut eingebuergerte Bezeichnung fuer das steirische Ennstal oberhalb des Grimming. Der im Vergleich zum mittleren Ennstal, zu dem keine scharfe Grenze existiert, nur schmal entwickelte Talraum wird vor allem von Schwemm- und Murenkegeln der Seitenbaeche gepraegt. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "en",
        "@value": "Quite well established name for the Styrian Ennstal above Grimming. Compared to the central Enns valley, with which there is no sharp border, the valley area is only narrowly developed and is mainly characterized by alluvial cones and debris flows from the side streams. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "oET"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Upper Ennstal"
      },
      {
        "@language": "de",
        "@value": "Oberes Ennstal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
