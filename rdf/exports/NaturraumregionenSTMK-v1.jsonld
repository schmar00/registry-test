      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/lST",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well-established name for the valley filled with fluvial and fluvioglacial sediments, which, together with the Paltental, forms a continuous longitudinal valley line over the Schoberpass, 849 m, for which the common name Kammertal was also used in former times. In contrast to the Paltental, the width of the Liesingtal valley varies considerably in the local area (e.g. a striking narrowing with a mighty mudflow cone between Mautern and Kammern). (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung fuer das von fluvialen und fluvioglazialen Sedimenten erfuellte Tal, das ueber den Schoberpass, 849 m, hinweg mit dem Paltental eine durchgehende Laengstalflucht bildet, fuer die frueher auch der gemeinsame Name Kammertal verwendet wurde. Im Gegensatz zum Paltental wechselt im Liesingtal die Talbreite geologisch bedingt lokal stark (z.B. markante Verengung mit maechtigem Murenkegel zwischen Mautern und Kammern). (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "lST"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Liesingtal"
      },
      {
        "@language": "de",
        "@value": "Liesingtal"
      }
    ],
