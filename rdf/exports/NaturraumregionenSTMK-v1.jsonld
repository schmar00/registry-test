  {
    "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK/sSL",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/br"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/br"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Well established name for a small low mountain range consisting mainly of weakly metamorphic slates of the Graz Palaeozoic with great cultural and natural landscape independence (Demmerkogel, 671 m) between Lassnitz valley in the N, Leibnitz field in the E, Sulm valley in the S and the depth line St. Andrae/Sausal - Weniggleinz - Waldschacher ponds in the W. With this bordering, which is oriented on practicability, larger portions of the tertiary riedland fall in the N and W to the Sausal, conversely the slate foothills reaching out over the Sulm to S remain excluded. (Author: Prof. Mag. Dr. Gerhard Karl LIEB)"
      },
      {
        "@language": "de",
        "@value": "Gut eingebuergerte Bezeichnung fuer ein ueberwiegend aus schwach metamorphen Schiefern des Grazer Palaeozoikums bestehendes kleines Mittelgebirge mit großer kultur- und naturlandschaftlicher Eigenstaendigkeit (Demmerkogel, 671 m) zwischen Lassnitztal im N, Leibnitzer Feld im E, Sulmtal im S und der Tiefenlinie St.Andrae/Sausal - Weniggleinz - Waldschacher Teiche im W. Mit dieser auf Praktikabilitaet ausgerichteten Umgrenzung fallen im N und W groeßere Anteile des Tertiaerriedellandes zum Sausal, umgekehrt bleiben die ueber die Sulm nach S ausgreifenden Schieferauslaeufer ausgeklammert. (Verfasser: Prof. Mag. Dr. Gerhard Karl LIEB)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "sSL"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "Sausal"
      },
      {
        "@language": "de",
        "@value": "Sausal"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/NaturraumregionenSTMK"
      }
    ],
