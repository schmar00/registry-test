      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Invntory of Wetlands in Austria; total area of wetlands assessd in Nov. 2008 ammounts to 2744 km2 divided into 889 wetland objects"
      },
      {
        "@language": "de",
        "@value": "Abgrenzung der Feuchtgebiete gemäß Feuchtgebietsinventar, Abgrenzung generalisiert; Insgesamt umfasst das Feuchtgebietsinventar Österreich im November 2008 insgesamt 889 Feuchtgebiete. Die Gesamtfläche der beschriebenen Gebiete beträgt mehr als 2744.0 km2. Das Inventar wird laufend durch Expertenmeldungen laufend erweitert."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe"
