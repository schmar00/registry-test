    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "These are risk areas where flood protection systems are in operation. When a flood event exceeds the degree of protection or a technical fault occurs, the flood protection system does not function, flooding occurs to a degree similar to the absence of the flood protection system. New buildings are to be built flood-proof in this area."
      },
      {
        "@language": "de",
        "@value": "Hierbei handelt es sich um Restrisikogebiete im Wirkungsbereich von Hochwasserschutzanlagen. Wenn ein Hochwasserereignis das Bemessungsereignis übersteigt bzw. in Folge eines technischen Gebrechens die Hochwasserschutzanlage nicht funktioniert, kommt es im Wirkungsbereich der Hochwasserschutzanlage zu Überflutungen in einem Ausmaß ähnlich wie bei Nichtvorhandensein der Hochwasserschutzanlage. Neubauten sind in diesem Bereich hochwassergeschützt zu errichten."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "formerRedZone"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "former red zone"
      },
      {
        "@language": "de",
        "@value": "ehemals Rote Zone"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
