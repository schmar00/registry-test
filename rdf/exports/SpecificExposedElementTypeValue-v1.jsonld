  {
    "@id": "https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/formerRedZone",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/nz-core"
      }
    ],
