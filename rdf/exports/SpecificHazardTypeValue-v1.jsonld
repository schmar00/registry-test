  {
    "@id": "https://registry.inspire.gv.at/codelist/SpecificHazardTypeValue/massWasting",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
