    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@language": "en",
        "@value": "national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "the dislodgement and downslope transport of soil and rock material under the direct application of gravitational body stresses. In contrast to other erosion processes, the debris removed by mass wasting is not carried within, on, or under another medium. The mass properties of the material being transported depend on the interaction of the soil and rock particles and on the moisture content."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
