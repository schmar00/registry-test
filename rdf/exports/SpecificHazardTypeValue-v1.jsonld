        "@value": "national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/SpecificHazardTypeValue/wind"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Dust devils are occasionally strong enough to cause minor damage (up to EF0 on the Enhanced Fujita scale). Diameters range from about 3 m to greater than 30 m; their average height is about 200 m, but a few have been observed as high as 1 km or more. They have been observed to rotate anticyclonically as well as cyclonically. Although the vertical velocity is predominantly upward, the flow along the axis of large dust devils may be downward. Large dust devils may also contain secondary vortices. Dust devils are best developed on a hot, calm afternoon with clear skies, in a dry region when intense surface heating causes a very steep lapse rate of temperature in the lowest 100 m of the atmosphere."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/SpecificHazardTypeValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "dustDevil"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "dust devil"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
