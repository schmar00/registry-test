<https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP:1> {
    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP/BlaueFunktionsbereiche> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:description "Def. UBA"@de,
            "Def. UBA"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Flächen, die für die Durchführung sowie für die Aufrechterhaltung der Funktionen geplanter schutzwasserwirtschaftlicher Maßnahmen benötigt werden."@de,
            "not available"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        skos:notation "BlaueFunktionsbereiche" ;
        skos:prefLabel "Blaue Funktionsbereiche"@de,
            "Blaue Funktionsbereiche"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP/GelbeGefahrenzonen> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:description "Def. UBA"@de,
            "Def. UBA"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Alle übrigen durch das Bemessungsereignis mittlerer Wahrscheinlichkeit betroffenen Überflutungsflächen. In diesen Flächen können unterschiedliche Gefährdungen geringeren Ausmaßes oder Beeinträchtigungen der Nutzung für Siedlungs- und Verkehrszwecke auftreten oder sind Beschädigungen von Bauobjekten und Verkehrsanlagen möglich."@de,
            "not available"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        skos:notation "GelbeGefahrenzonen" ;
        skos:prefLabel "Gelbe Gefahrenzonen"@de,
            "Gelbe Gefahrenzonen"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP/Restrisikogebiete> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:description "Def. UBA"@de,
            "Def. UBA"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Zonen mit Gefährdung niedriger Wahrscheinlichkeit (Restrisikogebiete') basieren auf dem Hochwasser niedriger Wahrscheinlichkeit (HQ300 oder Extremereignisse) und weisen auf die Restgefährdung beispielsweise bei Überschreiten des Schutzgrades bzw. erhöhte Schadenswirkung bei Versagen von Schutzmaßnahmen hin."@de,
            "not available"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        skos:notation "Restrisikogebiete" ;
        skos:prefLabel "Restrisikogebiete"@de,
            "Restrisikogebiete"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP/RotGelbSchraffierteFunktionsbereiche> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:description "Def. UBA"@de,
            "Def. UBA"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Überflutungsflächen, die wesentlich zum Hochwasserabfluss beitragen und deren Abflusswirkung dazu beiträgt, im durch den funktionierenden Hochwasserabfluss entlasteten Gebiet das Gefährdungspotenzial zu verringern oder bei denen im Falle von abflussbeeinträchtigenden Maßnahmen negative Auswirkungen auf das Abflussverhalten des Gewässers zu erwarten sind, welche das Schadenspotenzial erhöhen könnten."@de,
            "not available"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        skos:notation "RotGelbSchraffierteFunktionsbereiche" ;
        skos:prefLabel "Rot-gelb schraffierte Funktionsbereiche"@de,
            "Rot-gelb schraffierte Funktionsbereiche"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP/RoteGefahrenzonen> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz> ;
        dcterms:description "Def. UBA"@de,
            "Def. UBA"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        skos:definition "Flächen, die durch das Bemessungsereignis mittlerer Wahrscheinlichkeit derart gefährdet sind, dass ihre ständige Benützung für Siedlungs- und Verkehrszwecke wegen der voraussichtlichen Schadenswirkungen nicht oder nur mit unverhältnismäßig hohem Aufwand möglich ist (Gefahr für Leib und Leben)."@de,
            "not available"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        skos:notation "RoteGefahrenzonen" ;
        skos:prefLabel "Rote Gefahrenzonen"@de,
            "Rote Gefahrenzonen"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeGZP> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

