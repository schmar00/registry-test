  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/hazardtype/pyroclasticFlow">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/nz"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/volcanicActivity"/>
    <skos:definition xml:lang="en">Extremely hot gases, ash, and other materials of more than 1.000 degrees Celsius that rapidly flow down the flank of a volcano (more than 700 km/h) during an eruption.</skos:definition>
    <skos:definition xml:lang="en">Extremely hot gases, ash, and other mat eri als of more than 1, 000 degrees Celsius that rapidly flow down the flank of a volc ano (more than 700 km/h) during an eruption.</skos:definition>
    <skos:notation>pyroclasticFlow</skos:notation>
    <skos:prefLabel xml:lang="en">pyroclastic flow</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
