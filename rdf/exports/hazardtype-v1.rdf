    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/infestation"/>
    <skos:definition xml:lang="en">The pervasive influx, swarming and/or hatching of insects affecting humans, animals, crops, and perishable goods. Examples are locusts and African Bees.</skos:definition>
    <skos:definition xml:lang="en">The pervasive influx, swarming and or hatching of insects affecting humans, animals, crops, and perishable goods. Examples are locusts and African Bees.</skos:definition>
