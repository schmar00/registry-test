  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/hazardtype/mediumSeatedTiltingAndDrifting">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/nz"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/mediumSeated"/>
    <skos:definition xml:lang="en">Medium seated, from 2 m up to 50 m in depth, slow or moderate motion slope deformation of bed- or surface rocks with rotational gliding and drifting processes affects an area bigger than 10 square meter up to 1 square kilometer as well as a volume in a range between 10 to 10.000 cubic meter.</skos:definition>
    <skos:notation>mediumSeatedTiltingAndDrifting</skos:notation>
    <skos:prefLabel xml:lang="en">medium seated tilting and drifting</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/hazardtype/infestation">
