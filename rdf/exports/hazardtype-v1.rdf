  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/hazardtype/disease">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/nz"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/nz"/>
    <skos:broader rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/epidemic"/>
    <skos:definition xml:lang="en">Either an unusual, often sudden, increase in the number of incidents of an infectious disease that already existed in the region (e.g., flu, E.coli) or the appearance of an infectious disease previously absent from the region, e.g., plague, polio.</skos:definition>
    <skos:definition xml:lang="en">Either an unusual, often sudden, increase in the number of incidents of an infectious disease that already existed in the region (e.g., flu, E.coli) or the appearance of an infectious disease previously absent from the region (e.g., plague, polio).</skos:definition>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/viralDisease"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/prionDisease"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/parasiticDisease"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/fungalDisease"/>
    <skos:narrower rdf:resource="https://registry.inspire.gv.at/codelist/hazardtype/bacterialDisease"/>
    <skos:notation>disease</skos:notation>
    <skos:prefLabel xml:lang="en">disease</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
