    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/forestInventoryTypeValue/forestry"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Wald mit Nutzfunktion fuer wirtschaftliche und nachhaltige Hervorbringung des Rohstoffes Holz."
      },
      {
        "@language": "en",
        "@value": "Forest with productive function for economic and sustainable production of the raw material 'wood”."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/forestInventoryTypeValue"
