      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Wald in unterrepraesentativer Auspraegung (z.B. Gebiete mit intensiver landwirtschaftlicher Nutzung, Gletscher oder Seen)."
      },
      {
        "@language": "en",
        "@value": "Area is almost entirely non-forest (e.g. areas of intensive agricultural use, glaciers or lakes)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/forestInventoryTypeValue"
      }
