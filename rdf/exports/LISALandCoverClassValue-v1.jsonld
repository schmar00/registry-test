  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_3_PermanentBareSoil",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "de",
        "@value": "identisch mit EAGLE-Klasse: 1223_BareSoils - Da diese Klasse - wie die anderen - noch rein auf spektrale Merkmalen basiert, deckt sie eine sehr breite Nutzungspalette ab. Meist kommt diese Klasse im landwirtschaftlichen Bereich vor, es handelt sich dabei um Böden ohne Vegetationsbedeckung, aber mit reichlichem Humusgehalt (=Erde). Je geringer der Humusgehalt, desto mehr geht die Klasse offener Boden in die Klasse 'Schotter/Sand' über. Die Abgrenzung zum Grünbewuchs erfolgt über den Vegetationsindex (Einteilung in: keine, wenig, mittel und hoch siehe 'Grünbewuchs)). Der Vegetationsanteil beträgt maximal 10%. - Die im Gemüsebau manchmal anzutreffende temporäre Abdeckung von Äckern bzw. Ackerstreifen mittels schwarzen und weißen Folien soll als 'offener Boden' klassifiziert werden."
      },
      {
        "@language": "en",
        "@value": "identical to EAGLE class: 1223_BareSoils"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Nicht vegetationsbedeckter, offener Boden."
      },
      {
        "@language": "en",
        "@value": "Mixture of mineral and organic material that is capable of sustaining plant life, but being unvegetated at the moment of observation (primarily bare arable land)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "1_2_3_PermanentBareSoil"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "permanent bare soil"
      },
      {
        "@language": "de",
        "@value": "offener Boden (dauerhaft)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
