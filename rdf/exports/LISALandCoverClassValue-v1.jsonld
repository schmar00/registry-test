[
  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_11_DwarfShrubs",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "de",
        "@value": "identisch mit EAGLE-Klasse: 2122_DwarfShrubs - Da großflächige Zwergstrauchbestände nur in der (sub)alpinen Zone auftreten können diese durchaus mit einer gröberen räumlichen Auflösung erfaßt werden."
      },
      {
        "@language": "en",
        "@value": "identical to EAGLE class: 2122_DwarfShrubs"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "woody plants with a height between 0,2 and 0,5m."
      },
      {
        "@language": "de",
        "@value": "Flächige Bestände von v.a. Alpenrose und anderen Zwergsträuchern (Schwarzbeere, Preiselbeere, Rauschbeere). Zwergsträucher sind zwischen 10 cm und 40 cm hoch, wintergrün und meist als Sukzessionsstadien nach der Aufgabe von Almweide zu finden. Sie können mit Almweideflächen in enger Verzahnung auftreten."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "2_4_11_DwarfShrubs"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Zwergstrauch"
      },
      {
        "@language": "en",
        "@value": "dwarf shrubs"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_2_OtherConstructedArea",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "de",
        "@value": "identisch mit EAGLE-Klasse: 1112_OtherConstructions - Beinhaltet befestigte Straßen, Gehsteige, Parkplätze und sonstige befestigte Flächen, wie z.B. Tennisplätze, Sportlaufbahnen etc. Auch befestigte Baunebenflächen und Manipulationsflächen in Gewerbe- und Industrie fallen darunter. Ebenso in diese Kategorie fallen die dauerhaft angelegten landwirtschaftlichen Güterwege und Zu- und Abfahrten zu Industrie- und Gewerbegebieten sowie Lagerplätzen. - Plätze in Anlagen mit permanenter Nutzung sind in der Regel als befestigt anzusehen (Kompostanlagen, Industrielager, LKW-Abstellplätze etc.). Vorübergehend zur Lagerung benutzte Flächen sind in der Regel nicht durch Aufbringung von Fremdmaterial charakterisiert, aber die menschliche Intention ist klar erkennbar, der Oberboden angeschoben und das Erdreich verdichtet (Holzlager, Materialdepots von Baustellen etc.). - Abgrenzung: Bei der Klasse Schotter/Sand handelt es sich hingegen um natürliche Prozesse."
      },
      {
        "@language": "en",
        "@value": "identical to EAGLE class: 1112_OtherConstructions - Includes: e.g. asphalt, concrete, pave dings like on roads, parking lots, squares, storages areas, airport run ways, quays, sealed bottom pools, unvegetated cemeteries. - Excludes: gravel bed of railway track. It is an artificial surface but not impervious, better to be placed under Gravel, Pebble"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Künstlich angelegte, ganz oder teilweise versiegelte Flächen, insbesondere asphaltierte, betonierte, bekieste, geschotterte, gemergelte sowie mit Steinen oder Platten belegte Böden (© Schweizer Arealstatistik)."
      },
      {
        "@language": "en",
        "@value": "Flat surfaces covered by any type of impervious material which that is used for artificial surface pavements (e.g. asphalt, concrete, tarmacadam)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "1_1_2_OtherConstructedArea"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "sonstige befestigte Fläche"
      },
      {
        "@language": "en",
        "@value": "other constructed area"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
