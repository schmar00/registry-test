  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "identical to EAGLE class: 22_Herbaceous"
      },
      {
        "@language": "de",
        "@value": "identisch mit EAGLE-Klasse: 22_Herbaceous - Abgrenzung von benachbarten Objekten gleicher Klassenzugehörigkeit: Insbesondere in der Klasse Grünbewuchs ist es wichtig - ähnlich wie in der Klasse offener Boden jene Objekte zu erfassen, die eine geschlossene räumliche Einheit bilden. Grünbewuchsflächen können aneinander angrenzen und trotzdem werden sie räumlich differenziert, da sie sich - Auch sämtliche Ackerflächen, die eine luftbildsichtbare Vegetation aufweisen fallen in diese Kategorie (Weizen, Mais, Erdäpfel, etc.). Die Grünflächen enthalten somit alle vegetationsbedeckten aber nicht bestockten Flächen. Darunter fallen sowohl natürliche Wiesen, Wirtschaftsgrünland, Parkanlagen, Rasenflächen in Hausgärten, Grünbegleitstreifen etc."
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Sämtliche mit sichtbarer niedriger Vegetation (Gras oder Krautvegetation) bedeckte Flächen. Die innere Differenzierung des Grünbewuchse ('einzelne Schläge als getrennte Segmente' - Landschaftsstruktur) ist dabei mitzuerfassen. Der Deckungsgrad durch oberirdische Pflanzenteile muß mindestens 10% innerhalb der Referenzfläche einnehmen."
      },
      {
        "@language": "en",
        "@value": "This large class contains all kind of arable crops, pastures, meadows and natural grasslands. As for bare soil it is in the context of agricultural use not essential to assign the object the correct class, as the class of an object is a rather random issue depending on the acquisition date. However it is important to differentiate objects of the same class, if they are located next to each other, and if they can differentiate according to their vegetation index and physiognomic appearance."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_2_HerbaceousPeriodically"
      },
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_1_HerbaceousPermanent"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "2_5_12_Herbaceous"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Grünbewuchs"
      },
      {
        "@language": "en",
        "@value": "herbaceous"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_1_Building",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "de",
        "@value": "identisch mit EAGLE-Klasse: 1111_Buildings - Diese Klasse beinhaltet Gebäude und Gebäudekomplexe. Gebäude sind aus Sicht der Raumplanung ab einer Größe von 50 m² zu erfassen, da diese Größe die minimale Fläche eines Gebäudes ist, welches als Hauptgebäude (ganzjährige Wohnung und/oder betriebliche Arbeitsstätte) geeignet ist. Die minimale Höhe eines Gebäudes wird nicht definiert. - Im Bau befindliche Gebäude, bei welchen die Dachkonstruktion noch nicht abgeschlossen ist, werden als 'sonstige befestigte Flächen' klassifiziert."
      },
      {
        "@language": "en",
        "@value": "identical to EAGLE class: 1111_Buildings"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Überdachte, auf Dauer errichtete Bauwerke, die geeignet oder bestimmt sind, dem Schutz oder der Unterbringung von Menschen, Tieren oder Sachen zu dienen."
      },
      {
        "@language": "en",
        "@value": "Roof-covered constructions like single buildings or block of buildings with a significant height difference from the surrounding surface"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "1_1_1_Building"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Gebäude"
      },
      {
        "@language": "en",
        "@value": "building"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
