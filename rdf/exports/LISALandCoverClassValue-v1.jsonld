  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_Biotic",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "Includes: - Any vegetated land surface, either naturally grown, semi-natural or artificially planted vegetation (e.g. crops, urban parks), with or without anthropogenic influence."
      },
      {
        "@language": "de",
        "@value": "Vegetationsbedeckte Flächen weisen eine bestimmte Dichte der Biomasse zum Zeitpunkt der Aufnahme auf. Diese Vegetationsdichte kann durch entsprechende Parameter wie z.B. dem NDVI aus Fernerkundungsdaten ermittelt werden. Für deren Ermittlung ist die Verfügbarkeit von spektraler Information aus dem nahen Infrarot Bereich erforderlich (IR-Luftbilder oder Satellitenbilder). - Der Vegetationsindex ist je nach Phänologie saisonalen und jährlichen Änderungen unterworfen. Trotz dieser Änderungen ist der Vegetationsindex ein wichtiges Attribut und wird zur Differenzierung sowie räumlichen Trennung dieser Klassen herangezogen werden."
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Biotic surfaces have to be differentiated according to their attributes (e.g. coniferous percentage, biomass density, wetness, etc.)"
      },
      {
        "@language": "de",
        "@value": "Flächen mit einer Vegetationsbedeckung (biotisch)"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#narrower": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody"
      },
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "2_Biotic"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "biotic"
      },
      {
        "@language": "de",
        "@value": "vegetationsbedeckt"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#topConceptOf": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
