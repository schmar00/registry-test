  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_6_SurfaceWater",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "de",
        "@value": "identisch mit EAGLE-Klasse: 312_InlandWater - Zeitliche Dynamik: Wasserflächen unterliegen einer unbestimmten zeitlichen Dynamik, die von Tag, Woche, Monat und Jahr abhängig sein kann. Da Wasser als Landbedeckungsklasse manchmal nur sehr temporär und zeitlich beschränkt auftreten kann, ist dies bei der Ausweisung von flächenstatistischen Bilanzen zu Landbedeckungsveränderungen zu berücksichtigen (ähnliche Problematik wie bei Schneebedeckung bzw. Schatten)"
      },
      {
        "@language": "en",
        "@value": "identical to EAGLE class: 312_InlandWater"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Offene Wasserflächen von stehenden und fließenden Gewässern. Bei teilweise überschirmten Gewässern (kleinere Bachläufe) wird nur die tatsächliche luftbildsichtbare Wasserfläche ausgewiesen - es sei denn, daß Laserscanning Daten eine leichte und automatisierte Differenzierung auch überschirmter Wasserflächen gestatten."
      },
      {
        "@language": "en",
        "@value": "All kinds of inland surface water with no direct interference or interchange with open sea water."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "1_3_6_SurfaceWater"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Wasseroberfläche"
      },
      {
        "@language": "en",
        "@value": "surface water"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
