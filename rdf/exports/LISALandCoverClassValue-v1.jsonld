  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_4_Screes",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "de",
        "@value": "identisch mit EAGLE-Klasse: 1221_MineralFragments - Die Abgrenzung zu den 'sonstigen befestigten Flächen': frisch ausgehobenes Material oder temporär zwischengelagertes Material wird als Schutt/Sand bezeichnet. Wichtiges Unterscheidungskriterium zu 'sonstige befestigte Flächen' ist auch, ob der Oberboden eindeutig erkennbar durch menschliche Tätigkeiten abgeschoben (durch z.B. Bagger) und das darunterliegende Material verfestigt wurde (sonstige befestigte Flächen, z.B. Lager- und Umschlagplätze) bzw. die Flächen mit Fremdmaterial befestigt wurden (sonstige befestigte Flächen)."
      },
      {
        "@language": "en",
        "@value": "identical to EAGLE class: 1221_MineralFragments"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Screes come to be through physical disintegration of geological formations and are the result of becoming smaller and smaller along time. They are accumulated on site due to sedimentary processes or human activity. Further subdivision is made according to their particle size and constellation."
      },
      {
        "@language": "de",
        "@value": "Schutt und Sand: Lockersedimente wie Schuttfluren, Geröllfelder, Schotterflächen und sandige Bereiche bis hin zu Geröll (bis ca. max. 2 m Durchmesser) ohne erkennbare Beimischung von Humus. Der Vegetationsanteil beträgt maximal 10%."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "1_2_4_Screes"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "screes"
      },
      {
        "@language": "de",
        "@value": "Schotter"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
      }
    ],
    "http://www.w3.org/ns/adms#status": [
      {
        "@id": "http://inspire.ec.europa.eu/registry/status/valid"
      }
    ]
  },
  {
    "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_2_Ice",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/lcn"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "de",
        "@value": "identisch mit EAGLE-Klasse: 322_IceAndGlaciers - Eis findet sich in erster Linie in der alpinen Höhenzone wieder (innerhalb von LISA werden kaum Winteraufnahmen von gefrorenen Flüssen und Seen verwendet). Eis weist spektral eine deutlich unterschiedliche Signatur als Schnee auf (bläuliche Farbtöne). Eis bildet damit den Hauptbestandteil von Gletscherflächen. Vielfach ist das eigentliche Eis jedoch durch Schutt- und Moränenmaterial überdeckt und kann nicht als solches identifiziert werden."
      },
      {
        "@language": "en",
        "@value": "identical to EAGLE class: 322_IceAndGlaciers"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/lc"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@value": "http://www.landinformationsystem.at/en-us/lisa/overview.aspx"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#broader": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Vorwiegend mit Gletscher und Firn bedeckte Flächen."
      },
      {
        "@language": "en",
        "@value": "Glaciers in alpine zones."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/LISALandCoverClassValue"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "1_3_7_2_Ice"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "en",
        "@value": "ice"
      },
      {
        "@language": "de",
        "@value": "Eis"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
