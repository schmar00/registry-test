        "@language": "de",
        "@value": "Flächen, die keine vegetationsbedeckung aufweisen (abiotisch)"
      },
      {
        "@language": "en",
        "@value": "Any unvegetated surfaces, either covered with man-made artificial structures or geologically natural material surfaces (with or without anthropogenic influence or impact)."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
