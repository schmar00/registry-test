    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/sbgLandUseValue/GLSP"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/sbgLandUseValue/GLSO"/>
