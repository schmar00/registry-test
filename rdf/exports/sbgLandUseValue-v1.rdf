    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/sbgLandUseValue/VEGM"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/sbgLandUseValue/VEFP"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/sbgLandUseValue/VEEB"/>
