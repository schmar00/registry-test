        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/mainAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Kerngebiete sind Flächen mit einer im Vergleich zu anderen Baugebieten höheren Nutzungsvielfalt und Bebauungsdichte."@de,
            "Are areas with a higher variety of uses and building density compared to other building areas."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "mainAreas" ;
        skos:prefLabel "Kerngebiet"@de,
            "Main areas"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/openland> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Alle nicht als Bauland und Verkehrsland festgelegte Grundflächen gehören zum Freiland. Im Freiland können Sondernutzungen festgelegt werden (z.B.: öffentliche Parkanlagen)."@de,
            "All land not designated as building land or traffic land belongs to the open land. Special uses can be defined in the open land (e.g.: public parks)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "openland" ;
        skos:prefLabel "Freiland"@de,
            "Openland"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/rAIndustry> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "SG-Industrie sind nicht vollwertige Baulandflächen, die nach Beseitigung von Mängel zu vollwertigen Industriegebieten werden."@de,
            "RA-Industrial areas are not fully fledged building land, which become fully fledged industrial areas once defects have been remedied."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "rAIndustry" ;
        skos:prefLabel "SG-Industrie"@de,
            "RA-Industry"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/rAResidentialArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "SG-Wohnen sind nicht vollwertige Baulandflächen, die nach Beseitigung von Mängel zu vollwertigen Wohngebieten werden."@de,
            "RA-Residential areas are not fully-fledged building land that becomes fully-fledged residential areas after defects have been remedied."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "rAResidentialArea" ;
        skos:prefLabel "SG-Wohnen"@de,
            "RA-Residential area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/rAVillage> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "SG-Dorf  sind nicht vollwertige Baulandflächen, die nach Beseitigung von Mängel zu vollwertigen Dorfgebiet werden."@de,
            "RA-Villages are not fully-fledged building land which, once defects have been remedied, become fully-fledged village areas."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "rAVillage" ;
        skos:prefLabel "SG-Dorf"@de,
            "RA-Village"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/railway> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
