        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/buildingLandResidentialOrMixedUse> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. NOE"@de,
            "Def. NOE"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Fasst die Baulandwidmungsarten Wohngebiete (BW), Agrargebiete (BA), Kerngebiete (BK) und Gebiete fuer erhaltenswerte Ortsstrukturen (BO) zusammen (inkl. Aufschließungszonen bzw. wenn als Folgenutzungsart angegeben)."@de,
            "Covers building land use types residential areas (BW), agricultural areas (BA), core areas (BK) and areas with local structures worth preserving (BO) (incl. development zones or if subsequent type of use is specified)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "buildingLandResidentialOrMixedUse" ;
        skos:prefLabel "Bauland Wohn oder Mischnutzung"@de,
            "Building land residential or mixed use"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/buildingLandSpecialZone> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. NOE"@de,
            "Def. NOE"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Bauland Sondergebiete, fuer Nutzungen, die einen besonderen Schutz wie Krankenanstalten, Schulen, Pflegeheime erfordern oder denen ein bestimmter Standort zugeordnet werden soll wie Asphaltmischanalgen oder die sich nicht in die anderen Baulandwidmungen einordnen lassen wie Kasernen oder Sportanlagen."@de,
            "Building land - special zones for uses that require particular protection such as hospitals, schools, nursing homes, or that are to be assigned a specific location, such as asphalt mixing plants, or that cannot be categorised under other building use types, such as barracks or sports facilities."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "buildingLandSpecialZone" ;
        skos:prefLabel "Bauland-Sondergebiet"@de,
            "Building land special zone"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/centreZone> a skos:Concept ;
