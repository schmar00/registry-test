    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/residentialAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Wohnen sind Gebiete die ausschließlich oder vornehmlich für Wohnzwecke bestimmt sind."@de,
            "Residential areas are areas that are exclusively or primarily intended for residential purposes."@en ;
