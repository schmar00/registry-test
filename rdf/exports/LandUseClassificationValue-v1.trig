    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/industryAndCommerce> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "sind Flächen für Gewerbe und Industrie inklusive Verwaltungsgebäuden und die für die Aufrechterhaltung erforderlichen Wohnungen."@de,
            "are areas for trade and industry including administrative buildings and the apartments required for maintenance."@en ;
