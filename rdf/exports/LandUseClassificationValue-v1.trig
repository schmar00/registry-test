    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/specialUseOpenland> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "sind Flächen, wenn auf Grund ihrer besonderen Standortgunst die flächenhafte Nutzung im Vordergrund steht und diese nicht typischerweise einem Baulandgebiet zuzuordnen ist. Insbesondere sind das Flächen für Erwerbsgärtnereien, Erholungszwecke, Spielzwecke, Parkanlagen, Friedhöfe,…"@de,
            "are areas if, due to their particular locational advantages, the focus is on land use and this is not typically assigned to a building land area. In particular, these are areas for commercial nurseries, recreational purposes, playgrounds, parks, cemeteries, etc."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "specialUseOpenland" ;
        skos:prefLabel "Sondernutzung im Freiland"@de,
            "Special use in the open land"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/trafficAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
            "Def. STMRK"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lu> ;
        skos:definition "Verkehrsflächen sind solche Flächen, die für die Abwicklung des fließenden und ruhenden Verkehrs, sowie für die Aufschließung des Baulandes und des Freilandes vorgesehen sind."@de,
            "Traffic areas are those areas which are intended for the handling of moving and stationary traffic, as well as for the development of building land and open land"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "trafficAreas" ;
        skos:prefLabel "Verkehr"@de,
            "Traffic areas"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LandUseClassificationValue/villageAreas> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lunom> ;
        dcterms:description "Def. STMRK"@de,
