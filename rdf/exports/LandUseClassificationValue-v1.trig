        skos:definition "Fasst die Baulandwidmungsarten Industriegebiete (BI) und Betriebsgebiete (BB) zusammen."@de,
            "Covers building land use types industrial areas (BI) and commercial (BB) areas."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LandUseClassificationValue> ;
        skos:notation "buildingLandCommercialUse" ;
        skos:prefLabel "Bauland Betriebsnutzung"@de,
