@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <http://www.w3.org/ns/adms#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://registry.inspire.gv.at/codelist/LISALandCoverClassValue:1> {
    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_1_Building> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 1111_Buildings - Diese Klasse beinhaltet Gebäude und Gebäudekomplexe. Gebäude sind aus Sicht der Raumplanung ab einer Größe von 50 m² zu erfassen, da diese Größe die minimale Fläche eines Gebäudes ist, welches als Hauptgebäude (ganzjährige Wohnung und/oder betriebliche Arbeitsstätte) geeignet ist. Die minimale Höhe eines Gebäudes wird nicht definiert. - Im Bau befindliche Gebäude, bei welchen die Dachkonstruktion noch nicht abgeschlossen ist, werden als 'sonstige befestigte Flächen' klassifiziert."@de,
            "identical to EAGLE class: 1111_Buildings"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp> ;
        skos:definition "Überdachte, auf Dauer errichtete Bauwerke, die geeignet oder bestimmt sind, dem Schutz oder der Unterbringung von Menschen, Tieren oder Sachen zu dienen."@de,
            "Roof-covered constructions like single buildings or block of buildings with a significant height difference from the surrounding surface"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "1_1_1_Building" ;
        skos:prefLabel "Gebäude"@de,
            "building"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_2_OtherConstructedArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 1112_OtherConstructions - Beinhaltet befestigte Straßen, Gehsteige, Parkplätze und sonstige befestigte Flächen, wie z.B. Tennisplätze, Sportlaufbahnen etc. Auch befestigte Baunebenflächen und Manipulationsflächen in Gewerbe- und Industrie fallen darunter. Ebenso in diese Kategorie fallen die dauerhaft angelegten landwirtschaftlichen Güterwege und Zu- und Abfahrten zu Industrie- und Gewerbegebieten sowie Lagerplätzen. - Plätze in Anlagen mit permanenter Nutzung sind in der Regel als befestigt anzusehen (Kompostanlagen, Industrielager, LKW-Abstellplätze etc.). Vorübergehend zur Lagerung benutzte Flächen sind in der Regel nicht durch Aufbringung von Fremdmaterial charakterisiert, aber die menschliche Intention ist klar erkennbar, der Oberboden angeschoben und das Erdreich verdichtet (Holzlager, Materialdepots von Baustellen etc.). - Abgrenzung: Bei der Klasse Schotter/Sand handelt es sich hingegen um natürliche Prozesse."@de,
            "identical to EAGLE class: 1112_OtherConstructions - Includes: e.g. asphalt, concrete, pave dings like on roads, parking lots, squares, storages areas, airport run ways, quays, sealed bottom pools, unvegetated cemeteries. - Excludes: gravel bed of railway track. It is an artificial surface but not impervious, better to be placed under Gravel, Pebble"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp> ;
        skos:definition "Künstlich angelegte, ganz oder teilweise versiegelte Flächen, insbesondere asphaltierte, betonierte, bekieste, geschotterte, gemergelte sowie mit Steinen oder Platten belegte Böden (© Schweizer Arealstatistik)."@de,
            "Flat surfaces covered by any type of impervious material which that is used for artificial surface pavements (e.g. asphalt, concrete, tarmacadam)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "1_1_2_OtherConstructedArea" ;
        skos:prefLabel "sonstige befestigte Fläche"@de,
            "other constructed area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_3_PermanentBareSoil> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 1223_BareSoils - Da diese Klasse - wie die anderen - noch rein auf spektrale Merkmalen basiert, deckt sie eine sehr breite Nutzungspalette ab. Meist kommt diese Klasse im landwirtschaftlichen Bereich vor, es handelt sich dabei um Böden ohne Vegetationsbedeckung, aber mit reichlichem Humusgehalt (=Erde). Je geringer der Humusgehalt, desto mehr geht die Klasse offener Boden in die Klasse 'Schotter/Sand' über. Die Abgrenzung zum Grünbewuchs erfolgt über den Vegetationsindex (Einteilung in: keine, wenig, mittel und hoch siehe 'Grünbewuchs)). Der Vegetationsanteil beträgt maximal 10%. - Die im Gemüsebau manchmal anzutreffende temporäre Abdeckung von Äckern bzw. Ackerstreifen mittels schwarzen und weißen Folien soll als 'offener Boden' klassifiziert werden."@de,
            "identical to EAGLE class: 1223_BareSoils"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp> ;
        skos:definition "Nicht vegetationsbedeckter, offener Boden."@de,
            "Mixture of mineral and organic material that is capable of sustaining plant life, but being unvegetated at the moment of observation (primarily bare arable land)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "1_2_3_PermanentBareSoil" ;
        skos:prefLabel "offener Boden (dauerhaft)"@de,
            "permanent bare soil"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_4_Screes> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 1221_MineralFragments - Die Abgrenzung zu den 'sonstigen befestigten Flächen': frisch ausgehobenes Material oder temporär zwischengelagertes Material wird als Schutt/Sand bezeichnet. Wichtiges Unterscheidungskriterium zu 'sonstige befestigte Flächen' ist auch, ob der Oberboden eindeutig erkennbar durch menschliche Tätigkeiten abgeschoben (durch z.B. Bagger) und das darunterliegende Material verfestigt wurde (sonstige befestigte Flächen, z.B. Lager- und Umschlagplätze) bzw. die Flächen mit Fremdmaterial befestigt wurden (sonstige befestigte Flächen)."@de,
            "identical to EAGLE class: 1221_MineralFragments"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp> ;
        skos:definition "Schutt und Sand: Lockersedimente wie Schuttfluren, Geröllfelder, Schotterflächen und sandige Bereiche bis hin zu Geröll (bis ca. max. 2 m Durchmesser) ohne erkennbare Beimischung von Humus. Der Vegetationsanteil beträgt maximal 10%."@de,
            "Screes come to be through physical disintegration of geological formations and are the result of becoming smaller and smaller along time. They are accumulated on site due to sedimentary processes or human activity. Further subdivision is made according to their particle size and constellation."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "1_2_4_Screes" ;
        skos:prefLabel "Schotter"@de,
            "screes"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_5_BareRock> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 1211_BareRocks - Natura 2000: Felsflächen beinhalten bedeutende Lebensraumtypen mit großflächigem Vorkommen. Weitere Differenzierung über Geologie. - - 8210 Kalkfelsen mit Felsspaltenvegetation (Flächenschätzung 50.000-240.000 ha) - - 8220 Silikatfelsen mit Felsspaltenvegetation (Flächenschätzung 10.000-100.000 ha) - Hinweis: Felsbereiche sind oft sehr stark von topographischen Schattenflächen beeinflußt. Im Sinne eines flächenstatistisch korrekten Monitoring ist auf die Befüllung dieser Schattenflächen durch Ersatzdaten (Übernahme veralteter Daten bzw. Heranziehen weiterer Satellitenbildaufnahmen) besonders zu achten."@de,
            "identical to EAGLE class: 1211_BareRocks - Includes: - e.g. solid (closed) rock formations, fresh lava flows, quarries, mineral extraction sites, open pit mines"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp> ;
        skos:definition "Felsen und anstehendes festes Gestein. Anhäufungen von Gestein (Gesteinsfelder) werden ab einem durchschnittlichen Durchmesser von 2m als 'Fels/Gestein' ausgewiesen, darunter als 'Schotter/Sand'."@de,
            "The rock surface is continuous except perhaps for a few cracks in the material. Some areas may be covered by shallow layers of soil or there could be isolated pockets of soil or a mixture of both."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "1_2_5_BareRock" ;
        skos:prefLabel "Fels"@de,
            "bare rock"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_6_SurfaceWater> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 312_InlandWater - Zeitliche Dynamik: Wasserflächen unterliegen einer unbestimmten zeitlichen Dynamik, die von Tag, Woche, Monat und Jahr abhängig sein kann. Da Wasser als Landbedeckungsklasse manchmal nur sehr temporär und zeitlich beschränkt auftreten kann, ist dies bei der Ausweisung von flächenstatistischen Bilanzen zu Landbedeckungsveränderungen zu berücksichtigen (ähnliche Problematik wie bei Schneebedeckung bzw. Schatten)"@de,
            "identical to EAGLE class: 312_InlandWater"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water> ;
        skos:definition "Offene Wasserflächen von stehenden und fließenden Gewässern. Bei teilweise überschirmten Gewässern (kleinere Bachläufe) wird nur die tatsächliche luftbildsichtbare Wasserfläche ausgewiesen - es sei denn, daß Laserscanning Daten eine leichte und automatisierte Differenzierung auch überschirmter Wasserflächen gestatten."@de,
            "All kinds of inland surface water with no direct interference or interchange with open sea water."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "1_3_6_SurfaceWater" ;
        skos:prefLabel "Wasseroberfläche"@de,
            "surface water"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_1_Snow> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 321_Snow - Zeitliche Dynamik: Die Schneebedeckung ist zeitlich variable (Wochen, Monats-, Jahresdynamik). Dies ist bei der Etablierung eines Monitoringsystemes zu berücksichtigen, da keine echten Landbedeckungsänderungen unterhalb der Schneedecke feststellbar sind, dürfen die vom Schnee bedeckten Flächen auch nicht in Änderungsstatistiken übernommen werden. Wie bei großflächig beschatteten Bereichen sind auch bei Schneeflächen auf die Befüllung durch Ersatzdaten (Übernahme alter Daten bzw. Heranziehen weiterer Satellitenbildaufnahmen) besonders zu achten."@de,
            "identical to EAGLE class: 321_Snow"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce> ;
        skos:definition "Die Schneebedeckung ist naturgemäß in erster Linie vom Zeitpunkt der Aufnahme mittels Fernerkundungsdaten abhängig. Jedoch stellt sie sowohl in Luft- als auch in Satellitenbildern eine relativ einfach zu differenzierende Landbedeckungsklasse dar. Schnee überdeckt eine andere Landbedeckungsklasse, die aber zum Zeitpunkt der Aufnahme eben nicht feststellbar ist, sofern keine Information aus einer Vorperiode zur Verfügung steht. Vielfach befinden sich auch Eisflächen (Gletscher) unter dem Schnee."@de,
            "Permanent snow in alpine areas. Temporary snow coverage must not be mapped."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "1_3_7_1_Snow" ;
        skos:prefLabel "Schnee"@de,
            "snow"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_2_Ice> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 322_IceAndGlaciers - Eis findet sich in erster Linie in der alpinen Höhenzone wieder (innerhalb von LISA werden kaum Winteraufnahmen von gefrorenen Flüssen und Seen verwendet). Eis weist spektral eine deutlich unterschiedliche Signatur als Schnee auf (bläuliche Farbtöne). Eis bildet damit den Hauptbestandteil von Gletscherflächen. Vielfach ist das eigentliche Eis jedoch durch Schutt- und Moränenmaterial überdeckt und kann nicht als solches identifiziert werden."@de,
            "identical to EAGLE class: 322_IceAndGlaciers"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce> ;
        skos:definition "Vorwiegend mit Gletscher und Firn bedeckte Flächen."@de,
            "Glaciers in alpine zones."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "1_3_7_2_Ice" ;
        skos:prefLabel "Eis"@de,
            "ice"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_10_Bushes> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 2121_RegularBushes/Shrubs - Die im Siedlungsbereich häufig anzutreffenden Hecken und Gebüschreihen werden erst ab einer Breite von 1m erfasst. Für die Überprüfung der Genauigkeit gilt die generelle Evaluierungsbreite von 3m. - Weinreben werden aufgrund ihrer geringen Breite, aber der erkennbaren linearen Struktur, unter 'Grünbewuchs' mit dem Attribut 'lineare, parallele Struktur' geführt."@de,
            "identical to EAGLE class: 2121_RegularBushes/Shrubs"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody> ;
        skos:definition "Mit Krummholzbestände (z.B. Latsche), Büschen (z.B. Grünerle), Sträuchern (z.B. Hecken) bewachsene Flächen. Die Höhe liegt unter 5 m aber fast immer über 0,5 m. Der Deckungsgrad mit Gebüschen liegt dabei >50%. Jungwuchs und Dickungen mit einer Höhe < 5 m fallen ebenfalls in diese Klasse."@de,
            "woody plants with a height between 0,5 and 5m."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "2_4_10_Bushes" ;
        skos:prefLabel "Gebüsch"@de,
            "bushes"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_11_DwarfShrubs> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 2122_DwarfShrubs - Da großflächige Zwergstrauchbestände nur in der (sub)alpinen Zone auftreten können diese durchaus mit einer gröberen räumlichen Auflösung erfaßt werden."@de,
            "identical to EAGLE class: 2122_DwarfShrubs"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody> ;
        skos:definition "Flächige Bestände von v.a. Alpenrose und anderen Zwergsträuchern (Schwarzbeere, Preiselbeere, Rauschbeere). Zwergsträucher sind zwischen 10 cm und 40 cm hoch, wintergrün und meist als Sukzessionsstadien nach der Aufgabe von Almweide zu finden. Sie können mit Almweideflächen in enger Verzahnung auftreten."@de,
            "woody plants with a height between 0,2 and 0,5m."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "2_4_11_DwarfShrubs" ;
        skos:prefLabel "Zwergstrauch"@de,
            "dwarf shrubs"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_1_DeciduousTrees> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees> ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "2_4_9_1_DeciduousTrees" ;
        skos:prefLabel "Laubbäume"@de,
            "deciduous trees"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_2_MixedTrees> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees> ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "2_4_9_2_MixedTrees" ;
        skos:prefLabel "Mischung Laub/Nadel"@de,
            "mixed trees"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_3_ConiferousTrees> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees> ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "2_4_9_3_ConiferousTrees" ;
        skos:prefLabel "Nadelbäume"@de,
            "coniferous trees"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_1_HerbaceousPermanent> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "Flächen, die Größtenteils als Grünland genutzt werden."@de ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous> ;
        skos:definition "Flächen, die über ein ganzes Jahr hinweg durch Grünbewuchs bedeckt sind und keine unterjährliche Bodenbearbeitung auzfweisen."@de,
            "herbeceous vegetation that is permanently covered with vegetation throughout a year"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "2_5_12_1_HerbaceousPermanent" ;
        skos:prefLabel "Grünbewuchs dauerhaft"@de,
            "herbaceous permanent"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_2_HerbaceousPeriodically> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "flächen, die größtenteils als Acker genutzt werden"@de ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous> ;
        skos:definition "Flächen, die im Laufe eines Jahres zumindest einmal eine Bodenbearbeitung aufweisen."@de,
            "herbeceous vegetation that is not permanently covered with vegetation throughout a year. Bare soil can be observed at least once per year"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "2_5_12_2_HerbaceousPeriodically" ;
        skos:prefLabel "Grünbewuchs periodisch"@de,
            "herbaceous periodically"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_13_Reeds> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 2212_Reeds, Bamboos and Canes"@de,
            "identical to EAGLE class: 2212_Reeds, Bamboos and Canes"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous> ;
        skos:definition "Schilf kommt in größerem Ausmaß z.B. im Schilfgürtel des Neusiedler Sees vor und ist spektral eindeutig von anderen Klassen zu unterscheiden. Kleinsträumig ist Schilf mit Wasserflächen assoziiert (MVU = 500 m²)"@de,
            "Reed is a common name for several tall, grass-like plants of wetlands. They are all members of the order Poales (in the modern, expanded circumscription) (© wikipedia)"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:notation "2_5_13_Reeds" ;
        skos:prefLabel "Schilf"@de,
            "reeds"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "Excludes: - Urban greenery may be artificial and under human maintenance, but after all it is vegetation and not to be placed her."@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic> ;
        skos:definition "Befestigte Flächen sind charakterisiert durch eine dauerhafte befestigte Abdeckung des Erdbodens"@de,
            "All Surfaces where Landscape has been changed by or is under influence of human construction activities by replacing natural surfaces with artificial abiotic 2D/3D constructions or artificial materials. Artificial parts of urban and suburban areas, where mankind has settled with permanent settlement infrastructures, also the settlement parts of rural areas, built-up areas (buildings, other constructions and sealed flat surfaces) and non-built-up areas (no buildings, artificial and unsealed)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_1_Building>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_2_OtherConstructedArea> ;
        skos:notation "1_1_BuiltUp" ;
        skos:prefLabel "befestigte Fläche"@de,
            "built-up"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water> ;
        skos:definition "Snow and Ice (solid aggregated water)"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_1_Snow>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_2_Ice> ;
        skos:notation "1_3_7_SnowIce" ;
        skos:prefLabel "Schnee und Eis"@de,
            "snow/ice"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic> ;
        skos:definition "Die Landbedeckung Wasser wird nach ihren Aggregatzuständen unterschieden."@de,
            "The chemical substance of water (H2O), either in liquid or in frozen solid state of aggregation."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_6_SurfaceWater>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_7_SnowIce> ;
        skos:notation "1_3_Water" ;
        skos:prefLabel "Wasser"@de,
            "water"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 22_Herbaceous - Abgrenzung von benachbarten Objekten gleicher Klassenzugehörigkeit: Insbesondere in der Klasse Grünbewuchs ist es wichtig - ähnlich wie in der Klasse offener Boden jene Objekte zu erfassen, die eine geschlossene räumliche Einheit bilden. Grünbewuchsflächen können aneinander angrenzen und trotzdem werden sie räumlich differenziert, da sie sich - Auch sämtliche Ackerflächen, die eine luftbildsichtbare Vegetation aufweisen fallen in diese Kategorie (Weizen, Mais, Erdäpfel, etc.). Die Grünflächen enthalten somit alle vegetationsbedeckten aber nicht bestockten Flächen. Darunter fallen sowohl natürliche Wiesen, Wirtschaftsgrünland, Parkanlagen, Rasenflächen in Hausgärten, Grünbegleitstreifen etc."@de,
            "identical to EAGLE class: 22_Herbaceous"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous> ;
        skos:definition "Sämtliche mit sichtbarer niedriger Vegetation (Gras oder Krautvegetation) bedeckte Flächen. Die innere Differenzierung des Grünbewuchse ('einzelne Schläge als getrennte Segmente' - Landschaftsstruktur) ist dabei mitzuerfassen. Der Deckungsgrad durch oberirdische Pflanzenteile muß mindestens 10% innerhalb der Referenzfläche einnehmen."@de,
            "This large class contains all kind of arable crops, pastures, meadows and natural grasslands. As for bare soil it is in the context of agricultural use not essential to assign the object the correct class, as the class of an object is a rather random issue depending on the acquisition date. However it is important to differentiate objects of the same class, if they are located next to each other, and if they can differentiate according to their vegetation index and physiognomic appearance."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_1_HerbaceousPermanent>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_2_HerbaceousPeriodically> ;
        skos:notation "2_5_12_Herbaceous" ;
        skos:prefLabel "Grünbewuchs"@de,
            "herbaceous"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_Biotic> ;
        skos:definition "Flächen, die von nicht verholzter Vegetation bedeckt sind"@de ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_12_Herbaceous>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_13_Reeds> ;
        skos:notation "2_5_Herbaceous" ;
        skos:prefLabel "nicht verholzt"@de,
            "herbaceous"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_Biotic> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "Vegetationsbedeckte Flächen weisen eine bestimmte Dichte der Biomasse zum Zeitpunkt der Aufnahme auf. Diese Vegetationsdichte kann durch entsprechende Parameter wie z.B. dem NDVI aus Fernerkundungsdaten ermittelt werden. Für deren Ermittlung ist die Verfügbarkeit von spektraler Information aus dem nahen Infrarot Bereich erforderlich (IR-Luftbilder oder Satellitenbilder). - Der Vegetationsindex ist je nach Phänologie saisonalen und jährlichen Änderungen unterworfen. Trotz dieser Änderungen ist der Vegetationsindex ein wichtiges Attribut und wird zur Differenzierung sowie räumlichen Trennung dieser Klassen herangezogen werden."@de,
            "Includes: - Any vegetated land surface, either naturally grown, semi-natural or artificially planted vegetation (e.g. crops, urban parks), with or without anthropogenic influence."@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:definition "Flächen mit einer Vegetationsbedeckung (biotisch)"@de,
            "Biotic surfaces have to be differentiated according to their attributes (e.g. coniferous percentage, biomass density, wetness, etc.)"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_5_Herbaceous> ;
        skos:notation "2_Biotic" ;
        skos:prefLabel "vegetationsbedeckt"@de,
            "biotic"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "Includes: unvegetated rocky mountainous regions, sand, also quarries and extraction sites, etc"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic> ;
        skos:definition "Flächen, die durch keine anthropogen erzeugte dauerhaft befestigte Abdeckungs des Erdbodens charakterisiert sind"@de,
            "Any kind of surface material which remains in its natural consistence or form either with or without anthropogenic influence. Consolidated and unconsolidated surfaces."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_3_PermanentBareSoil>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_4_Screes>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_5_BareRock> ;
        skos:notation "1_2_NonBuiltUp" ;
        skos:prefLabel "nicht befestigte Fläche"@de,
            "non built-up"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_Abiotic> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:definition "Flächen, die keine vegetationsbedeckung aufweisen (abiotisch)"@de,
            "Any unvegetated surfaces, either covered with man-made artificial structures or geologically natural material surfaces (with or without anthropogenic influence or impact)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_1_BuiltUp>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_2_NonBuiltUp>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/1_3_Water> ;
        skos:notation "1_Abiotic" ;
        skos:prefLabel "nicht vegetationsbedeckt"@de,
            "abiotic"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:description "identisch mit EAGLE-Klasse: 211_Trees - Bestockte Flächen können aus Einzelbäumen, Baumgruppen oder zusammenhängenden Waldbeständen aufgebaut sein. Sie weisen fast immer auch einen entsprechenden Höhenunterschied (erkennbar durch Schatten bzw. Höhendifferenz aus ALS-Daten) zu benachbarten Flächen auf. Die mit Bäumen bestockten Flächen werden aufgrund ihrer flächendeckenden Bedeutung (ca. 47 % von Österreich) sollen nach dem Kriterium Flächengröße validiert werden. Die Flächengrößen der Validierungsstrata entsprechen ca. den in Version 1 des Datenmodelles geführten Unterklassen 'Einzelbaum', 'Baumgruppe' und 'Waldstück'. - Die Zuweisung zur Landbedeckungsklasse 'bestockte Fläche' nimmt keineswegs zwangsläufig die Zuordnung zur Landnutzungsklasse 'Wald' vorweg. Bei überwiegender Dominanz anderer als forstlicher Nutzung können Waldstücke durchaus auch der Landnutzung 'Landwirtschaft' zugewiesen werden bzw. aufgrund des Größenkriteriums in einer anderen Klasse aggregiert werden. - Anzumerken ist dabei, dass auch Streuobstwiesen, Obstplantagen oder Christbaumkulturen in der Klasse 'bestockte Fläche' ausgewiesen werden. Eine Differenzierung nach der Art der Nutzung (Wald vs. Landwirtschaft) erfolgt erst im Datenmodellbereich 'Landnutzung'."@de,
            "identical to EAGLE class: 211_Trees"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody> ;
        skos:definition "Mit bestockter Fläche werden innerhalb von LISA sämtliche mit verholzten Pflanzen (Bäumen oder Gebüschen) bestockte Flächen definiert. Die Höhe von bestockten Flächen ist >5 m (Ausnahme Jungwuchs und Dickungen - können auch kleiner als 5m sein, und werden daher in der Landbedeckung trotzdem zu Klasse 'bestockte Fläche' gezählt!)."@de,
            "Trees with a minimum crown coverage: 10% (measured as stem-to-stem distance of 10m)"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_1_DeciduousTrees>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_2_MixedTrees>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_3_ConiferousTrees> ;
        skos:notation "2_4_9_Trees" ;
        skos:prefLabel "bestockte Fläche"@de,
            "trees"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_Woody> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/lc> ;
        rdfs:seeAlso "http://www.landinformationsystem.at/en-us/lisa/overview.aspx" ;
        skos:broader <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_Biotic> ;
        skos:definition "Flächen die durch verholzte Pflanzen bedeckt sind."@de,
            "Areas that are covered with woody plants."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> ;
        skos:narrower <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_10_Bushes>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_11_DwarfShrubs>,
            <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue/2_4_9_Trees> ;
        skos:notation "2_4_Woody" ;
        skos:prefLabel "verholzt"@de,
            "woody"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/LISALandCoverClassValue> a skos:ConceptScheme ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/lcn> ;
        dcterms:created "2026-05-05T14:30:11+00:00"^^xsd:dateTime ;
