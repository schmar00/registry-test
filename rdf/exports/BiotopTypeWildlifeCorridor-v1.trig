        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor/transitionArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/hb> ;
        dcterms:description "OOE"@de,
            "OOE"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:definition "Gebiete mit signifikanter Waldausstattung (30-50 % Flächenanteil) und eingeschränkter Eignung als Lebensraum für waldgebundene Tierarten mit großen Raumansprüchen. Strukturreiche Kulturlandschaft mit vielen Kleinwaldflächen, wenig Siedlungsinfrastruktur, geringe Zerschneidung durch hochrangige Verkehrsträger."@de,
            "Areas with a sginificant portion of woodland (30-50 % of total amount) and reduced habitat function for large forest animals. Diverse cultural landscape with small structured forest areas, only moderately fragmented by traffic infrastructure and settlements."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor> ;
        skos:notation "transitionArea" ;
        skos:prefLabel "Uebergangszone"@de,
            "transition area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

