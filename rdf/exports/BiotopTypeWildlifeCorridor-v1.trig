        dcterms:description "OOE"@de,
            "OOE"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:definition "Abschnitt eines international bedeutenden Wildtierkorridors mit erheblich eingeschränkter Funktionalität."@de,
