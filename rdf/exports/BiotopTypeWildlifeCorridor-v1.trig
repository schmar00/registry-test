<https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor:1> {
    <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor/coreArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/hb> ;
        dcterms:description "OOE"@de,
            "OOE"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:definition "Gebiete mit hoher Waldausstattung (> 50 % Flächenanteil) und guter Eignung als Lebensraum für waldgebundene Tierarten mit großen Raumansprüchen. Größere geschlossene Waldgebiete, kaum Siedlungsinfrastruktur und Zerschneidung durch hochrangige Verkehrsträger, kleinteilige Kulturlandschaft."@de,
            "Areas with a high portion of woodland (more than 50 % of total amount) and appropriate habitat function for large forest animals. Larger closed woodland areas or highly diverse cultural landscapes, hardly or not fragmented by traffic infrastructure and settlements."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor> ;
        skos:notation "coreArea" ;
        skos:prefLabel "Kernzone"@de,
            "core area"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        skos:topConceptOf <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor> ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor/corridorA> a skos:Concept ;
