        dcterms:description "OOE"@de,
            "OOE"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:definition "International bedeutender Wildtierkorridor zur Lebensraumvernetzung für weitwandernde Großsäuger."@de,
            "Wildlife corridor of international importance for the dispersion of migrating large mammals."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor> ;
        skos:notation "corridorA" ;
        skos:prefLabel "Korridor - A"@de,
