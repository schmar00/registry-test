    <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor/steppingStone> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/hb> ;
        dcterms:description "OOE"@de,
            "OOE"@en ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:definition "Waldgebiete mit Rückzugs- und Vernetzungsfunktion entlang der Donau zur Überwindung natürlicher Barrieren."@de,
            "Woodland areas highly important for ecological landscape connectivity along the Danube river."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/BiotopTypeWildlifeCorridor> ;
        skos:notation "steppingStone" ;
        skos:prefLabel "Trittstein"@de,
