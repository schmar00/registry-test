        skos:notation "residentialBuilding" ;
        skos:prefLabel "Wohngebaeude"@de,
            "residential building"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/sewer> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
