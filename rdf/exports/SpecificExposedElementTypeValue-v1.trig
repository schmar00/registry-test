            "building economic benefit"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/electricalInstallations> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/transporAndNetworkInfrastructure> ;
        skos:definition "Bauliche Infrastrukturanlagen zur Herstellung und Versorgung durch elektrischen Strom."@de,
            "Shipping water areas, rivers and canals and their associated structures (e. g. jetties, locks)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "electricalInstallations" ;
        skos:prefLabel "Elektrische Anlagen"@de,
            "water path transport"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/forestAndAgriculturalTrails> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/transporAndNetworkInfrastructure> ;
        skos:definition "Bauliche Objekte, die als Transportweg zur zweckmäßigen Bewirtschaftung von land- und forstwirtschaftlichen Liegenschaften dienen."@de,
            "Structural objects that serve as a transport route for the appropriate management of agricultural and forestry properties."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "forestAndAgriculturalTrails" ;
        skos:prefLabel "Forst und Agrarwege"@de,
            "Forest and agricultural trails"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/forestryArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/agriculturalAndForestryCrops> ;
        skos:definition "Flächen, die zur forstwirtschaftlichen Rohstofferzeugung als auch das Erbringen immaterieller Leistungen insbesondere als Schutz- und Erholungsraum."@de,
            "Areas used for the production of forest products and the provision of intangible services, in particular as a protected and recreational area."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "forestryArea" ;
        skos:prefLabel "forstwirtschaftliche Flaechen"@de,
            "forestry area"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/forestryObjects> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/agriculturalAndForestryCrops> ;
        skos:definition "Objekte die zur forstwirtschaftlichen Rohstofferzeugung dienen und Produkte."@de,
            "Objects used for the production of forest materials and products."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "forestryObjects" ;
        skos:prefLabel "forstwirtschaftliche Objekte"@de,
            "forestry objects"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/formerRedZone> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone> ;
        skos:definition "Hierbei handelt es sich um Restrisikogebiete im Wirkungsbereich von Hochwasserschutzanlagen. Wenn ein Hochwasserereignis das Bemessungsereignis übersteigt bzw. in Folge eines technischen Gebrechens die Hochwasserschutzanlage nicht funktioniert, kommt es im Wirkungsbereich der Hochwasserschutzanlage zu Überflutungen in einem Ausmaß ähnlich wie bei Nichtvorhandensein der Hochwasserschutzanlage. Neubauten sind in diesem Bereich hochwassergeschützt zu errichten."@de,
            "These are risk areas where flood protection systems are in operation. When a flood event exceeds the degree of protection or a technical fault occurs, the flood protection system does not function, flooding occurs to a degree similar to the absence of the flood protection system. New buildings are to be built flood-proof in this area."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "formerRedZone" ;
        skos:prefLabel "ehemals Rote Zone"@de,
            "former red zone"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/gasPipelines> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
