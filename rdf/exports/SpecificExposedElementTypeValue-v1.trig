            "Structural infrastructure facilities for communication supply."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "gasPipelines" ;
        skos:prefLabel "Gasleitungen"@de,
            "telecommunication network"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

