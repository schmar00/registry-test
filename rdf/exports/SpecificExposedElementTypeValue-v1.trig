    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/redYellowZone> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone> ;
        skos:definition "Diese Bereiche sind als Retentions-, Abfluss- und wasserwirtschaftliche Vorrangzonen vorgesehen und sind für den schadlosen Abfluss und Hochwasserrückhalt im Hochwasserfall von großer Bedeutung."@de,
            "These areas are intended as retention, drainage and water management priority zones and are of great importance for the safe discharge and flood retention in flood situations."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "redYellowZone" ;
        skos:prefLabel "Rot Gelbe Zone"@de,
            "red yellow zone"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/redZone> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone> ;
        skos:definition "Bereiche die von Hochwasser mit mittlerer Eintrittswahrscheinlichkeit besonders gefährdet sind. Es besteht Gefahr für Leib und Leben und diese Flächen sind für die Bebauung nicht geeignet."@de,
            "Areas that are particularly at risk from floods with medium probability of occurrence. There is danger to life and these areas are not suitable for building."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "redZone" ;
        skos:prefLabel "Rote Zone"@de,
            "red zone"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/remainingRisk> a skos:Concept ;
