<https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue:1> {
    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/agriculturalArea> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/agriculturalAndForestryCrops> ;
        skos:definition "Flächen, die zur landwirtschaftlichen Rohstofferzeugung als auch Brachflächen dienen. Landwirtschaftliche Gebäude- und Hofflächen sind nicht enthalten."@de,
            "Areas used for the production of agricultural products and fallow land. Agricultural buildings and yards are not included."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "agriculturalArea" ;
        skos:prefLabel "landwirtschaftliche Flaechen"@de,
            "agricultural area"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/agriculturalBuilding> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/buildingsAndFacilities> ;
        skos:definition "Bauliche Anlagen, die für die Erzeugung landwirtschaflicher Produkt, primaer als auch sekundär genutzt werden."@de,
            "Constructional facilities used for the production of agricultural products, both primer and secondary."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "agriculturalBuilding" ;
        skos:prefLabel "Agrargebaeude"@de,
            "agricultural building"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/agriculturalObjects> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/agriculturalAndForestryCrops> ;
        skos:definition "Objekte die zur landwirtschaftliche Rohstofferzeugung dienen und Produkte (auch Tier und Fischbestände) ."@de,
            "PObjects used for agricultural production of materials and products (including animals and fish stocks)."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "agriculturalObjects" ;
        skos:prefLabel "landwirtschaftliche Objekte"@de,
            "agricultural objects"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/blueZone> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/classificationZone> ;
        skos:definition "Dieser Bereich ist eine wasserwirtschaftliche Bedarfszone und wird auf Flächen ausgewiesen, die für die Durchführung sowie Aufrechterhaltung der Funktionen geplanter schutzwasserwirtschaftlicher Maßnahmen benötigt werden."@de,
            "This area is a water-based demand zone and is identified to carry out and maintain the functions of planned flood protection management measures."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "blueZone" ;
        skos:prefLabel "Blaue Zone"@de,
            "blue zone"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/bridge> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/nz-core> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/nz> ;
        rdfs:seeAlso "national-technical"@en ;
        skos:broader <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/transporAndNetworkInfrastructure> ;
        skos:definition "Bauliche Objekte oder Versorgungseinrichtungen, die durch technische Konstruktionen Hindernisse überwinden."@de,
            "Structural objects or utilities that overcome obstacles through technical constructions."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "bridge" ;
        skos:prefLabel "Bruecke"@de,
            "bridge"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue/buildingEconomicBenefit> a skos:Concept ;
