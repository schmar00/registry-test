            "Constructional facilities that are primarily used for the purpose of business activities such as hotels, restaurants, etc. and small businesses."@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/SpecificExposedElementTypeValue> ;
        skos:notation "buildingEconomicBenefit" ;
