<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:ns1="http://www.w3.org/ns/adms#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/PlanTypeNameValue/gravelControlPlan">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/plu"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Diese Flaechen (Zonen) sind auf Grund von naturschutz-, forstfachlichen, wasserrechtlichen und siedlungstechnischen Gründen für Bergbau und einen Abbau nicht geeignet bzw. auf Grund von rechtlichen Bestimmung für Bergbau und einen Abbau auszuschließen.</skos:definition>
    <skos:definition xml:lang="en">Areas that are specifically excluded from any types of mining due to technical (i.e. conservation areas, forestry use, water regulations, settlement structures) or legal reasons.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue"/>
    <skos:notation>gravelControlPlan</skos:notation>
    <skos:prefLabel xml:lang="de">Kiesleitplan</skos:prefLabel>
    <skos:prefLabel xml:lang="en">gravel control plan</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/PlanTypeNameValue/zoningPlan">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/plu"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">The zoning plan must classify the municipal area according to the intended goals and determine the types of zoning for all area.</skos:definition>
    <skos:definition xml:lang="de">Der Flaechenwidmungsplan hat das Gemeindegebiet entsprechend den angestrebten Zielen zu gliedern und die Widmungsarten für alle Flaechen festzulegen.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue"/>
    <skos:notation>zoningPlan</skos:notation>
    <skos:prefLabel xml:lang="en">Zoning Plan</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Flaechenwidmungsplan</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/PlanTypeNameValue/sectoralSpatialPlanningProgram">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/plu"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="de">Sektorale Raumordnungsprogramme konkretisieren die Ziele des Landes NÖ für einzelne Landesteile und legen Maßnahmen verbindlich fest. Sie sind die Grundlage für die weitere räumliche Entwicklung Niederösterreichs.</skos:definition>
    <skos:definition xml:lang="en">Sectoral spatial planning programs specify the goals of the Province of Lower Austria for individual parts of the country and set binding measures. They form the basis for the further spatial development of Lower Austria.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue"/>
    <skos:notation>sectoralSpatialPlanningProgram</skos:notation>
    <skos:prefLabel xml:lang="de">Sektorales Raumordnungsprogramm</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Sectoral spatial planning program</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/PlanTypeNameValue/greenArea">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/plu"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/lu"/>
    <skos:definition xml:lang="en">Zones to be kept undeveloped to provide steady conditions for agricultural and forestry use, tourism and recreational purposes as well as to foster climate and sanitation; to preserve the characteristics of towns and landscapes and to retain traditional settlement patterns. Provide a substantial basis for the protection and restoration of the ecosystem.</skos:definition>
    <skos:definition xml:lang="de">Flaechen, die die Funktion für die Land- und Forstwirtschaft, die Erholung und den Tourismus, die Siedlungshygiene und die Klimaverhaeltnisse, die Siedlungs- und Raumgliederung, das typische Orts- und Landschaftsbild, die Sicherung oder Wiederherstellung eines ausgewogenen Natur- und Landschaftshaushalts beibehalten sollen und daher von Bebauung freigehalten werden müssen.</skos:definition>
    <skos:inScheme rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue"/>
    <skos:notation>greenArea</skos:notation>
    <skos:prefLabel xml:lang="de">Gruenzone</skos:prefLabel>
    <skos:prefLabel xml:lang="en">green area</skos:prefLabel>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue"/>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://registry.inspire.gv.at/codelist/PlanTypeNameValue">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <dcterms:conformsTo rdf:resource="http://inspire.ec.europa.eu/applicationschema/base2"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-05T14:30:11+00:00</dcterms:created>
    <dcterms:description xml:lang="de">Typen von Plänen gemäß Definition in den Mitgliedstaaten.</dcterms:description>
    <dcterms:description xml:lang="en">Types of plans as defined in the Member States.</dcterms:description>
    <dcterms:publisher rdf:resource="https://registry.inspire.gv.at/dataprovider/0021"/>
    <dcterms:subject rdf:resource="http://inspire.ec.europa.eu/theme/"/>
    <dcterms:title xml:lang="de">Bezeichnung des Plantyps</dcterms:title>
    <dcterms:title xml:lang="en">Plan Type Name</dcterms:title>
    <dcterms:type rdf:resource="http://inspire.ec.europa.eu/codelist/PlanTypeNameValue"/>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue/zoningPlan"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue/gravelControlPlan"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue/greenArea"/>
    <skos:hasTopConcept rdf:resource="https://registry.inspire.gv.at/codelist/PlanTypeNameValue/sectoralSpatialPlanningProgram"/>
    <skos:scopeNote xml:lang="en">INSPIRE governance level: national-technical</skos:scopeNote>
    <skos:scopeNote xml:lang="en">INSPIRE extensibility: open, internal by value</skos:scopeNote>
    <ns1:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
</rdf:RDF>
