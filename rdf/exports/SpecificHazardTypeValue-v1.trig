        dcterms:title "Specific Hazard Type"@de,
            "Specific Hazard Type"@en ;
        owl:versionInfo "1.0.0" ;
        skos:hasTopConcept <https://registry.inspire.gv.at/codelist/SpecificHazardTypeValue/coldWave>,
            <https://registry.inspire.gv.at/codelist/SpecificHazardTypeValue/flood>,
            <https://registry.inspire.gv.at/codelist/SpecificHazardTypeValue/fluviatileErosion>,
            <https://registry.inspire.gv.at/codelist/SpecificHazardTypeValue/heatWave>,
