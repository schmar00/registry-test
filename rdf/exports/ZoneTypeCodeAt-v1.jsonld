    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The aim of this development program is to define supra-local guidelines for the spatially compatible expansion of wind energy in Styria."
      },
      {
        "@language": "de",
        "@value": "Dieses Entwicklungsprogramm hat die Festlegung von überörtlichen Vorgaben zum raumverträglichen Ausbau der Windenergie in der Steiermark zum Ziel."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"
