  {
    "@id": "https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt/ALSAG_Gebiete",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://purl.org/dc/terms/conformsTo": [
      {
        "@id": "http://inspire.ec.europa.eu/applicationschema/am"
      }
    ],
    "http://purl.org/dc/terms/subject": [
      {
        "@id": "http://inspire.ec.europa.eu/theme/am"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "de",
        "@value": "Gebiete gemaess Altlastensanierungsgesetz (ALSAG). Vom Landeshauptmann gemeldete Altablagerungen (alte Deponien) und Altstandorte (ehemalige Fabriken), die vor 1989 kontaminiert sein koennen, werden nach Durchführung einer Gefaehrdungsabschaetzung und Feststellung einer erheblichen Gefaehrdung für die Umwelt und Gesundheit (nach Bewertung durch das Umweltbundesamt) als sicherungs- und sanierungsbeduerftige Altlasten vom Bundesminister in der AltlastenVO ausgewiesen. Die Bewertung der Dringlichkeit von erforderlichen Sanierungsmassnahmen werden mittels drei Prioritätenklassen unterschieden. Eine Einstufung in die Prioritätenklasse 1 bedeutet die höechste Dringlichkeit von Sanierungsmaßnahmen. Nach Bestaetigung des Sanierungserfolges werden die Daten zur Altlast vom Umweltbundesamt aktualisiert und in der AltlastenVO vom Bundesminister als sanierte oder gesicherte Altlast gekennzeichnet."
      },
      {
        "@language": "en",
        "@value": "Areas pursuant to the Contaminated Sites Remediation Act."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://registry.inspire.gv.at/codelist/ZoneTypeCodeAt"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "ALSAG_Gebiete"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "de",
        "@value": "Gebiete gemaess Altlastensanierungsgesetz"
      },
      {
        "@language": "en",
        "@value": "Contaminated Site Area"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "INSPIRE governance level: national-technical"
