<https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe:1> {
    <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/AuenObjekt> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/hb> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:broader <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare> ;
        skos:definition "Inventar der Auobjekte Österreichs (Minimalfläche 20 ha) und Detailkartierung in Kärnten und Steiermark (Minimalfläche 5 ha). 822 Auenobjekte mit einer Gesamtfläche von 95.541 ha. , Credits: Werner LAZOWSKI und Ulrich SCHWARZ, Aueninventar Österreich: Bericht zur bundesweiten Übersicht der Auobjekte, Wien, 2011; Siehe: https://www.bmlrt.gv.at/dam/jcr:988293c2-2c0e-424d-86dd-91721197be61/%C3%96sterreichisches%20Aueninventar_Final_20111108.pdf"@de,
            "Inventory of floodplain objects in Austria (minimum area 20 ha) and detailed mapping in Carinthia and Styria (minimum area 5 ha).822 floodplain properties with a total area of 95,541 ha were designated.  Credits: Werner LAZOWSKI and Ulrich SCHWARZ, Aueninventar Austria: Report on the nationwide overview of floodplain objects, Vienna, 2011; Reference: Siehe: https://www.bmlrt.gv.at/dam/jcr:988293c2-2c0e-424d-86dd-91721197be61/%C3%96sterreichisches%20Aueninventar_Final_20111108.pdf"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe> ;
        skos:notation "AuenObjekt" ;
        skos:prefLabel "Auenobjekt"@de,
            "Floodplain object"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/FeuchtgebietsObjekt> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/hb> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:broader <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare> ;
        skos:definition "Abgrenzung der Feuchtgebiete gemäß Feuchtgebietsinventar, Abgrenzung generalisiert; Insgesamt umfasst das Feuchtgebietsinventar Österreich im November 2008 insgesamt 889 Feuchtgebiete. Die Gesamtfläche der beschriebenen Gebiete beträgt mehr als 2744.0 km2. Das Inventar wird laufend durch Expertenmeldungen laufend erweitert."@de,
            "Invntory of Wetlands in Austria; total area of wetlands assessd in Nov. 2008 ammounts to 2744 km2 divided into 889 wetland objects"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe> ;
        skos:notation "FeuchtgebietsObjekt" ;
        skos:prefLabel "Feuchtgebietsobjekt"@de,
            "Wetland object"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/MoorObjekt> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/hb> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:broader <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare> ;
        skos:definition "Moorflächen aus dem Moorschutzkatalog (Steiner et al. 1992), Hrsg.: Bundesministerium für Gesundheit und Umweltschutz, Credits: Gert Michael STEINER unter Mitarbeit von P. Englmaier, M. Fink, F, Grünweis, I. Höfner I. Korner, A. Ströhle und W. Wolf (im Auftrag des Bundesministeriums für Gesundheit und Umweltschutz), Wien, 1992"@de,
            "Bog and mire inventory"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe> ;
        skos:notation "MoorObjekt" ;
        skos:prefLabel "Moorobjekt"@de,
            "Bog and Mire object"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

    <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/TrockenrasenObjekt> a skos:Concept ;
        dcterms:conformsTo <http://inspire.ec.europa.eu/applicationschema/hb> ;
        dcterms:subject <http://inspire.ec.europa.eu/theme/hb> ;
        skos:broader <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe/Naturschutzinventare> ;
        skos:definition "Flächenhaft abgegrenzte Trockenrasen Österreichs mit Stand 1986; vielfach schon sehr veralterte Information, Gesamtanzahl der flächenhaft abgegrenzten Trockenrasen: 682. Erstabgrenzung anhand der topographischen Karte ÖK 50; Abgrenzung vor allem in Ostösterreich (Sauberer), Ergänzung im Jahr 2008 durch VINCA und Aufbereitung durch Digitalisierung."@de,
            "Mapping of dry meadows in Austria"@en ;
        skos:inScheme <https://registry.inspire.gv.at/codelist/generalisierteHabitatkomplexe> ;
        skos:notation "TrockenrasenObjekt" ;
        skos:prefLabel "Trockenrasenobjekt"@de,
            "Dry meadow object"@en ;
        skos:scopeNote "INSPIRE governance level: national-technical"@en ;
        ns1:status <http://inspire.ec.europa.eu/registry/status/valid> .

