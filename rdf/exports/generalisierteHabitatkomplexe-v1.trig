        dcterms:created "2026-05-05T14:30:11+00:00"^^xsd:dateTime ;
        dcterms:description "generalisierte Habitatkomplexe, die eine funktionalen Zusammenhang zwischen mehreren Biotoptypen darstellen und im Rahmen von Einzelprojekten erhoben werden"@de,
            "generalized habitat complexes that establish a functional relation between different habitat types and that are assessd in single projects"@en ;
